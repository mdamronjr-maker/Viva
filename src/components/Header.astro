---
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || (p !== '/' && path.startsWith(p));
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label="Viva Wellness Co. — home">
      <span class="brand__mark">V</span>
      <span class="brand__word">Viva Wellness Co.</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <a href="/" class:list={["nav__link", isActive('/') && 'is-active']}>Home</a>
      <a href="/about" class:list={["nav__link", isActive('/about') && 'is-active']}>About</a>
      <a href="/services" class:list={["nav__link", isActive('/services') && 'is-active']}>Services</a>
      <a href="/quiz" class:list={["nav__link", isActive('/quiz') && 'is-active']}>Find Protocol</a>
      <a href="/contact" class:list={["nav__link", isActive('/contact') && 'is-active']}>Contact</a>
    </nav>

    <a href="https://vivawellnessco.glossgenius.com/" class="btn btn--bronze nav__cta" target="_blank" rel="noopener">
      Start Protocol
    </a>

    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span><span></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(18px) saturate(140%);
    background: rgba(12, 10, 9, 0.72);
    border-bottom: 1px solid var(--rule);
  }
  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 2rem;
    padding-top: 1.1rem;
    padding-bottom: 1.1rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-display);
    font-weight: 480;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
  }
  .brand__mark {
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    background: var(--bronze);
    color: var(--ink);
    font-weight: 600;
    font-size: 1.05rem;
    line-height: 1;
    border-radius: 2px;
  }
  .nav {
    display: flex;
    gap: 2.2rem;
    justify-content: center;
  }
  .nav__link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(245, 241, 234, 0.6);
    padding: 0.4rem 0;
    border-bottom: 1px solid transparent;
    transition: color 200ms var(--ease), border-color 200ms var(--ease);
  }
  .nav__link:hover { color: var(--paper); }
  .nav__link.is-active { color: var(--paper); border-bottom-color: var(--bronze); }
  .nav__cta { padding: 0.75rem 1.1rem; }

  .nav-toggle { display: none; }

  @media (max-width: 900px) {
    .site-header__inner { grid-template-columns: auto 1fr auto; }
    .nav { display: none; }
    .nav-toggle {
      display: grid; gap: 5px;
      width: 32px; height: 32px;
      align-content: center; justify-content: center;
    }
    .nav-toggle span {
      display: block; width: 22px; height: 1.5px; background: var(--paper);
    }
    .nav__cta { padding: 0.7rem 1rem; font-size: 0.7rem; }
  }
  @media (max-width: 540px) {
    .brand__word { display: none; }
  }

  /* Mobile menu open */
  :global(body.menu-open) .site-mobile-nav { transform: translateY(0); }
</style>

<nav class="site-mobile-nav" aria-label="Mobile">
  <a href="/">Home</a>
  <a href="/about">About</a>
  <a href="/services">Services</a>
  <a href="/quiz">Find Protocol</a>
  <a href="/contact">Contact</a>
  <a href="https://vivawellnessco.glossgenius.com/" target="_blank" rel="noopener" class="mobile-cta">Start Protocol →</a>
</nav>

<style>
  .site-mobile-nav {
    position: fixed;
    inset: 64px 0 0 0;
    z-index: 90;
    background: var(--ink);
    transform: translateY(-110%);
    transition: transform 360ms var(--ease);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 2.5rem var(--gutter);
    border-bottom: 1px solid var(--rule);
  }
  .site-mobile-nav a {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 380;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .mobile-cta {
    margin-top: 1.5rem;
    color: var(--bronze);
    font-style: italic;
  }
  @media (min-width: 901px) { .site-mobile-nav { display: none; } }
</style>

<script>
  const toggle = document.querySelector('.nav-toggle');
  toggle?.addEventListener('click', () => {
    const open = document.body.classList.toggle('menu-open');
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  document.querySelectorAll('.site-mobile-nav a').forEach(a =>
    a.addEventListener('click', () => document.body.classList.remove('menu-open'))
  );
</script>
