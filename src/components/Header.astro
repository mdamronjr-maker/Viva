---
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || (p !== '/' && path.startsWith(p));
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="brand" aria-label="Viva Wellness Co. · home">
      <img
        src="/viva-logo-paper.png"
        alt="Viva Wellness Co."
        class="brand__logo"
        width="240"
        height="52"
      />
    </a>

    <nav class="nav" aria-label="Primary">
      <a href="/" class:list={["nav__link", isActive('/') && 'is-active']}>Home</a>
      <a href="/about" class:list={["nav__link", isActive('/about') && 'is-active']}>About</a>
      <a href="/services" class:list={["nav__link", isActive('/services') && 'is-active']}>Programs</a>
      <a href="/blog" class:list={["nav__link", isActive('/blog') && 'is-active']}>Blog</a>
      <a href="/contact" class:list={["nav__link", isActive('/contact') && 'is-active']}>Contact</a>
    </nav>

    <a href="https://vivawellnessco.glossgenius.com/?utm_source=vivawellnessco&utm_medium=cta&utm_content=header_nav" target="_blank" rel="noopener" class="btn btn--bronze nav__cta">
      Start Your Protocol
    </a>

    <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="site-mobile-nav">
      <span></span><span></span>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    backdrop-filter: blur(18px) saturate(140%);
    background: rgba(12, 10, 9, 0.72);
    border-bottom: 1px solid var(--rule);
  }
  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 2rem;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    line-height: 0;
  }
  .brand__logo {
    height: 32px;
    width: auto;
    display: block;
  }
  @media (max-width: 540px) {
    .brand__logo { height: 26px; }
  }
  .nav {
    display: flex;
    gap: 1.6rem;
    justify-content: center;
  }
  .nav__link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(245, 241, 234, 0.6);
    padding: 0.4rem 0;
    border-bottom: 1px solid transparent;
    transition: color 200ms var(--ease), border-color 200ms var(--ease);
  }
  .nav__link:hover { color: var(--paper); }
  .nav__link.is-active { color: var(--paper); border-bottom-color: var(--bronze); }
  .nav__cta { padding: 0.75rem 1.1rem; }

  .nav-toggle { display: none; }

  @media (max-width: 900px) {
    .site-header__inner { grid-template-columns: auto 1fr auto; }
    .nav { display: none; }
    .nav-toggle {
      display: grid; gap: 5px;
      width: 32px; height: 32px;
      align-content: center; justify-content: center;
    }
    .nav-toggle span {
      display: block; width: 22px; height: 1.5px; background: var(--paper);
      transition: transform 240ms var(--ease), opacity 200ms var(--ease);
      transform-origin: center;
    }
    :global(body.menu-open) .nav-toggle span:first-child {
      transform: translateY(3.25px) rotate(45deg);
    }
    :global(body.menu-open) .nav-toggle span:last-child {
      transform: translateY(-3.25px) rotate(-45deg);
    }
    .nav__cta { padding: 0.7rem 1rem; font-size: 0.68rem; }
  }
  @media (max-width: 560px) {
    .nav__cta { display: none; }
    .site-header__inner { grid-template-columns: auto 1fr auto; }
  }

  /* Mobile menu open */
  :global(body.menu-open) .site-mobile-nav { transform: translateY(0); }
</style>

<nav class="site-mobile-nav" id="site-mobile-nav" aria-label="Mobile" inert>
  <a href="/">Home</a>
  <a href="/about">About</a>
  <a href="/services">Programs</a>
  <a href="/blog">Blog</a>
  <a href="/contact">Contact</a>
  <a href="https://vivawellnessco.glossgenius.com/?utm_source=vivawellnessco&utm_medium=cta&utm_content=header_mobile" target="_blank" rel="noopener" class="mobile-cta">Start Your Protocol →</a>
</nav>

<style>
  .site-mobile-nav {
    position: fixed;
    inset: 64px 0 0 0;
    z-index: 90;
    background: var(--ink);
    transform: translateY(-110%);
    transition: transform 360ms var(--ease);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 2.5rem var(--gutter);
    border-bottom: 1px solid var(--rule);
  }
  .site-mobile-nav a {
    font-family: var(--font-display);
    font-size: 1.9rem;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--rule);
  }
  .mobile-cta {
    margin-top: 1.5rem;
    color: var(--bronze);
    font-family: var(--font-display-italic) !important;
    font-style: italic;
    text-transform: none !important;
  }
  @media (min-width: 901px) { .site-mobile-nav { display: none; } }
</style>

<script>
  // Re-bind on every page navigation so view transitions work cleanly.
  // Element-level listeners die with the DOM; document-level keydown is bound
  // once via a module-scoped flag to avoid accumulating duplicates.
  let escBound = false;

  function bindHeader() {
    const toggle = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
    const mobileNav = document.getElementById('site-mobile-nav');
    if (!toggle || !mobileNav) return;

    function setOpen(open: boolean) {
      document.body.classList.toggle('menu-open', open);
      toggle!.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (open) mobileNav!.removeAttribute('inert');
      else mobileNav!.setAttribute('inert', '');
    }

    toggle.addEventListener('click', () => {
      setOpen(!document.body.classList.contains('menu-open'));
    });
    mobileNav.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setOpen(false))
    );

    if (!escBound) {
      escBound = true;
      document.addEventListener('keydown', (e) => {
        if (e.key !== 'Escape' || !document.body.classList.contains('menu-open')) return;
        document.body.classList.remove('menu-open');
        const t = document.querySelector('.nav-toggle') as HTMLButtonElement | null;
        t?.setAttribute('aria-expanded', 'false');
        document.getElementById('site-mobile-nav')?.setAttribute('inert', '');
        t?.focus();
      });
    }
  }

  // Astro fires astro:page-load on initial load AND every router navigation
  document.addEventListener('astro:page-load', bindHeader);
</script>
