---
import '../styles/global.css';
import '../styles/fonts.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileStickyCta from '../components/MobileStickyCta.astro';

const {
  title = 'Concierge Telehealth in Austin | Viva Wellness Co.',
  description = 'Concierge peptide therapy, GLP-1 weight loss, hormone optimization, and recovery protocols delivered virtually from Austin, TX. Provider-led. Texas, Colorado, Florida, and Iowa.',
  ogImage = '/og-image.jpg',
  ogType = 'website',
  publishDate,
  modifiedDate,
  author = 'Liliana Damron, APRN, FNP-BC',
  schema,
  noindex = false,
} = Astro.props;

const normalizedPath = Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '');
const canonicalURL = new URL(normalizedPath, Astro.site).href;
const isHome = normalizedPath === '/';

// Staging/feedback builds (set PUBLIC_DEPLOY_TARGET=feedback at build time) must
// never be indexed: they mirror the live domain and canonicalize to it, so an
// indexable mirror would compete as duplicate content / a parallel "live" site.
const isFeedbackBuild = import.meta.env.PUBLIC_DEPLOY_TARGET === 'feedback';

// Resolve the og:image. If a caller passed an explicit non-default value,
// use it. Otherwise derive from the path: every static page and blog post
// has its own PNG generated at build time by src/pages/og/[...route].png.ts.
function ogForPath(p: string): string {
  if (p === '/') return '/og/home.png';
  if (['/about', '/services', '/partners', '/contact', '/privacy', '/terms', '/blog'].includes(p)) {
    return `/og${p}.png`;
  }
  if (p.startsWith('/blog/')) return `/og${p}.png`;
  return '/og-image.jpg';
}
const resolvedOgImage = ogImage && ogImage !== '/og-image.jpg' ? ogImage : ogForPath(normalizedPath);
// Cache-buster: bump this when the OG image *design* changes so platforms
// that already cached the preview for a shared URL (Slack, iMessage,
// LinkedIn, etc.) refetch instead of serving the stale thumbnail.
// v2 = Matt Johnson photo background + Fraunces italic title (May 2026).
// v3 = state taglines now include Iowa (June 2026).
const OG_CACHE_VERSION = '3';
const ogImageURL = new URL(`${resolvedOgImage}?v=${OG_CACHE_VERSION}`, Astro.site).href;
const siteName = 'Viva Wellness Co.';

// Sitewide Organization + WebSite schema (always present)
const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'MedicalBusiness',
      '@id': 'https://vivawellnessco.com/#organization',
      name: 'Viva Wellness Co.',
      alternateName: 'Viva Wellness',
      url: 'https://vivawellnessco.com',
      logo: 'https://vivawellnessco.com/viva-logo-paper.png',
      image: 'https://vivawellnessco.com/viva-logo-paper.png',
      description: 'Concierge telehealth practice delivering peptide therapy, hormone optimization, GLP-1 weight loss protocols, and recovery medicine. Austin, Texas.',
      founder: {
        '@type': 'Person',
        '@id': 'https://vivawellnessco.com/about#liliana',
        name: 'Liliana Damron',
        honorificSuffix: 'APRN, FNP-BC',
        jobTitle: 'Family Nurse Practitioner, Founder',
      },
      address: {
        '@type': 'PostalAddress',
        streetAddress: '5900 Balcones Dr #19640',
        addressLocality: 'Austin',
        addressRegion: 'TX',
        postalCode: '78731',
        addressCountry: 'US',
      },
      areaServed: [
        { '@type': 'State', name: 'Texas' },
        { '@type': 'State', name: 'Colorado' },
        { '@type': 'State', name: 'Florida' },
        { '@type': 'State', name: 'Iowa' },
      ],
      medicalSpecialty: [
        'Peptide Therapy',
        'Hormone Therapy',
        'Weight Management',
        'Performance Medicine',
        'Regenerative Medicine',
      ],
      priceRange: '$$$',
      telephone: '+1-737-210-7283',
      email: 'info@vivawellnessco.com',
      sameAs: [
        'https://www.instagram.com/vivawellnessatx',
      ],
      // aggregateRating intentionally omitted. Google requires schema ratings
      // to be verifiable and current; hardcoded counts drift and can cost the
      // entire structured-result eligibility. Wire a Worker to Places API on a
      // schedule if you want this back in.
    },
    {
      '@type': 'WebSite',
      '@id': 'https://vivawellnessco.com/#website',
      url: 'https://vivawellnessco.com',
      name: siteName,
      description: 'Concierge telehealth peptide therapy and hormone optimization.',
      publisher: { '@id': 'https://vivawellnessco.com/#organization' },
      inLanguage: 'en-US',
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#110e0b" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  {(noindex || isFeedbackBuild) && <meta name="robots" content="noindex, nofollow" />}

  {/* Open Graph */}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  {publishDate && <meta property="article:published_time" content={publishDate} />}
  {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}
  {ogType === 'article' && <meta property="article:author" content={author} />}

  {/* Twitter */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  {/* Schema.org JSON-LD - sitewide org + website */}
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  {/* Page-specific schema, passed in via props */}
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  {/* Hero LCP preload · only the home page. Responsive via imagesrcset. */}
  {isHome && (
    <link
      rel="preload"
      as="image"
      href="/matt-johnson-hd.jpg"
      imagesrcset="/matt-johnson-hd-sm.jpg 800w, /matt-johnson-hd.jpg 1600w"
      imagesizes="100vw"
      fetchpriority="high"
    />
  )}

  {/* Preconnect to the booking destination + the Turnstile challenge host */}
  <link rel="preconnect" href="https://vivawellnessco.glossgenius.com" crossorigin />
  <link rel="dns-prefetch" href="https://vivawellnessco.glossgenius.com" />
  <link rel="preconnect" href="https://challenges.cloudflare.com" crossorigin />

  {/* RSS feed for the blog · power readers, news aggregators */}
  <link rel="alternate" type="application/rss+xml" title="Viva Wellness Co. Blog" href="/rss.xml" />

  {/* PWA manifest */}
  <link rel="manifest" href="/site.webmanifest" />

  {/* Fonts · SELF-HOSTED (privacy/compliance + perf, no Google CDN). @font-face is in fonts.css; preload the critical cuts so the Fraunces headline + Geist body paint fast. */}
  <link rel="preload" href="/fonts/fraunces-normal-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/geist-normal-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/geistmono-normal-latin.woff2" as="font" type="font/woff2" crossorigin />

  <ClientRouter />

  {/* Cloudflare Turnstile · loads once, persists across view transitions.
      Widgets render explicitly in each form's init (see contact/index/refer). */}
  <script is:inline async defer src="https://challenges.cloudflare.com/turnstile/v0/api.js"></script>

  {/* Privacy-respecting analytics · loads only when PUBLIC_PLAUSIBLE_DOMAIN
      is set in Cloudflare Pages env vars (e.g. "vivawellnessco.com"). No
      cookies, no PII, no cookie banner needed. Tracks pageviews + the
      built-in /api/lead form-submit event via the 404 / outbound plugins. */}
  {import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN && (
    <script
      defer
      data-domain={import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN}
      src="https://plausible.io/js/script.outbound-links.js"
    ></script>
  )}
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  <Header />
  <main id="main" tabindex="-1">
    <slot />
  </main>
  <Footer />
  <MobileStickyCta />

  <script>
    // Scroll-driven reveal for cards and grid items. Progressive enhancement:
    // CSS keeps elements visible until JS opts them into the .to-reveal class,
    // then the IntersectionObserver brings them back with .is-revealed.
    function initScrollReveal() {
      const selector = '.pillar, .program, .testimonial:not(.testimonial--lead), .faq__item, .post-card, .post-related__item, .nf-card, .standard, .tier, .state, .contact-side__panel, .pulse-divider';
      const els = document.querySelectorAll(selector);
      if (!els.length) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      els.forEach((el) => el.classList.add('to-reveal'));

      const obs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-revealed');
              obs.unobserve(e.target);
            }
          }
        },
        { threshold: 0.05, rootMargin: '0px 0px -6% 0px' }
      );
      els.forEach((el) => obs.observe(el));
    }
    document.addEventListener('astro:page-load', initScrollReveal);

    // Booking links open in a centered popup over the page (GlossGenius can't be iframed).
    // Falls back to normal navigation if the browser blocks the popup.
    function initBookingPopup() {
      document.querySelectorAll('a[href*="glossgenius.com"]').forEach((a) => {
        if (a.dataset.popupBound) return;
        a.dataset.popupBound = '1';
        a.addEventListener('click', (e) => {
          const w = 480;
          const h = Math.min(880, (window.screen.availHeight || 900) - 60);
          const left = Math.max(0, Math.round(((window.screen.availWidth || 1280) - w) / 2));
          const top = Math.max(0, Math.round(((window.screen.availHeight || 900) - h) / 2));
          const popup = window.open(
            a.href,
            'viva-booking',
            `width=${w},height=${h},left=${left},top=${top},scrollbars=yes,resizable=yes`
          );
          if (popup) { e.preventDefault(); popup.focus(); }
        });
      });
    }
    document.addEventListener('astro:page-load', initBookingPopup);

    // Subtle parallax on the Vega backdrop images — adds depth/motion.
    function initParallax() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const sel = '.qx__bg, .section__bg, .testimonials__bg, .cta__bg, .services-hero__bg, .partners-hero__bg, .about-hero__bg';
      const imgs = Array.from(document.querySelectorAll(sel));
      if (!imgs.length) return;
      imgs.forEach((img) => { img.style.height = '128%'; img.style.top = '-14%'; img.style.willChange = 'transform'; });
      function update() {
        const vh = window.innerHeight;
        for (const img of imgs) {
          const host = img.parentElement;
          if (!host) continue;
          const r = host.getBoundingClientRect();
          if (r.bottom < -240 || r.top > vh + 240) continue;
          const move = Math.max(-70, Math.min(70, (r.top + r.height / 2 - vh / 2) * -0.07));
          img.style.transform = 'translate3d(0,' + move.toFixed(1) + 'px,0)';
        }
      }
      let ticking = false;
      function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(() => { update(); ticking = false; }); } }
      if (window.__pxScroll) { window.removeEventListener('scroll', window.__pxScroll); window.removeEventListener('resize', window.__pxScroll); }
      window.__pxScroll = onScroll;
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      update();
    }
    document.addEventListener('astro:page-load', initParallax);

    // Subtle magnetic pull on buttons (hover-capable, fine-pointer devices only).
    function initMagnetic() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
      document.querySelectorAll('.btn').forEach((btn) => {
        if (btn.dataset.magBound) return;
        btn.dataset.magBound = '1';
        btn.addEventListener('pointermove', (e) => {
          const r = btn.getBoundingClientRect();
          const x = Math.max(-6, Math.min(6, (e.clientX - (r.left + r.width / 2)) * 0.25));
          const y = Math.max(-6, Math.min(6, (e.clientY - (r.top + r.height / 2)) * 0.25));
          btn.style.transform = `translate(${x.toFixed(1)}px, ${(y - 1).toFixed(1)}px)`;
        });
        btn.addEventListener('pointerleave', () => { btn.style.transform = ''; });
      });
    }
    document.addEventListener('astro:page-load', initMagnetic);
  </script>
</body>
</html>
