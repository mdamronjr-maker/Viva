---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileStickyCta from '../components/MobileStickyCta.astro';

const {
  title = 'Concierge Telehealth in Austin | Viva Wellness Co.',
  description = 'Performance medicine delivered virtually from Austin, TX. Provider-led GLP-1 weight loss, hormone optimization, recovery, and recomposition protocols. Texas, Colorado, and Florida.',
  ogImage = '/og-image.jpg',
  ogType = 'website',
  publishDate,
  modifiedDate,
  author = 'Liliana Damron, APRN, FNP-BC',
  schema,
  noindex = false,
} = Astro.props;

const normalizedPath = Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '');
const canonicalURL = new URL(normalizedPath, Astro.site).href;
const isHome = normalizedPath === '/';

// Resolve the og:image. If a caller passed an explicit non-default value,
// use it. Otherwise derive from the path: every static page and blog post
// has its own PNG generated at build time by src/pages/og/[...route].png.ts.
function ogForPath(p: string): string {
  if (p === '/') return '/og/home.png';
  if (['/about', '/services', '/contact', '/privacy', '/terms', '/blog'].includes(p)) {
    return `/og${p}.png`;
  }
  if (p.startsWith('/blog/')) return `/og${p}.png`;
  return '/og-image.jpg';
}
const resolvedOgImage = ogImage && ogImage !== '/og-image.jpg' ? ogImage : ogForPath(normalizedPath);
const ogImageURL = new URL(resolvedOgImage, Astro.site).href;
const siteName = 'Viva Wellness Co.';

// Sitewide Organization + WebSite schema (always present)
const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'MedicalBusiness',
      '@id': 'https://vivawellnessco.com/#organization',
      name: 'Viva Wellness Co.',
      alternateName: 'Viva Wellness',
      url: 'https://vivawellnessco.com',
      logo: 'https://vivawellnessco.com/viva-logo-paper.png',
      image: 'https://vivawellnessco.com/viva-logo-paper.png',
      description: 'Concierge telehealth practice delivering performance medicine, hormone optimization, GLP-1 weight loss protocols, and recovery therapy. Austin, Texas.',
      founder: {
        '@type': 'Person',
        '@id': 'https://vivawellnessco.com/about#liliana',
        name: 'Liliana Damron',
        honorificSuffix: 'APRN, FNP-BC',
        jobTitle: 'Family Nurse Practitioner, Founder',
      },
      address: {
        '@type': 'PostalAddress',
        streetAddress: '5900 Balcones Dr #19640',
        addressLocality: 'Austin',
        addressRegion: 'TX',
        postalCode: '78731',
        addressCountry: 'US',
      },
      areaServed: [
        { '@type': 'State', name: 'Texas' },
        { '@type': 'State', name: 'Colorado' },
        { '@type': 'State', name: 'Florida' },
      ],
      medicalSpecialty: [
        'Hormone Therapy',
        'Weight Management',
        'Performance Medicine',
        'Regenerative Medicine',
      ],
      priceRange: '$$$',
      telephone: '+1-737-210-7283',
      email: 'info@vivawellnessco.com',
      sameAs: [
        'https://www.instagram.com/vivawellnessatx',
      ],
      // aggregateRating intentionally omitted. Google requires schema ratings
      // to be verifiable and current; hardcoded counts drift and can cost the
      // entire structured-result eligibility. Wire a Worker to Places API on a
      // schedule if you want this back in.
    },
    {
      '@type': 'WebSite',
      '@id': 'https://vivawellnessco.com/#website',
      url: 'https://vivawellnessco.com',
      name: siteName,
      description: 'Concierge telehealth performance medicine.',
      publisher: { '@id': 'https://vivawellnessco.com/#organization' },
      inLanguage: 'en-US',
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="theme-color" content="#0c0a09" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  {noindex && <meta name="robots" content="noindex, nofollow" />}

  {/* Open Graph */}
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={ogImageURL} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  {publishDate && <meta property="article:published_time" content={publishDate} />}
  {modifiedDate && <meta property="article:modified_time" content={modifiedDate} />}
  {ogType === 'article' && <meta property="article:author" content={author} />}

  {/* Twitter */}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL} />

  {/* Schema.org JSON-LD - sitewide org + website */}
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  {/* Page-specific schema, passed in via props */}
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

  {/* Hero LCP preload · only the home page. Responsive via imagesrcset. */}
  {isHome && (
    <link
      rel="preload"
      as="image"
      href="/matt-johnson.jpg"
      imagesrcset="/matt-johnson-sm.jpg 800w, /matt-johnson.jpg 1600w"
      imagesizes="100vw"
      fetchpriority="high"
    />
  )}

  {/* DNS prefetch for the booking destination */}
  <link rel="dns-prefetch" href="https://vivawellnessco.glossgenius.com" />

  {/* RSS feed for the blog · power readers, news aggregators */}
  <link rel="alternate" type="application/rss+xml" title="Viva Wellness Co. Blog" href="/rss.xml" />

  {/* PWA manifest */}
  <link rel="manifest" href="/site.webmanifest" />

  {/* Fonts · preconnect, then load stylesheet directly (faster than CSS @import) */}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..600,0..100;1,9..144,300..600,0..100&family=Inter:ital,wght@0,300..600;1,300..600&display=swap"
  />

  <ClientRouter />
</head>
<body>
  <a href="#main" class="skip-link">Skip to main content</a>
  <Header />
  <main id="main" tabindex="-1">
    <slot />
  </main>
  <Footer />
  <MobileStickyCta />

  <script>
    // Scroll-driven reveal for cards and grid items. Progressive enhancement:
    // CSS keeps elements visible until JS opts them into the .to-reveal class,
    // then the IntersectionObserver brings them back with .is-revealed.
    function initScrollReveal() {
      const selector = '.pillar, .program, .testimonial:not(.testimonial--lead), .faq__item, .post-card, .post-related__item, .nf-card, .standard, .tier, .state, .contact-side__panel';
      const els = document.querySelectorAll(selector);
      if (!els.length) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      els.forEach((el) => el.classList.add('to-reveal'));

      const obs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('is-revealed');
              obs.unobserve(e.target);
            }
          }
        },
        { threshold: 0.05, rootMargin: '0px 0px -6% 0px' }
      );
      els.forEach((el) => obs.observe(el));
    }
    document.addEventListener('astro:page-load', initScrollReveal);
  </script>
</body>
</html>
