---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const recent = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---

<Layout
  title="Page not found · Viva Wellness Co."
  description="The page you were looking for isn't here. Find your protocol, book a visit, or head back home."
  noindex={true}
>

  <section class="notfound">
    <div class="container notfound__inner">
      <span class="eyebrow">· 404</span>
      <h1 class="notfound__title">
        This page<br/>
        <span class="italic-display">isn't here.</span>
      </h1>
      <p class="lead">
        Either the link is stale or we moved something. Either way, here's where to go next.
      </p>

      <div class="notfound__cards">
        <a class="nf-card" href="/">
          <span class="nf-card__num">01</span>
          <span class="nf-card__title">Back to home</span>
          <span class="nf-card__desc">Start over from the top.</span>
        </a>
        <a class="nf-card nf-card--featured" href="/#quiz">
          <span class="nf-card__num">02</span>
          <span class="nf-card__title">Find your protocol</span>
          <span class="nf-card__desc">Five questions, ninety seconds.</span>
        </a>
        <a class="nf-card" href="/services">
          <span class="nf-card__num">03</span>
          <span class="nf-card__title">See programs</span>
          <span class="nf-card__desc">All twelve, with pricing.</span>
        </a>
        <a class="nf-card" href="/contact">
          <span class="nf-card__num">04</span>
          <span class="nf-card__title">Get in touch</span>
          <span class="nf-card__desc">Call, message, or email.</span>
        </a>
      </div>

      {recent.length > 0 && (
        <div class="nf-recent">
          <span class="eyebrow">· Or read something useful</span>
          <ul class="nf-recent__list">
            {recent.map((p) => (
              <li>
                <a href={`/blog/${p.id}`} class="nf-recent__link">
                  <span class="nf-recent__cat">{p.data.category}</span>
                  <span class="nf-recent__title">{p.data.title}</span>
                  <span class="nf-recent__arrow" aria-hidden="true">→</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>

</Layout>

<style>
  .notfound {
    padding: clamp(5rem, 10vw, 9rem) 0 clamp(4rem, 8vw, 7rem);
    position: relative;
    overflow: hidden;
    min-height: 70vh;
  }
  .notfound::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(800px 500px at 75% 30%, rgba(201, 120, 58, 0.14), transparent 60%);
    pointer-events: none;
  }
  .notfound__inner {
    position: relative;
    max-width: 1100px;
  }
  .notfound__title {
    font-size: clamp(2.6rem, 6.8vw, 5.4rem);
    line-height: 1.02;
    letter-spacing: -0.028em;
    margin: 1rem 0 1.5rem;
  }
  .notfound__title .italic-display { color: var(--bronze-bright); }

  .notfound__cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--rule-strong);
    border: 1px solid var(--rule-strong);
    margin-top: 3rem;
  }
  @media (max-width: 800px) { .notfound__cards { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .notfound__cards { grid-template-columns: 1fr; } }
  .nf-card {
    background: var(--ink);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: background 220ms var(--ease);
    border-bottom: none;
  }
  .nf-card:hover { background: var(--ink-2); }
  .nf-card--featured {
    background: var(--ink-2);
    box-shadow: inset 0 2px 0 0 var(--bronze);
  }
  .nf-card__num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--bronze);
    margin-bottom: 0.4rem;
  }
  .nf-card__title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1.1;
    color: var(--paper);
  }
  .nf-card__desc {
    font-size: 0.9rem;
    color: rgba(245, 241, 234, 0.6);
    line-height: 1.5;
  }

  .nf-recent { margin-top: 3.5rem; padding-top: 2.5rem; border-top: 1px solid var(--rule); }
  .nf-recent .eyebrow { display: block; margin-bottom: 1.4rem; }
  .nf-recent__list { display: flex; flex-direction: column; gap: 0; border-top: 1px solid var(--rule); }
  .nf-recent__list li { border-bottom: 1px solid var(--rule); }
  .nf-recent__link {
    display: grid;
    grid-template-columns: 180px 1fr 32px;
    gap: 1.5rem;
    align-items: center;
    padding: 1.2rem 0;
    transition: background 220ms var(--ease);
  }
  .nf-recent__link:hover { background: rgba(201, 120, 58, 0.04); }
  .nf-recent__cat {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bronze);
  }
  .nf-recent__title {
    font-family: var(--font-display-italic);
    font-size: 1.15rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--paper);
  }
  .nf-recent__link:hover .nf-recent__title { color: var(--bronze-bright); }
  .nf-recent__arrow {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--bronze);
    text-align: center;
    transition: transform 220ms var(--ease);
  }
  .nf-recent__link:hover .nf-recent__arrow { transform: translateX(6px); }
  @media (max-width: 600px) {
    .nf-recent__link { grid-template-columns: 1fr; gap: 0.3rem; }
    .nf-recent__arrow { display: none; }
  }
</style>
