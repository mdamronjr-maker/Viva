---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Find Your Protocol | 5-Question Quiz | Viva Wellness Co."
  description="Take our 5-question quiz to find the right concierge telehealth protocol for your goals. GLP-1, TRT, recovery, or recomposition. Match in 90 seconds."
>

  <section class="quiz-shell">
    <div class="container">

      {/* INTRO STATE */}
      <div class="screen screen--intro is-active" data-screen="intro">
        <div class="intro">
          <span class="eyebrow reveal" style="--d: 100ms;">— Find your protocol</span>
          <h1 class="intro__title reveal" style="--d: 250ms;">
            Five questions.<br/>
            <span class="italic-display">One recommendation.</span>
          </h1>
          <p class="lead reveal" style="--d: 450ms;">
            Tell us about your goals, your training, and your starting point.
            We'll match you with the protocol that fits — and the tier that
            makes sense for where you are right now. Takes about ninety seconds.
          </p>
          <div class="intro__meta reveal" style="--d: 600ms;">
            <div class="intro__stat">
              <div class="intro__stat-num">5</div>
              <div class="intro__stat-label">Questions</div>
            </div>
            <div class="intro__stat">
              <div class="intro__stat-num">90s</div>
              <div class="intro__stat-label">Average time</div>
            </div>
            <div class="intro__stat">
              <div class="intro__stat-num">12</div>
              <div class="intro__stat-label">Possible matches</div>
            </div>
          </div>
          <button class="btn btn--bronze intro__cta reveal" style="--d: 800ms;" data-action="start">
            Begin
          </button>
        </div>
      </div>

      {/* QUESTION STATES — populated dynamically */}
      <div class="screen" data-screen="question">
        <div class="quiz-progress">
          <div class="quiz-progress__count">
            <span data-question-num>01</span> <span class="muted">/</span> <span>05</span>
          </div>
          <div class="quiz-progress__bar">
            <div class="quiz-progress__fill" data-progress-fill></div>
          </div>
        </div>

        <div class="question">
          <div class="question__head">
            <span class="index" data-num="—" data-question-eyebrow>Goal</span>
            <h2 class="question__title" data-question-title>What are you here for?</h2>
            <p class="question__lead" data-question-lead>Pick the one that's most true. There's no wrong answer.</p>
          </div>

          <div class="options" data-options></div>

          <div class="quiz-nav">
            <button class="btn-ghost" data-action="back" disabled>← Back</button>
            <button class="btn btn--bronze" data-action="next" disabled>Continue →</button>
          </div>
        </div>
      </div>

      {/* RESULTS STATE */}
      <div class="screen" data-screen="results">
        <div class="results">
          <span class="eyebrow">— Your match</span>
          <div class="results__category" data-result-category>Metabolic Reset</div>
          <h2 class="results__name italic-display" data-result-name>Metabolic Core</h2>
          <div class="results__price">
            <span class="results__amt" data-result-price>$349</span>
            <span class="results__cad">/mo</span>
          </div>

          <div class="results__why">
            <p data-result-why>Based on your answers...</p>
          </div>

          <div class="results__includes">
            <h3>What's in this protocol</h3>
            <ul data-result-includes></ul>
          </div>

          <div class="results__ctas">
            <a href="https://vivawellnessco.glossgenius.com/" target="_blank" rel="noopener" class="btn btn--bronze">Book Your First Visit</a>
            <button class="btn" data-action="restart">Retake the quiz</button>
          </div>

          {/* Soft email opt-in below the fold */}
          <div class="email-opt">
            <span class="eyebrow">— Stay in the loop</span>
            <h3>Want this sent to your inbox?</h3>
            <p>We'll email you the protocol details, what to expect from the first consult, and a couple of articles tailored to your goal. One email per week, max. Unsubscribe anytime.</p>

            <form class="email-opt__form" id="email-opt-form" novalidate>
              <input type="email" name="email" placeholder="your@email.com" required />
              <input type="text" name="_honey" tabindex="-1" autocomplete="off" class="hp" aria-hidden="true" />
              <button type="submit" class="btn btn--ink" id="email-opt-btn">Send it</button>
            </form>
            <div class="email-opt__status" id="email-opt-status" role="status" aria-live="polite"></div>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script is:inline>
(() => {
  // ============ QUIZ DATA ============
  const QUESTIONS = [
    {
      eyebrow: 'Goal',
      title: 'What are you here for?',
      lead: "Pick the one that's most true. There's no wrong answer.",
      type: 'category',
      options: [
        { label: 'Lose fat / reset metabolism',     desc: 'GLP-1 protocols, appetite control, sustainable fat loss', value: 'metabolic' },
        { label: 'Optimize hormones',               desc: 'TRT or HRT calibrated to how you want to feel and perform', value: 'hormone' },
        { label: 'Recover faster / reduce pain',    desc: 'Peptide stacks for joints, tissue repair, post-injury',     value: 'recovery' },
        { label: 'Build muscle while losing fat',   desc: 'Body recomposition for athletes and lifters',               value: 'recomp' },
        { label: 'General optimization / longevity', desc: 'Cellular health, energy, cognition, slow aging',           value: 'longevity' },
      ],
    },
    {
      eyebrow: 'Starting point',
      title: 'Where are you right now?',
      lead: 'How dialed in is your baseline?',
      type: 'score',
      options: [
        { label: "I'm in good shape, just fine-tuning", desc: 'Looking for a small edge or maintenance-level support', score: 1 },
        { label: 'Solid baseline, ready to commit',     desc: "Reasonable health, ready to invest in the next level",  score: 2 },
        { label: 'I need real change',                  desc: "I'm not where I want to be and I'm done waiting",        score: 3 },
      ],
    },
    {
      eyebrow: 'Training',
      title: 'How active are you?',
      lead: 'Be honest. This helps us calibrate intensity.',
      type: 'score',
      options: [
        { label: 'Mostly sedentary',           desc: 'Walks, gardening, occasional movement',                   score: 1 },
        { label: 'Active a few times a week',  desc: 'Gym 2-3x, runs, yoga, cycling, recreational sports',     score: 2 },
        { label: 'Train consistently',          desc: 'Lifter, runner, hybrid athlete, or competitive level',   score: 3 },
      ],
    },
    {
      eyebrow: 'Timeline',
      title: 'How quickly do you want to see results?',
      lead: 'Aggressive timelines mean more aggressive protocols.',
      type: 'score',
      options: [
        { label: "I'm patient. Do it right.",      desc: 'Steady, sustainable, no rush',                        score: 1 },
        { label: 'Steady progress over 3-6 months', desc: 'Real results over a quarter or two',                  score: 2 },
        { label: 'Maximum impact, starting now',    desc: 'I want the strongest protocol I can responsibly run', score: 3 },
      ],
    },
    {
      eyebrow: 'Priorities',
      title: 'What else matters to you?',
      lead: 'Pick all that apply. Or none.',
      type: 'multi',
      options: [
        { label: "I've tried programs that didn't work",  desc: "Need something that actually moves the needle", score: 1 },
        { label: 'I want concierge-level provider access', desc: 'Direct messaging, priority scheduling',         score: 2 },
        { label: "I'm motivated by data and tracking",     desc: 'Labs, biomarkers, measurable outcomes',         score: 1 },
        { label: 'None of these',                          desc: 'Keep it simple',                                score: 0 },
      ],
    },
  ];

  // Tier definitions
  const PROGRAMS = {
    'hrt': {
      category: 'Hormone Optimization',
      name: 'HRT Guidance',
      price: '$99',
      includes: [
        'Provider-led hormone management',
        'Use your insurance for labs and prescriptions',
        'Direct messaging with provider',
        'Quarterly telehealth reviews',
      ],
    },
    'trt': {
      category: 'Hormone Optimization',
      name: 'TRT All Inclusive',
      price: '$199',
      includes: [
        'Compounded testosterone with home delivery',
        'All supplies included (syringes, sharps disposal)',
        'Biannual labs included',
        'Direct messaging and quarterly reviews',
        'Adjuncts available as add-ons',
      ],
    },
    'metabolic-micro': {
      category: 'Metabolic Reset',
      name: 'Metabolic Micro-Dose',
      price: '$199',
      includes: [
        'Micro-dosed compounded medication',
        'Maintenance-level metabolic support',
        'Home delivery and supplies',
        'Provider follow-ups built in',
      ],
    },
    'metabolic-essential': {
      category: 'Metabolic Reset',
      name: 'Metabolic Essential',
      price: '$249',
      includes: [
        'Compounded semaglutide at any dose',
        'Or upgraded multi-compound micro-dose tirzepatide',
        'All supplies and home delivery',
        'Direct provider access',
      ],
    },
    'metabolic-core': {
      category: 'Metabolic Reset',
      name: 'Metabolic Core',
      price: '$349',
      includes: [
        'Stepped-up multi-compound at low to moderate dosing',
        'Stronger appetite control, consistent fat loss',
        'Energy and muscle preservation built in',
        'Provider access plus quarterly reviews',
      ],
    },
    'metabolic-advanced': {
      category: 'Metabolic Reset',
      name: 'Metabolic Advanced',
      price: '$399',
      includes: [
        'Tirzepatide or retatrutide at moderate-to-high dosing',
        'For patients ready to push fat loss further',
        'Close provider monitoring and labs',
        'Adjustment cadence built in',
      ],
    },
    'metabolic-elite': {
      category: 'Metabolic Reset',
      name: 'Metabolic Elite',
      price: '$499',
      includes: [
        'Top-tier retatrutide at moderate-to-high dosing',
        'Maximum appetite control and fat-loss support',
        'Provider concierge-level access',
        'Comprehensive labs and tracking',
      ],
    },
    'recovery-foundational': {
      category: 'Recovery & Repair',
      name: 'Foundational Recovery',
      price: '$349',
      includes: [
        'Provider-led peptide protocols',
        'Reduce inflammation, protect joints',
        'Improve post-workout recovery',
        'Ideal for active patients and lifters',
      ],
    },
    'recovery-regenerative': {
      category: 'Recovery & Repair',
      name: 'Regenerative Healing',
      price: '$499',
      includes: [
        'Higher-level regenerative therapy stack',
        'For post-surgical or chronic joint pain',
        'Cellular-level repair support',
        'Comprehensive provider monitoring',
      ],
    },
    'recomp-total': {
      category: 'Recomp & Performance',
      name: 'Total Recomp',
      price: '$599',
      includes: [
        'Metabolic optimization plus muscle support',
        'Lose fat without losing strength',
        'Designed for athletes and hybrid trainees',
        'Direct provider access',
      ],
    },
    'recomp-peak': {
      category: 'Recomp & Performance',
      name: 'Peak Performance',
      price: '$699',
      includes: [
        'Most comprehensive Viva protocol',
        'Combines metabolic, recovery, and longevity',
        'Concierge-level access and priority scheduling',
        'Includes Essential, Core, and Elite components',
      ],
    },
    'vitality': {
      category: 'Lifestyle & Longevity',
      name: 'Vitality Protocol',
      price: '$249',
      includes: [
        'Cellular health and energy support',
        'Cognition, skin, hair, and sexual wellness',
        'Rotating essential protocols',
        'Personalized adjustments quarterly',
      ],
    },
  };

  // ============ STATE ============
  const state = {
    screen: 'intro',
    qIndex: 0,
    answers: [], // { score: number, value?: string, selected: number[] }
    category: null,
  };

  // ============ DOM ============
  const screens = {
    intro: document.querySelector('[data-screen="intro"]'),
    question: document.querySelector('[data-screen="question"]'),
    results: document.querySelector('[data-screen="results"]'),
  };
  const optionsEl = document.querySelector('[data-options]');
  const titleEl = document.querySelector('[data-question-title]');
  const leadEl = document.querySelector('[data-question-lead]');
  const eyebrowEl = document.querySelector('[data-question-eyebrow]');
  const numEl = document.querySelector('[data-question-num]');
  const fillEl = document.querySelector('[data-progress-fill]');
  const nextBtn = document.querySelector('[data-action="next"]');
  const backBtn = document.querySelector('[data-action="back"]');

  // ============ HELPERS ============
  function showScreen(name) {
    Object.values(screens).forEach(s => s.classList.remove('is-active'));
    screens[name].classList.add('is-active');
    state.screen = name;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function renderQuestion() {
    const q = QUESTIONS[state.qIndex];
    const total = QUESTIONS.length;
    const num = state.qIndex + 1;

    numEl.textContent = String(num).padStart(2, '0');
    eyebrowEl.textContent = q.eyebrow;
    eyebrowEl.setAttribute('data-num', String(num).padStart(2, '0'));
    titleEl.textContent = q.title;
    leadEl.textContent = q.lead;
    fillEl.style.width = `${((num - 1) / total) * 100}%`;

    // Restore previous selection if going back
    const prev = state.answers[state.qIndex];

    optionsEl.innerHTML = '';
    optionsEl.dataset.type = q.type;

    q.options.forEach((opt, i) => {
      const isMulti = q.type === 'multi';
      const isSelected = prev && (
        isMulti
          ? (prev.selected || []).includes(i)
          : prev.selected === i
      );

      const card = document.createElement('button');
      card.type = 'button';
      card.className = 'option' + (isSelected ? ' is-selected' : '');
      card.dataset.idx = String(i);
      card.innerHTML = `
        <span class="option__check" aria-hidden="true"></span>
        <span class="option__body">
          <span class="option__label">${opt.label}</span>
          ${opt.desc ? `<span class="option__desc">${opt.desc}</span>` : ''}
        </span>
      `;
      card.addEventListener('click', () => handleOptionClick(i));
      optionsEl.appendChild(card);
    });

    backBtn.disabled = state.qIndex === 0;
    updateNextBtn();
  }

  function updateNextBtn() {
    const q = QUESTIONS[state.qIndex];
    const a = state.answers[state.qIndex];
    let valid = false;
    if (q.type === 'multi') {
      valid = a && Array.isArray(a.selected) && a.selected.length > 0;
    } else {
      valid = a && typeof a.selected === 'number';
    }
    nextBtn.disabled = !valid;
    nextBtn.textContent = state.qIndex === QUESTIONS.length - 1 ? 'See your match →' : 'Continue →';
  }

  function handleOptionClick(idx) {
    const q = QUESTIONS[state.qIndex];
    const isMulti = q.type === 'multi';

    if (isMulti) {
      const current = state.answers[state.qIndex] || { selected: [], score: 0 };
      let selected = [...(current.selected || [])];

      // "None of these" is mutually exclusive with the others
      const noneIdx = q.options.findIndex(o => /none/i.test(o.label));
      if (idx === noneIdx) {
        selected = selected.includes(idx) ? [] : [idx];
      } else {
        selected = selected.filter(i => i !== noneIdx);
        if (selected.includes(idx)) {
          selected = selected.filter(i => i !== idx);
        } else {
          selected.push(idx);
        }
      }

      const score = selected.reduce((sum, i) => sum + (q.options[i].score || 0), 0);
      state.answers[state.qIndex] = { selected, score };

      // Re-render to update visual selection
      const cards = optionsEl.querySelectorAll('.option');
      cards.forEach((c, i) => c.classList.toggle('is-selected', selected.includes(i)));
    } else {
      const opt = q.options[idx];
      const ans = { selected: idx };
      if (q.type === 'category') ans.value = opt.value;
      if (q.type === 'score') ans.score = opt.score;
      state.answers[state.qIndex] = ans;

      const cards = optionsEl.querySelectorAll('.option');
      cards.forEach((c, i) => c.classList.toggle('is-selected', i === idx));
    }

    updateNextBtn();
  }

  // ============ SCORING / RESULT ============
  function computeResult() {
    const category = state.answers[0].value;
    const totalScore =
      (state.answers[1]?.score || 0) +
      (state.answers[2]?.score || 0) +
      (state.answers[3]?.score || 0) +
      (state.answers[4]?.score || 0);

    // totalScore range: 3 (1+1+1+0) to 11 (3+3+3+2)
    let key;
    if (category === 'hormone') {
      key = totalScore >= 7 ? 'trt' : 'hrt';
    } else if (category === 'metabolic') {
      if (totalScore <= 4) key = 'metabolic-micro';
      else if (totalScore <= 6) key = 'metabolic-essential';
      else if (totalScore <= 8) key = 'metabolic-core';
      else if (totalScore <= 10) key = 'metabolic-advanced';
      else key = 'metabolic-elite';
    } else if (category === 'recovery') {
      key = totalScore >= 7 ? 'recovery-regenerative' : 'recovery-foundational';
    } else if (category === 'recomp') {
      key = totalScore >= 7 ? 'recomp-peak' : 'recomp-total';
    } else {
      key = 'vitality';
    }

    return { key, program: PROGRAMS[key], totalScore, category };
  }

  function buildWhy(result) {
    const a = state.answers;
    const cat = a[0];
    const intensity = a[1].score + a[2].score + a[3].score;
    const goalLabel = QUESTIONS[0].options[cat.selected].label.toLowerCase();

    const intensityWord = intensity <= 5 ? 'measured' : intensity <= 7 ? 'committed' : 'aggressive';

    let priorities = '';
    const multiSelected = a[4].selected || [];
    if (multiSelected.length && !multiSelected.includes(QUESTIONS[4].options.findIndex(o => /none/i.test(o.label)))) {
      const labels = multiSelected.map(i => QUESTIONS[4].options[i].label.toLowerCase());
      priorities = ` Plus, you flagged that ${labels.join(' and ')}, which the protocol is built to address.`;
    }

    return `You said you're here to ${goalLabel}, and your training, timeline, and starting point all point to a ${intensityWord} approach.${priorities}`;
  }

  // ============ NAVIGATION ============
  document.querySelector('[data-action="start"]').addEventListener('click', () => {
    state.qIndex = 0;
    state.answers = [];
    renderQuestion();
    showScreen('question');
  });

  nextBtn.addEventListener('click', () => {
    if (state.qIndex < QUESTIONS.length - 1) {
      state.qIndex++;
      renderQuestion();
    } else {
      showResults();
    }
  });

  backBtn.addEventListener('click', () => {
    if (state.qIndex > 0) {
      state.qIndex--;
      renderQuestion();
    }
  });

  document.querySelector('[data-action="restart"]').addEventListener('click', () => {
    state.qIndex = 0;
    state.answers = [];
    state.category = null;
    showScreen('intro');
    document.getElementById('email-opt-form').reset();
    document.getElementById('email-opt-status').textContent = '';
    document.getElementById('email-opt-status').className = 'email-opt__status';
  });

  function showResults() {
    const r = computeResult();
    document.querySelector('[data-result-category]').textContent = r.program.category;
    document.querySelector('[data-result-name]').textContent = r.program.name;
    document.querySelector('[data-result-price]').textContent = r.program.price;
    document.querySelector('[data-result-why]').textContent = buildWhy(r);

    const ul = document.querySelector('[data-result-includes]');
    ul.innerHTML = '';
    r.program.includes.forEach(item => {
      const li = document.createElement('li');
      li.textContent = item;
      ul.appendChild(li);
    });

    // Stash result for the email handler
    window.__quizResult = {
      category: r.program.category,
      name: r.program.name,
      price: r.program.price,
      key: r.key,
      score: r.totalScore,
      answers: state.answers.map((a, i) => ({
        question: QUESTIONS[i].title,
        choice: a.value || (typeof a.selected === 'number' ? QUESTIONS[i].options[a.selected].label : (a.selected || []).map(s => QUESTIONS[i].options[s].label).join(', ')),
      })),
    };

    showScreen('results');
  }

  // ============ EMAIL OPT-IN ============
  const optForm = document.getElementById('email-opt-form');
  const optStatus = document.getElementById('email-opt-status');
  const optBtn = document.getElementById('email-opt-btn');

  optForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    optStatus.className = 'email-opt__status';
    optStatus.textContent = '';
    const data = Object.fromEntries(new FormData(optForm).entries());

    if (data._honey) return; // bot, silently ignore
    if (!data.email || !data.email.includes('@')) {
      optStatus.className = 'email-opt__status err';
      optStatus.textContent = 'Add a valid email address.';
      return;
    }

    optBtn.disabled = true;
    const original = optBtn.textContent;
    optBtn.textContent = 'Sending…';

    try {
      const payload = {
        email: data.email,
        source: 'quiz',
        result: window.__quizResult || null,
      };
      const res = await fetch('/api/quiz', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const json = await res.json().catch(() => ({}));
      if (res.ok && json.ok) {
        optStatus.className = 'email-opt__status ok';
        optStatus.textContent = 'Sent. Check your inbox in the next few minutes.';
        optForm.reset();
      } else {
        optStatus.className = 'email-opt__status err';
        optStatus.textContent = json.error || 'Something went wrong.';
      }
    } catch (err) {
      optStatus.className = 'email-opt__status err';
      optStatus.textContent = 'Network error. Try again or email us directly.';
    } finally {
      optBtn.disabled = false;
      optBtn.textContent = original;
    }
  });
})();
</script>

<style is:global>
  .quiz-shell {
    padding: clamp(3rem, 7vw, 6rem) 0 clamp(4rem, 9vw, 7rem);
    min-height: 80vh;
    position: relative;
    overflow: hidden;
  }
  .quiz-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(800px 500px at 80% 20%, rgba(201, 120, 58, 0.12), transparent 60%);
    pointer-events: none;
  }
  .quiz-shell .container { position: relative; }

  /* SCREEN MANAGEMENT */
  .screen { display: none; }
  .screen.is-active { display: block; }

  /* INTRO */
  .intro { max-width: 820px; }
  .intro__title {
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 320;
    line-height: 0.95;
    letter-spacing: -0.03em;
    margin: 1.2rem 0 1.5rem;
  }
  .intro__title .italic-display { color: var(--bronze-bright); }
  .intro__meta {
    display: flex;
    gap: 0;
    margin: 3rem 0 2.5rem;
    border-top: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
  }
  .intro__stat {
    flex: 1;
    padding: 1.5rem 0;
    border-right: 1px solid var(--rule);
  }
  .intro__stat:last-child { border-right: 0; }
  .intro__stat:not(:first-child) { padding-left: 1.5rem; }
  .intro__stat-num {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 360;
    line-height: 1;
    color: var(--bronze);
  }
  .intro__stat-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mute);
    margin-top: 0.4rem;
  }
  @media (max-width: 600px) {
    .intro__meta { flex-direction: column; }
    .intro__stat { border-right: 0; border-bottom: 1px solid var(--rule); padding: 1.2rem 0; }
    .intro__stat:last-child { border-bottom: 0; }
    .intro__stat:not(:first-child) { padding-left: 0; }
  }

  /* PROGRESS */
  .quiz-progress {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 3rem;
    max-width: 720px;
  }
  .quiz-progress__count {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    color: var(--paper);
    flex-shrink: 0;
  }
  .quiz-progress__count .muted { color: var(--mute); margin: 0 0.3rem; }
  .quiz-progress__bar {
    flex: 1;
    height: 1px;
    background: var(--rule-strong);
    position: relative;
    overflow: hidden;
  }
  .quiz-progress__fill {
