---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Find Your Protocol · Viva Wellness Co."
  description="Answer five quick questions about your goals and starting point. We'll match you with the Viva Wellness protocol and tier that fits. Concierge telehealth in Austin, TX."
>

  <section class="quiz">
    <div class="container quiz__inner">

      <h1 class="sr-only">Protocol Match Quiz</h1>

      {/* Progress */}
      <div class="quiz__progress" aria-hidden="true">
        <div class="quiz__progress-bar" id="q-bar"></div>
      </div>
      <div class="quiz__meta">
        <span class="eyebrow" id="q-step">Question 1 of 5</span>
      </div>

      {/* ==== Step 1: goal ==== */}
      <div class="quiz__step is-active" data-step="1">
        <h2 class="quiz__q">
          What is your <span class="italic-display">primary goal</span> right now?
        </h2>
        <div class="quiz__options">
          <button class="quiz__opt" data-q="goal" data-v="weight">
            <span class="quiz__opt-num">01</span>
            <span class="quiz__opt-label">Lose weight or reset metabolism</span>
          </button>
          <button class="quiz__opt" data-q="goal" data-v="hormones">
            <span class="quiz__opt-num">02</span>
            <span class="quiz__opt-label">Optimize hormones (energy, libido, mood)</span>
          </button>
          <button class="quiz__opt" data-q="goal" data-v="recovery">
            <span class="quiz__opt-num">03</span>
            <span class="quiz__opt-label">Recover from training, surgery, or injury</span>
          </button>
          <button class="quiz__opt" data-q="goal" data-v="longevity">
            <span class="quiz__opt-num">04</span>
            <span class="quiz__opt-label">Longevity, anti-aging, sustained vitality</span>
          </button>
          <button class="quiz__opt" data-q="goal" data-v="performance">
            <span class="quiz__opt-num">05</span>
            <span class="quiz__opt-label">Performance and body recomposition</span>
          </button>
        </div>
      </div>

      {/* ==== Step 2: age ==== */}
      <div class="quiz__step" data-step="2">
        <h2 class="quiz__q">
          What is your <span class="italic-display">age range</span>?
        </h2>
        <div class="quiz__options">
          <button class="quiz__opt" data-q="age" data-v="u35"><span class="quiz__opt-num">01</span><span class="quiz__opt-label">Under 35</span></button>
          <button class="quiz__opt" data-q="age" data-v="35to44"><span class="quiz__opt-num">02</span><span class="quiz__opt-label">35 to 44</span></button>
          <button class="quiz__opt" data-q="age" data-v="45to54"><span class="quiz__opt-num">03</span><span class="quiz__opt-label">45 to 54</span></button>
          <button class="quiz__opt" data-q="age" data-v="55plus"><span class="quiz__opt-num">04</span><span class="quiz__opt-label">55 and up</span></button>
        </div>
      </div>

      {/* ==== Step 3: sex ==== */}
      <div class="quiz__step" data-step="3">
        <h2 class="quiz__q">
          For protocol routing, sex <span class="italic-display">assigned at birth</span>?
        </h2>
        <div class="quiz__options">
          <button class="quiz__opt" data-q="sex" data-v="m"><span class="quiz__opt-num">01</span><span class="quiz__opt-label">Male</span></button>
          <button class="quiz__opt" data-q="sex" data-v="f"><span class="quiz__opt-num">02</span><span class="quiz__opt-label">Female</span></button>
        </div>
      </div>

      {/* ==== Step 4: activity ==== */}
      <div class="quiz__step" data-step="4">
        <h2 class="quiz__q">
          How <span class="italic-display">active</span> are you?
        </h2>
        <div class="quiz__options">
          <button class="quiz__opt" data-q="activity" data-v="sedentary"><span class="quiz__opt-num">01</span><span class="quiz__opt-label">Mostly sedentary right now</span></button>
          <button class="quiz__opt" data-q="activity" data-v="moderate"><span class="quiz__opt-num">02</span><span class="quiz__opt-label">2 to 4 workouts a week</span></button>
          <button class="quiz__opt" data-q="activity" data-v="athlete"><span class="quiz__opt-num">03</span><span class="quiz__opt-label">5+ sessions, training with intent</span></button>
          <button class="quiz__opt" data-q="activity" data-v="competitive"><span class="quiz__opt-num">04</span><span class="quiz__opt-label">Competitive athlete or high performer</span></button>
        </div>
      </div>

      {/* ==== Step 5: budget ==== */}
      <div class="quiz__step" data-step="5">
        <h2 class="quiz__q">
          Where is your <span class="italic-display">monthly comfort</span>?
        </h2>
        <div class="quiz__options">
          <button class="quiz__opt" data-q="budget" data-v="b99"><span class="quiz__opt-num">01</span><span class="quiz__opt-label">Up to $99 a month</span></button>
          <button class="quiz__opt" data-q="budget" data-v="b199"><span class="quiz__opt-num">02</span><span class="quiz__opt-label">Up to $199 a month</span></button>
          <button class="quiz__opt" data-q="budget" data-v="b349"><span class="quiz__opt-num">03</span><span class="quiz__opt-label">Up to $349 a month</span></button>
          <button class="quiz__opt" data-q="budget" data-v="bmax"><span class="quiz__opt-num">04</span><span class="quiz__opt-label">$349 and up, build me the plan</span></button>
        </div>
      </div>

      {/* ==== Step 6: gate form ==== */}
      <div class="quiz__step" data-step="6">
        <h2 class="quiz__q">
          Almost done. <span class="italic-display">Three details</span> to see your match.
        </h2>
        <p class="lead quiz__lede">
          We'll email your matched protocol plus the Precision Hormone &amp;
          Peptide Therapy eBook. Liliana will follow up personally only if you
          want her to.
        </p>
        <form class="quiz__form" id="quiz-form" novalidate>
          <div class="field">
            <label for="q-name" class="field__label">Your name</label>
            <input id="q-name" name="name" type="text" class="field__input" autocomplete="name" required placeholder="First and last" />
          </div>
          <div class="field">
            <label for="q-email" class="field__label">Email</label>
            <input id="q-email" name="email" type="email" class="field__input" autocomplete="email" required placeholder="you@example.com" />
          </div>
          <div class="field">
            <label for="q-phone" class="field__label">Phone</label>
            <input id="q-phone" name="phone" type="tel" class="field__input" autocomplete="tel" placeholder="(512) 555-0123" />
            <span class="field__hint">Optional. Only used if you ask us to call or text.</span>
          </div>
          {/* honeypot */}
          <div class="hp" aria-hidden="true">
            <label>Leave empty<input name="company" type="text" tabindex="-1" autocomplete="off" /></label>
          </div>

          <button type="submit" class="btn btn--bronze" id="q-submit">Reveal my protocol</button>
          <div class="quiz__status" id="q-status" role="status" aria-live="polite"></div>
        </form>
      </div>

      {/* ==== Step 7: result ==== */}
      <div class="quiz__step" data-step="7">
        <span class="eyebrow" id="r-eyebrow">Your match</span>
        <h2 class="quiz__result-title">
          <span class="italic-display">Recommended:</span><br/>
          <span id="r-name">Viva Concierge</span>
        </h2>
        <div class="quiz__result-card">
          <div class="quiz__result-price">
            <span class="quiz__result-amt" id="r-price">$99</span>
            <span class="quiz__result-cad">/mo</span>
          </div>
          <p class="quiz__result-body" id="r-body">A starting protocol calibrated to your answers.</p>
          <ul class="quiz__result-list" id="r-list"></ul>
          <div class="quiz__result-ctas">
            <a href="https://vivawellnessco.glossgenius.com/?utm_source=vivawellnessco&utm_medium=cta&utm_content=quiz_result" target="_blank" rel="noopener" class="btn btn--bronze">Book your first visit</a>
            <a href="/services" class="btn">See all programs</a>
          </div>
          <p class="quiz__result-note">
            The eBook is on its way to your inbox. This match is a starting
            point, your final protocol will be tailored during your consult.
          </p>
        </div>
      </div>

      {/* ==== Back button ==== */}
      <button class="quiz__back" id="q-back" aria-label="Previous question" hidden>
        ← Back
      </button>
    </div>
  </section>

</Layout>

<script>
  import { match, type Answers } from '../lib/quiz';
  const TOTAL = 5; // five real questions before the gate
  const state = {
    step: 1,
    answers: {} as Answers,
  };

  const stepEls = document.querySelectorAll('.quiz__step') as NodeListOf<HTMLDivElement>;
  const bar = document.getElementById('q-bar') as HTMLDivElement;
  const meta = document.getElementById('q-step') as HTMLSpanElement;
  const back = document.getElementById('q-back') as HTMLButtonElement;

  function render() {
    stepEls.forEach((el) => {
      el.classList.toggle('is-active', Number(el.dataset.step) === state.step);
    });
    // bar reflects the 5-question journey, then jumps to 100% at gate and result
    const pct = state.step <= TOTAL
      ? ((state.step - 1) / TOTAL) * 100
      : 100;
    bar.style.width = `${pct}%`;

    if (state.step <= TOTAL) {
      meta.textContent = `Question ${state.step} of ${TOTAL}`;
    } else if (state.step === TOTAL + 1) {
      meta.textContent = 'Almost there';
    } else {
      meta.textContent = 'Your match';
    }

    back.hidden = state.step <= 1 || state.step > TOTAL + 1;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // Option clicks
  document.querySelectorAll('.quiz__opt').forEach((btn) => {
    btn.addEventListener('click', () => {
      const q = (btn as HTMLElement).dataset.q as keyof Answers;
      const v = (btn as HTMLElement).dataset.v as string;
      if (!q || !v) return;
      state.answers[q] = v;
      if (state.step < TOTAL + 1) state.step += 1;
      render();
    });
  });

  back.addEventListener('click', () => {
    if (state.step > 1) {
      state.step -= 1;
      render();
    }
  });

  // ====== Form submit (gate) ======
  const form = document.getElementById('quiz-form') as HTMLFormElement | null;
  const status = document.getElementById('q-status') as HTMLDivElement | null;
  const submit = document.getElementById('q-submit') as HTMLButtonElement | null;

  if (form && status && submit) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';
      status.className = 'quiz__status';

      const data = new FormData(form);
      const name = String(data.get('name') || '').trim();
      const email = String(data.get('email') || '').trim();
      const phone = String(data.get('phone') || '').trim();
      const company = String(data.get('company') || '').trim();

      if (!name || !email) {
        status.textContent = 'Name and email are required.';
        status.classList.add('is-error');
        return;
      }

      const m = match(state.answers);
      const utm: Record<string, string> = {};
      const params = new URLSearchParams(window.location.search);
      for (const k of ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'] as const) {
        const v = params.get(k);
        if (v) utm[k] = v;
      }

      submit.disabled = true;
      submit.textContent = 'Sending…';

      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            source: 'quiz',
            name, email, phone, company,
            quiz: state.answers,
            match: { key: m.key, name: m.name, price: m.price },
            utm,
            referrer: document.referrer || '',
          }),
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok || !json.ok) {
          throw new Error(json.error || 'Send failed. Try again or email info@vivawellnessco.com.');
        }
        // Show result
        const nameEl = document.getElementById('r-name')!;
        const priceEl = document.getElementById('r-price')!;
        const bodyEl = document.getElementById('r-body')!;
        const listEl = document.getElementById('r-list')!;
        nameEl.textContent = m.name;
        priceEl.textContent = m.price;
        bodyEl.textContent = m.body;
        listEl.innerHTML = m.bullets.map((b) => `<li>${b}</li>`).join('');
        state.step = TOTAL + 2;
        render();
      } catch (err) {
        status.textContent = err instanceof Error ? err.message : 'Send failed. Try again.';
        status.classList.add('is-error');
      } finally {
        submit.disabled = false;
        submit.textContent = 'Reveal my protocol';
      }
    });
  }

  render();
</script>

<style>
  .quiz {
    padding: clamp(4rem, 10vw, 8rem) 0;
    position: relative;
    min-height: 80vh;
  }
  .quiz::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(700px 400px at 80% 15%, rgba(201, 120, 58, 0.16), transparent 60%),
      radial-gradient(500px 350px at 10% 85%, rgba(201, 120, 58, 0.08), transparent 60%);
    pointer-events: none;
  }
  .quiz__inner {
    position: relative;
    max-width: 780px;
    margin: 0 auto;
  }

  .quiz__progress {
    height: 3px;
    width: 100%;
    background: var(--rule-strong);
    overflow: hidden;
    margin-bottom: 1.2rem;
  }
  .quiz__progress-bar {
    height: 100%;
    background: var(--bronze);
    width: 0%;
    transition: width 500ms var(--ease);
  }

  .quiz__meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 2.5rem;
  }

  /* Steps · cross-fade between them */
  .quiz__step {
    display: none;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 500ms var(--ease), transform 500ms var(--ease);
  }
  .quiz__step.is-active {
    display: block;
    opacity: 1;
    transform: translateY(0);
  }

  .quiz__q {
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.0;
    letter-spacing: 0.005em;
    margin-bottom: 2.5rem;
    max-width: 22ch;
  }
  .quiz__q .italic-display { color: var(--bronze-bright); }

  .quiz__lede { margin: -1.5rem 0 2rem; }

  .quiz__options {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .quiz__opt {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    padding: 1.3rem 1.6rem;
    background: var(--ink-2);
    border: 1px solid var(--rule-strong);
    border-radius: 2px;
    text-align: left;
    cursor: pointer;
    transition: background 220ms var(--ease), border-color 220ms var(--ease), transform 280ms var(--ease);
  }
  .quiz__opt:hover {
    background: var(--ink-3);
    border-color: rgba(201, 120, 58, 0.5);
    transform: translateX(4px);
  }
  .quiz__opt-num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--bronze);
    flex-shrink: 0;
    width: 24px;
  }
  .quiz__opt-label {
    font-family: var(--font-display-italic);
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    letter-spacing: -0.01em;
    color: var(--paper);
    line-height: 1.3;
  }

  /* Gate form */
  .quiz__form {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    max-width: 480px;
  }
  .quiz__form .btn { align-self: flex-start; margin-top: 0.4rem; }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .quiz__status {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    min-height: 1.2em;
    padding: 0.3rem 0;
  }
  .quiz__status.is-success { color: var(--bronze-bright); }
  .quiz__status.is-error { color: #e76e6e; }

  /* Result */
  .quiz__result-title {
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    line-height: 1.0;
    margin: 1rem 0 2rem;
    letter-spacing: 0.005em;
  }
  .quiz__result-title .italic-display { color: var(--bronze); }

  .quiz__result-card {
    background: var(--ink-2);
    border: 1px solid var(--rule-strong);
    box-shadow: inset 0 2px 0 0 var(--bronze);
    padding: clamp(2rem, 4vw, 3rem);
    border-radius: 2px;
  }
  .quiz__result-price {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
    margin-bottom: 1.5rem;
  }
  .quiz__result-amt {
    font-family: var(--font-display);
    font-size: clamp(3rem, 6vw, 4.5rem);
    color: var(--paper);
    line-height: 1;
    letter-spacing: 0.005em;
  }
  .quiz__result-cad {
    font-family: var(--font-mono);
    color: var(--mute);
    font-size: 1rem;
  }
  .quiz__result-body {
    font-size: 1.1rem;
    line-height: 1.55;
    color: rgba(245, 241, 234, 0.85);
    max-width: 56ch;
    margin-bottom: 1.5rem;
  }
  .quiz__result-list {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-bottom: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
  }
  .quiz__result-list li {
    position: relative;
    padding-left: 1.6rem;
    color: rgba(245, 241, 234, 0.85);
    font-size: 0.97rem;
    line-height: 1.5;
  }
  .quiz__result-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--bronze);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .quiz__result-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }
  .quiz__result-note {
    font-size: 0.85rem;
    color: var(--mute);
    line-height: 1.55;
    padding-top: 1.2rem;
    border-top: 1px solid var(--rule);
    max-width: 60ch;
  }

  .quiz__back {
    display: inline-flex;
    margin-top: 2.5rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--mute);
    padding: 0.5rem 0;
    transition: color 200ms var(--ease);
  }
  .quiz__back:hover { color: var(--paper); }
</style>
