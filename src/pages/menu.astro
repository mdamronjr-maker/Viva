---
import Layout from '../layouts/Layout.astro';

/* ============================================================
   /menu · the full treatment catalog. The /services pillars deep-link
   into each category here (e.g. /menu#peptides).

   DRAFT CONTENT — PENDING LILIANA'S CLINICAL REVIEW before promotion to
   the live site. This is a comprehensive starting menu drawn from what the
   site already documents (hormones, GLP-1s, the named peptides) plus common
   peptide/hormone-clinic offerings. Liliana should fix descriptors and
   REMOVE anything Viva does not actually offer. Every item is a compounded,
   patient-specific preparation prescribed individually after a clinical
   evaluation (see the note near the bottom of the page).
   ============================================================ */

const menu = [
  {
    id: 'hormone',
    label: 'Hormone Optimization',
    blurb: 'Bioidentical and compounded hormone therapy, dosed to how you want to feel and perform, not just to the bottom of a lab range.',
    items: [
      { name: 'Testosterone — men (TRT)', desc: 'Injectable, cream, or pellet for energy, libido, strength, mood, and recovery.' },
      { name: 'Testosterone — women, low-dose', desc: 'Micro-dosed for energy, libido, focus, and lean mass.' },
      { name: 'Estradiol', desc: 'Estrogen replacement for perimenopause and menopause symptoms.' },
