---
import Layout from '../layouts/Layout.astro';

/* ============================================================
   /menu · the full Stacks & Protocols catalog. The /services pillars
   deep-link into each category here (e.g. /menu#peptides).

   Content is from Viva's own "Stacks & Protocols" document (branded stack
   names + compounds + benefits + Essential/Core/Elite tiers). Organized here
   by goal so the goal-based pillar links resolve.

   PENDING LILIANA'S REVIEW before promotion to live. No prices shown (pricing
   lives on Services / GlossGenius). L-Carnitine dropped from the GLP-1 stacks
   and GHK-Cu's stack (La Reina) placed under Recovery, per Michael. A couple of
   stack names are edgy Spanish slang — kept verbatim from the doc; tone down if
   desired. Every stack is a compounded, patient-specific protocol prescribed
   individually after a consult (see disclaimer below).
   ============================================================ */

const menu = [
  {
    id: 'hormone',
    label: 'Hormone Optimization',
    blurb: 'All-inclusive TRT and HRT for men and women, fully managed: medication, supplies, home delivery, and labs.',
    stacks: [
      { brand: 'All-Inclusive TRT / HRT Program', compounds: 'Testosterone · estradiol · progesterone · thyroid · enclomiphene & more', benefit: 'A bundled membership for men and women: compounded medication, supplies, home delivery, follow-up consults, and labs twice a year.', tier: 'Membership' },
    ],
  },
  {
    id: 'metabolic',
    label: 'Metabolic & Weight Loss',
    blurb: 'Compounded GLP-1 and metabolic protocols, provider-titrated, with lean muscle preserved.',
    stacks: [
      { brand: 'Slimaglutide Stack', compounds: 'Semaglutide', benefit: 'Appetite control, fat metabolism, and steady energy for weight loss.', tier: 'Essential' },
      { brand: 'Texaglutide Stack', compounds: 'Tirzepatide', benefit: 'Premium weight loss and energy support: appetite control, better insulin response, and metabolic correction.', tier: 'Core' },
      { brand: 'A Toda Madre', compounds: 'SLU-PP-332', benefit: 'Mimics endurance training by switching the body to burn fat for fuel, with lean-muscle preservation.', tier: 'Core' },
      { brand: 'El Rey', compounds: 'Retatrutide', benefit: 'Deeper appetite control, stronger insulin-sensitivity support, and enhanced fat-to-energy conversion while preserving lean muscle.', tier: 'Elite' },
    ],
  },
  {
    id: 'peptides',
    label: 'Peptide Therapy — Recovery & Repair',
    blurb: 'Compounded peptides for joints, tendons, gut, and tissue repair.',
    stacks: [
      { brand: 'El Curandero', compounds: 'BPC-157', benefit: 'Supports joints, tendons, and gut health, and one of the few peptides that can be taken orally.', tier: 'Essential' },
      { brand: 'El Lobo Stack', compounds: 'BPC-157 + TB-500', benefit: 'A recovery classic: gut health, faster recovery, and injury healing.', tier: 'Core' },
      { brand: 'La Reina', compounds: 'GHK-Cu', benefit: 'A copper peptide that supports tissue and wound healing, skin elasticity, and hair.', tier: 'Essential' },
      { brand: 'Sana Sana Colita de Rana', compounds: 'BPC-157 + TB-500 + KPV + GHK-Cu', benefit: 'A powerhouse stack that synergistically boosts tissue repair, lowers inflammation, and accelerates recovery.', tier: 'Elite' },
    ],
  },
  {
    id: 'performance',
    label: 'Performance & Growth',
    blurb: 'Growth-hormone support and output for athletes and high-drive professionals.',
    stacks: [
      { brand: 'Savage Protocol', compounds: 'Sermorelin', benefit: 'Recovery, sleep, and anti-aging. Stimulates the body’s own HGH production to improve body composition.', tier: 'Essential' },
      { brand: 'Échale Ganas Stack', compounds: 'CJC-1295 + Ipamorelin', benefit: 'Lean muscle, fat metabolism, deeper sleep, and faster recovery.', tier: 'Elite' },
      { brand: 'Ponte Mamado', compounds: 'IGF-LR3', benefit: 'Muscle growth and recovery by enhancing protein synthesis and cell repair.', tier: 'Elite' },
    ],
  },
  {
    id: 'recomp',
    label: 'Recomposition & Cutting',
    blurb: 'Drop fat, hold muscle: cutting and body-recomposition stacks.',
    stacks: [
      { brand: 'Fuego Protocol', compounds: 'MOTS-c', benefit: 'Promotes fat burning, higher cellular energy, and lean muscle.', tier: 'Essential' },
      { brand: 'El Corte Stack', compounds: 'Tesamorelin + Ipamorelin', benefit: 'Built for cutting: visceral and abdominal fat loss, lean muscle, and sleep.', tier: 'Core' },
      { brand: 'Peso Pluma Protocol', compounds: 'Tesamorelin + Ipamorelin + AOD-9604 + MOTS-c', benefit: 'The ultimate body-recomposition stack: fat loss, lean muscle, and recovery.', tier: 'Elite' },
    ],
  },
  {
    id: 'longevity',
    label: 'Lifestyle & Longevity',
    blurb: 'Cellular energy, skin, immunity, sleep, and a clearer head.',
    stacks: [
      { brand: 'De NAD+a', compounds: 'NAD+', benefit: 'Energy, cellular repair, skin health, and weight management by helping the body use fat for fuel.', tier: 'Essential' },
      { brand: 'Bidi Bidi Bombshell Stack', compounds: 'GHK-Cu + Epithalon', benefit: 'Skin elasticity, collagen, cellular longevity, hair growth, and a youthful glow.', tier: 'Core' },
      { brand: 'La Guardia', compounds: 'Thymosin Alpha-1', benefit: 'Boosts immunity and lowers inflammation by promoting T-cell activity and both innate and adaptive immunity.', tier: 'Core' },
      { brand: 'No Chingues, Relax Stack', compounds: 'Semax + Selank', benefit: 'Sharper focus, less stress, and clearer thinking with no crash; supports anxiety and ADHD symptoms.', tier: 'Elite' },
    ],
  },
  {
    id: 'labs',
    label: 'Labs & Diagnostics',
    blurb: 'The measurement layer underneath every protocol.',
    stacks: [
      { brand: 'Targeted Lab Analysis', compounds: 'Hormone · metabolic · thyroid · inflammation panels', benefit: 'Run before and during your protocol and read by the same provider, so your dosing is guided by data, not guesswork.', tier: '' },
    ],
  },
];
---

<Layout
  title="Stacks & Protocols Menu · Peptides, GLP-1, TRT/HRT | Viva Wellness Co."
  description="The full Viva Wellness Co. stacks & protocols menu: compounded peptide, GLP-1 weight-loss, performance, recomposition, longevity, and TRT/HRT protocols. Each stack is prescribed individually after a provider consult. Concierge telehealth in Texas, Colorado, Florida, and Iowa."
>
  <section class="menu-hero">
    <div class="container menu-hero__inner">
      <span class="eyebrow">· Stacks &amp; protocols</span>
      <h1 class="menu-hero__title">
        Everything <span class="italic-display">available.</span>
      </h1>
      <p class="lead menu-hero__lead">
        Every protocol has a name; under it is exactly what's in it. Grouped by
        goal, tiered from Essential to Elite. Nothing here is picked off a shelf,
        each is a compounded, patient-specific protocol prescribed individually
        after we talk and look at your labs.
      </p>
      <nav class="menu-jump" aria-label="Jump to a category">
        {menu.map((c) => (
          <a href={`#${c.id}`} class="menu-jump__link">{c.label}</a>
        ))}
      </nav>
    </div>
  </section>

  {menu.map((c) => (
    <section class="menu-cat" id={c.id} aria-labelledby={`${c.id}-h`}>
      <div class="container menu-cat__inner">
        <div class="menu-cat__head">
          <h2 id={`${c.id}-h`} class="menu-cat__title">{c.label}</h2>
          <p class="menu-cat__blurb">{c.blurb}</p>
        </div>
        <ul class:list={["menu-list", c.stacks.length === 1 && 'menu-list--single']}>
          {c.stacks.map((s) => (
            <li class="stack">
              {s.tier && <span class="stack__tier">{s.tier}</span>}
              <h3 class="stack__brand">{s.brand}</h3>
              <p class="stack__compounds">{s.compounds}</p>
              <p class="stack__benefit">{s.benefit}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  <section class="section section--paper menu-note-section">
    <div class="container">
      <p class="menu-note">
        Stack names are for branding and educational purposes only and are not
        the names of FDA-approved medications. Each stack is a wellness protocol
        of compounded peptides and/or medications, prescribed individually based
        on a licensed provider consultation. A medical consultation is required
        before prescribing. Individual results may vary. These protocols are
        intended for wellness support and should not be interpreted as claims to
        diagnose, treat, cure, or prevent any disease.
      </p>
    </div>
  </section>

  <section class="menu-cta">
    <div class="container menu-cta__inner">
      <h2 class="menu-cta__title">
        Not sure which stack? <span class="italic-display">Start with a visit.</span>
      </h2>
      <p class="lead">
        Tell me your goals and I'll build the protocol: the right compounds, the
        right doses, adjusted as we go.
      </p>
      <div class="menu-cta__ctas">
        <a href="/start?utm_source=vivawellnessco&utm_medium=cta&utm_content=menu_cta" class="btn btn--bronze">Book your first visit</a>
        <a href="/#quiz" class="btn">Take the match quiz</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .menu-hero { padding: clamp(6rem, 12vw, 9rem) 0 clamp(2.5rem, 6vw, 4rem); }
  .menu-hero__inner { max-width: 900px; display: flex; flex-direction: column; gap: 1.4rem; }
  .menu-hero__title { font-size: clamp(2.6rem, 7vw, 5rem); line-height: 1.02; letter-spacing: -0.028em; }
  .menu-hero__title .italic-display { color: var(--bronze); }
  .menu-hero__lead { max-width: 62ch; }
  .menu-jump { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.6rem; }
  .menu-jump__link { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--paper); border: 1px solid var(--rule-strong); border-radius: var(--radius-pill); padding: 0.5rem 0.9rem; text-decoration: none; transition: background 200ms var(--ease), border-color 200ms var(--ease), color 200ms var(--ease); }
  .menu-jump__link:hover { background: var(--bronze); color: var(--ink); border-color: var(--bronze); }

  .menu-cat { padding: clamp(2rem, 5vw, 3.5rem) 0; border-top: 1px solid var(--rule); scroll-margin-top: 90px; }
  .menu-cat__inner { display: grid; grid-template-columns: 1fr 2fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: start; }
  .menu-cat__title { font-size: clamp(1.6rem, 3.5vw, 2.4rem); letter-spacing: -0.02em; }
  .menu-cat__blurb { color: rgba(245, 241, 234, 0.7); font-size: 0.95rem; line-height: 1.5; margin-top: 0.6rem; max-width: 36ch; }

  .menu-list { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--rule); border: 1px solid var(--rule); }
  .menu-list--single { grid-template-columns: 1fr; }
  .menu-list > .stack:last-child:nth-child(odd) { grid-column: 1 / -1; }
  .stack { background: var(--ink); padding: 1.2rem 1.3rem; display: flex; flex-direction: column; gap: 0.4rem; }
  .stack__tier { align-self: flex-start; font-family: var(--font-mono); font-size: 0.58rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--bronze-bright); border: 1px solid rgba(214, 134, 74, 0.4); border-radius: var(--radius-pill); padding: 0.15rem 0.55rem; }
  .stack__brand { font-size: 1.15rem; line-height: 1.15; color: var(--paper); letter-spacing: -0.01em; }
  .stack__compounds { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--bronze); }
  .stack__benefit { color: rgba(245, 241, 234, 0.7); font-size: 0.86rem; line-height: 1.45; }

  .menu-note-section { padding: clamp(2.5rem, 6vw, 4rem) 0; }
  .menu-note { max-width: 76ch; color: var(--ink); opacity: 0.72; font-size: 0.82rem; line-height: 1.6; }

  .menu-cta { padding: clamp(3rem, 8vw, 6rem) 0; text-align: center; }
  .menu-cta__inner { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 1.2rem; align-items: center; }
  .menu-cta__title { font-size: clamp(2rem, 5vw, 3.4rem); letter-spacing: -0.02em; }
  .menu-cta__title .italic-display { color: var(--bronze); }
  .menu-cta__ctas { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-top: 0.4rem; }

  @media (max-width: 800px) {
    .menu-cat__inner { grid-template-columns: 1fr; }
    .menu-list { grid-template-columns: 1fr; }
  }
</style>
