      { name: 'HCG', desc: 'Maintains natural production and fertility alongside TRT.' },
      { name: 'Enclomiphene', desc: 'Stimulates your own testosterone, an oral option for some men.' },
      { name: 'Anastrozole', desc: 'Estrogen management on TRT when labs call for it.' },
      { name: 'DHEA', desc: 'Hormone-precursor support.' },
    ],
  },
  {
    id: 'metabolic',
    label: 'Metabolic & Weight',
    blurb: 'Compounded GLP-1 and multi-agonist protocols, provider-titrated to your physiology with muscle preservation in mind.',
    items: [
      { name: 'Semaglutide', desc: 'GLP-1 for appetite control and steady fat loss.' },
      { name: 'Tirzepatide', desc: 'Dual GIP/GLP-1 for stronger appetite control and metabolic effect.' },
      { name: 'Retatrutide', desc: 'Triple agonist, the most aggressive metabolic tier.' },
      { name: 'Micro-dose protocols', desc: 'Lower-dose semaglutide or tirzepatide for gentle starts or maintenance.' },
    ],
  },
  {
    id: 'peptides',
    label: 'Peptide Therapy',
    blurb: 'Compounded peptides for recovery, repair, and growth-hormone support.',
    items: [
      { name: 'BPC-157', desc: 'Soft-tissue and gut repair: tendons, ligaments, gut lining.' },
      { name: 'TB-500', desc: 'Thymosin beta-4; healing, flexibility, and inflammation.' },
      { name: 'GHK-Cu', desc: 'Copper peptide for skin, hair, wound healing, and antioxidant support.' },
      { name: 'CJC-1295 / Ipamorelin', desc: "Prompts your body's own pulsatile growth-hormone release for recovery, body composition, and sleep." },
      { name: 'Sermorelin', desc: 'Growth-hormone-releasing peptide, a gentler GH-support option.' },
      { name: 'Tesamorelin', desc: 'GH-releasing peptide studied for visceral fat.' },
      { name: 'MOTS-c', desc: 'Mitochondrial peptide for metabolic and exercise support.' },
      { name: 'PT-141', desc: 'Peptide for sexual health and libido.' },
      { name: 'Thymosin Alpha-1', desc: 'Immune-support peptide.' },
    ],
  },
  {
    id: 'performance',
    label: 'Performance',
    blurb: 'For athletes and high-output professionals: hormone optimization, recovery peptides, and metabolic support tuned to keep you on the line.',
    items: [
      { name: 'Testosterone optimization', desc: 'Dialed for output, recovery, and drive.' },
      { name: 'Recovery peptide stack', desc: 'BPC-157 + TB-500 for soft-tissue recovery between sessions.' },
      { name: 'CJC-1295 / Ipamorelin', desc: 'GH support for recovery, sleep, and body composition.' },
      { name: 'NAD+', desc: 'Cellular energy and recovery support.' },
    ],
  },
  {
    id: 'recomp',
    label: 'Recomposition',
    blurb: 'Change your body composition while training stays intact: metabolic, hormone, and recovery support working as one.',
    items: [
      { name: 'GLP-1, micro to standard dose', desc: 'Fat loss without giving back hard-earned muscle.' },
      { name: 'Hormone support', desc: 'Protects lean mass through a deficit.' },
      { name: 'Recovery peptides', desc: 'Keep training quality high while you cut.' },
    ],
  },
  {
    id: 'longevity',
    label: 'Lifestyle & Longevity',
    blurb: 'The long game: cellular energy, sleep, inflammation, and healthspan.',
    items: [
