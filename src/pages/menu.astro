---
import Layout from '../layouts/Layout.astro';

/* ============================================================
   /menu · plain-language peptide & compound dictionary. The /services
   pillars deep-link into each category here (e.g. /menu#peptides).

   Entries (name + class + definition) were drafted and adversarially
   accuracy/compliance-reviewed by a multi-agent pass. Conservative by design:
   "studied for" / "studied in relation to", no efficacy guarantees, no disease
   claims, no dosing, no brand/stack names, no prices. Every compound is a
   compounded, patient-specific preparation prescribed individually after a
   consult (see disclaimer). PENDING LILIANA'S REVIEW before promotion to live.
   The Labs category is a plain-panels reference (not from the agent pass).
   ============================================================ */

const menu = [
  {
    id: 'hormone',
    label: 'Hormone Optimization',
    blurb: 'Foundational sex and thyroid hormones used in individualized hormone therapy.',
    entries: [
      { name: 'Testosterone', klass: 'Androgen hormone', definition: "The primary androgen sex hormone, available in compounded forms for hormone therapy. It has been studied in relation to energy, libido, mood, muscle mass, and bone density." },
      { name: 'Estradiol', klass: 'Estrogen hormone', definition: "The principal form of estrogen, prepared in compounded formulations for hormone therapy. It has been studied in relation to estrogen levels, menopausal symptoms, bone health, and vaginal and skin tissue." },
      { name: 'Progesterone', klass: 'Progestogen hormone', definition: "A naturally occurring progestogen hormone, available in compounded preparations. It is studied in relation to hormonal balance, the menstrual cycle, sleep, and mood, and is sometimes used alongside estrogen therapy." },
      { name: 'Enclomiphene', klass: 'Selective estrogen receptor modulator (SERM)', definition: "A selective estrogen receptor modulator that signals the pituitary to increase luteinizing and follicle-stimulating hormone. It is studied for supporting the body's own testosterone production while helping preserve fertility." },
      { name: 'Thyroid', klass: 'Thyroid hormone preparation', definition: "A thyroid hormone formulation that may combine T4 and T3 forms. It is studied in relation to thyroid hormone balance and is prescribed individually after consultation." },
    ],
  },
  {
    id: 'metabolic',
    label: 'Metabolic & Weight Loss',
    blurb: 'Incretin-based and metabolic agents studied in relation to blood sugar, appetite, and weight.',
    entries: [
      { name: 'Semaglutide', klass: 'GLP-1 receptor agonist', definition: "A peptide that mimics the incretin hormone GLP-1, acting on receptors involved in blood sugar regulation and appetite. It is studied and used to support glycemic regulation and weight management." },
      { name: 'Tirzepatide', klass: 'Dual GIP/GLP-1 receptor agonist', definition: "A peptide that activates both the GIP and GLP-1 incretin receptors, pathways tied to blood sugar and appetite regulation. It is studied and used to support glycemic regulation and weight management." },
      { name: 'Retatrutide', klass: 'Triple GIP/GLP-1/glucagon receptor agonist', definition: "An investigational peptide that engages the GIP, GLP-1, and glucagon receptors, pathways involved in appetite, blood sugar, and energy metabolism. It is being studied for its potential role in weight management and metabolic health." },
    ],
  },
  {
    id: 'peptides',
    label: 'Peptide Therapy — Recovery & Repair',
    blurb: 'Research peptides studied for their potential roles in tissue repair and recovery.',
    entries: [
      { name: 'BPC-157', klass: 'Synthetic peptide (pentadecapeptide)', definition: "A synthetic 15-amino-acid peptide derived from a sequence found in gastric juice. It is studied for its potential role in tissue repair and recovery, including the gut, tendon, and connective tissue." },
      { name: 'TB-500', klass: 'Synthetic peptide (thymosin beta-4 fragment/analog)', definition: "A synthetic peptide related to thymosin beta-4, a naturally occurring protein involved in cell movement and tissue organization. It is studied for its potential role in tissue repair, recovery, and mobility." },
      { name: 'KPV', klass: 'Tripeptide (alpha-MSH fragment)', definition: "A short three-amino-acid peptide derived from the C-terminal region of the hormone alpha-melanocyte-stimulating hormone (alpha-MSH). It is studied for its potential role in the body's inflammatory response and gut and skin health." },
      { name: 'GHK-Cu', klass: 'Copper-binding tripeptide', definition: "A naturally occurring copper-binding peptide (glycyl-histidyl-lysine) found in human plasma. It is studied and used to support tissue repair, skin health, and collagen-related processes." },
    ],
  },
  {
    id: 'performance',
    label: 'Performance & Growth',
    blurb: "Peptides and analogs studied for their effects on the body's own growth hormone and related signaling.",
    entries: [
      { name: 'Sermorelin', klass: 'Growth hormone-releasing hormone (GHRH) analog', definition: "A synthetic peptide that mimics a fragment of the body's natural growth hormone-releasing hormone, prompting the pituitary gland to release growth hormone. It is studied for supporting the body's own growth hormone output, with interest in areas such as body composition, recovery, and sleep quality." },
      { name: 'CJC-1295', klass: 'Growth hormone-releasing hormone (GHRH) analog', definition: "A modified GHRH-analog peptide (based on GRF 1-29) that signals the pituitary to release growth hormone. It is studied to support the body's own growth hormone and IGF-1 levels, and some forms are modified to extend their duration of activity." },
      { name: 'Ipamorelin', klass: 'Growth hormone secretagogue / ghrelin receptor agonist', definition: "A selective peptide secretagogue that stimulates the pituitary to release growth hormone through the ghrelin receptor pathway. It is studied for supporting growth hormone release and is noted for receptor selectivity." },
      { name: 'Tesamorelin', klass: 'Growth hormone-releasing hormone (GHRH) analog', definition: "A stabilized GHRH-analog peptide that stimulates the pituitary to release growth hormone. It has been studied most extensively in relation to excess visceral (abdominal) adipose tissue and body composition." },
      { name: 'IGF-LR3', klass: 'Insulin-like growth factor-1 analog (Long R3 variant)', definition: "A modified, longer-acting analog of insulin-like growth factor-1, a hormone that mediates many of the downstream effects of growth hormone on tissue growth and repair. It is studied in relation to cellular growth, recovery, and anabolic signaling." },
    ],
  },
  {
    id: 'recomp',
    label: 'Recomposition',
    blurb: 'Agents studied for their potential roles in fat metabolism and lean-mass support.',
    entries: [
      { name: 'AOD-9604', klass: 'Peptide fragment (modified hGH 176-191)', definition: "A synthetic peptide derived from the C-terminal fragment of human growth hormone. It is studied for its potential role in fat metabolism without the broader growth-hormone effects of the full molecule." },
      { name: 'MOTS-c', klass: 'Mitochondrial-derived peptide', definition: "A small peptide encoded in mitochondrial DNA that acts as a metabolic regulator. It is studied for its potential role in cellular energy production, insulin sensitivity, and fat metabolism." },
      { name: 'SLU-PP-332', klass: 'Synthetic ERR (estrogen-related receptor) agonist', definition: "An investigational small-molecule compound that activates estrogen-related receptors involved in energy metabolism. It is being studied for its potential role in fat metabolism and exercise-related adaptations." },
    ],
  },
  {
    id: 'longevity',
    label: 'Lifestyle & Longevity',
    blurb: 'Coenzymes and peptides studied in relation to cellular aging, immune balance, and cognitive support.',
    entries: [
      { name: 'NAD+', klass: 'Coenzyme (nicotinamide adenine dinucleotide)', definition: "An essential coenzyme present in every cell that participates in energy metabolism and cellular repair pathways. It is studied and used to support mitochondrial function, cellular energy production, and aspects of healthy aging." },
      { name: 'Epithalon', klass: 'Synthetic tetrapeptide (pineal-derived)', definition: "A synthetic four-amino-acid peptide modeled on a pineal gland extract. It is being studied for its potential role in regulating circadian and endocrine rhythms and in telomere and cellular-aging biology." },
      { name: 'Thymosin Alpha-1', klass: 'Synthetic thymic peptide (immunomodulator)', definition: "A synthetic peptide based on a naturally occurring thymus-derived hormone involved in immune regulation. It is studied for its potential role in immune regulation." },
      { name: 'Semax', klass: 'Synthetic peptide (ACTH-derived; nootropic)', definition: "A synthetic peptide derived from a fragment of adrenocorticotropic hormone (ACTH). It is studied for its potential effects on cognition, focus, and neuroprotection." },
      { name: 'Selank', klass: 'Synthetic peptide (tuftsin analog; anxiolytic)', definition: "A synthetic peptide analog of the naturally occurring immune peptide tuftsin. It is studied for its potential effects on anxiety, stress resilience, and cognitive function." },
    ],
  },
  {
    id: 'labs',
    label: 'Labs & Diagnostics',
    blurb: 'The measurement layer underneath every protocol, read by the same provider running your plan.',
    entries: [
      { name: 'Hormone panel', klass: 'Diagnostic', definition: "Total and free testosterone, estradiol, LH/FSH, SHBG, and related markers to guide hormone therapy." },
      { name: 'Metabolic panel', klass: 'Diagnostic', definition: "Glucose, insulin, HbA1c, and lipids to track metabolic and weight-related health." },
      { name: 'Thyroid panel', klass: 'Diagnostic', definition: "TSH, free T3 and T4, and thyroid antibodies to assess thyroid function." },
      { name: 'Inflammation & micronutrients', klass: 'Diagnostic', definition: "Markers such as hs-CRP, plus vitamin D, B12, and ferritin, to round out the picture." },
    ],
  },
];
---

<Layout
  title="Peptide & Compound Dictionary · TRT, GLP-1, Peptides | Viva Wellness Co."
  description="A plain-language dictionary of the peptides and compounds used at Viva Wellness Co.: hormones, GLP-1s, recovery and growth peptides, longevity and cognitive agents, and labs. Each is prescribed individually after a provider consult. Concierge telehealth in Texas, Colorado, Florida, and Iowa."
>
  <section class="menu-hero">
    <div class="container menu-hero__inner">
      <span class="eyebrow">· Peptide &amp; compound dictionary</span>
      <h1 class="menu-hero__title">
        Know what's <span class="italic-display">in it.</span>
      </h1>
      <p class="lead menu-hero__lead">
        A plain-language reference to every peptide and compound I work with,
        grouped by goal: what each one is, and what it's studied to support. No
        brand names, no hype. Your actual protocol is built with me, after we talk
        and look at your labs.
      </p>
      <nav class="menu-jump" aria-label="Jump to a category">
        {menu.map((c) => (
          <a href={`#${c.id}`} class="menu-jump__link">{c.label}</a>
        ))}
      </nav>
    </div>
  </section>

  {menu.map((c) => (
    <section class="menu-cat" id={c.id} aria-labelledby={`${c.id}-h`}>
      <div class="container menu-cat__inner">
        <div class="menu-cat__head">
          <h2 id={`${c.id}-h`} class="menu-cat__title">{c.label}</h2>
          <p class="menu-cat__blurb">{c.blurb}</p>
        </div>
        <ul class="menu-list">
          {c.entries.map((e) => (
            <li class="entry">
              <h3 class="entry__name">{e.name}</h3>
              <span class="entry__klass">{e.klass}</span>
              <p class="entry__def">{e.definition}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  <section class="section section--paper menu-note-section">
    <div class="container">
      <p class="menu-note">
        These names are for educational purposes and are not the names of
        FDA-approved medications. Each is a wellness protocol of compounded
        peptides and/or medications, prescribed individually based on a licensed
        provider consultation. A medical consultation is required before
        prescribing. Individual results may vary. These protocols are intended
        for wellness support and should not be interpreted as claims to diagnose,
        treat, cure, or prevent any disease.
      </p>
    </div>
  </section>

  <section class="menu-cta">
    <div class="container menu-cta__inner">
      <h2 class="menu-cta__title">
        Not sure what fits? <span class="italic-display">Start with a visit.</span>
      </h2>
      <p class="lead">
        Tell me your goals and I'll build the protocol: the right compounds, the
        right doses, adjusted as we go.
      </p>
      <div class="menu-cta__ctas">
        <a href="/start?utm_source=vivawellnessco&utm_medium=cta&utm_content=menu_cta" class="btn btn--bronze">Book your first visit</a>
        <a href="/#quiz" class="btn">Take the match quiz</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .menu-hero { padding: clamp(6rem, 12vw, 9rem) 0 clamp(2.5rem, 6vw, 4rem); }
  .menu-hero__inner { max-width: 900px; display: flex; flex-direction: column; gap: 1.4rem; }
  .menu-hero__title { font-size: clamp(2.6rem, 7vw, 5rem); line-height: 1.02; letter-spacing: -0.028em; }
  .menu-hero__title .italic-display { color: var(--bronze); }
  .menu-hero__lead { max-width: 62ch; }
  .menu-jump { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.6rem; }
  .menu-jump__link { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--paper); border: 1px solid var(--rule-strong); border-radius: var(--radius-pill); padding: 0.5rem 0.9rem; text-decoration: none; transition: background 200ms var(--ease), border-color 200ms var(--ease), color 200ms var(--ease); }
  .menu-jump__link:hover { background: var(--bronze); color: var(--ink); border-color: var(--bronze); }

  .menu-cat { padding: clamp(2rem, 5vw, 3.5rem) 0; border-top: 1px solid var(--rule); scroll-margin-top: 90px; }
  .menu-cat__inner { display: grid; grid-template-columns: 1fr 2fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: start; }
  .menu-cat__title { font-size: clamp(1.6rem, 3.5vw, 2.4rem); letter-spacing: -0.02em; }
  .menu-cat__blurb { color: rgba(245, 241, 234, 0.7); font-size: 0.95rem; line-height: 1.5; margin-top: 0.6rem; max-width: 36ch; }

  .menu-list { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--rule); border: 1px solid var(--rule); }
  .entry { background: var(--ink); padding: 1.2rem 1.3rem; display: flex; flex-direction: column; gap: 0.35rem; }
  .entry__name { font-size: 1.1rem; line-height: 1.2; color: var(--paper); letter-spacing: -0.01em; }
  .entry__klass { font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--bronze); }
  .entry__def { color: rgba(245, 241, 234, 0.7); font-size: 0.85rem; line-height: 1.5; margin-top: 0.15rem; }

  .menu-note-section { padding: clamp(2.5rem, 6vw, 4rem) 0; }
  .menu-note { max-width: 76ch; color: var(--ink); opacity: 0.72; font-size: 0.82rem; line-height: 1.6; }

  .menu-cta { padding: clamp(3rem, 8vw, 6rem) 0; text-align: center; }
  .menu-cta__inner { max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 1.2rem; align-items: center; }
  .menu-cta__title { font-size: clamp(2rem, 5vw, 3.4rem); letter-spacing: -0.02em; }
  .menu-cta__title .italic-display { color: var(--bronze); }
  .menu-cta__ctas { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; margin-top: 0.4rem; }

  @media (max-width: 800px) {
    .menu-cat__inner { grid-template-columns: 1fr; }
    .menu-list { grid-template-columns: 1fr; }
  }
</style>
