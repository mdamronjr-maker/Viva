      { name: 'MOTS-c', desc: 'Mitochondrial and metabolic support.' },
      { name: 'Glutathione', desc: 'Antioxidant and detox support.' },
      { name: 'GHK-Cu', desc: 'Skin, hair, and tissue support.' },
      { name: '5-Amino-1MQ', desc: 'Studied for metabolism and body composition.' },
    ],
  },
  {
    id: 'labs',
    label: 'Labs & Diagnostics',
    blurb: 'The measurement layer underneath every protocol. Ordered through your insurance where possible, read by the same provider running your plan.',
    items: [
      { name: 'Comprehensive hormone panel', desc: 'Total/free testosterone, estradiol, LH/FSH, SHBG, and more.' },
      { name: 'Metabolic panel', desc: 'Glucose, insulin, HbA1c, and lipids.' },
      { name: 'Thyroid panel', desc: 'TSH, free T3/T4, and antibodies.' },
      { name: 'Inflammation & micronutrients', desc: 'hs-CRP, vitamin D, B12, ferritin, and more.' },
