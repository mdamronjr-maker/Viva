---
import Layout from '../layouts/Layout.astro';

/* ============================================================
   /start · the intake page that should sit between any "Book"
   button and the GlossGenius scheduler. Adds the context that
   concierge customers expect (duration, price, what to bring,
   who their provider is) before they hand over a card.

   To wire this as the universal booking destination, swap every
   GlossGenius href across the site to /start. The Schedule CTA
   below still routes to GlossGenius with a "start_page" UTM tag.
   ============================================================ */

// Mirrors the "New Patient Consult" SKU in GlossGenius. Update both places
// (here + the scheduler) if the price or deposit ever changes.
const FIRST_VISIT_DURATION_MIN = 45;
const FIRST_VISIT_PRICE_USD = 200;
const FIRST_VISIT_DEPOSIT_USD = 50;
const FIRST_VISIT_CREDIT_NOTE =
  `One-time fee, separate from any membership. $${FIRST_VISIT_DEPOSIT_USD} deposit due at booking, balance billed at the visit.`;

// TODO: replace with the real Calendly (or other scheduler) URL for the free
// 15-minute discovery call. Leaving as a placeholder so the CTA renders and
// can be flipped on by editing one constant when the link is ready. If left
// empty, the discovery-call CTA won't render anywhere.
const DISCOVERY_CALL_URL = ''; // e.g. 'https://calendly.com/liliana-viva/intro'

// Pass any UTM params from the inbound link straight through to the booking
// destination, so attribution survives the /start intermediate page. Fall
// back to a start_page default when the page is visited directly.
const incoming = Astro.url.searchParams;
const utmKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'] as const;
const utmParts = utmKeys
  .map((k) => {
    const v = incoming.get(k);
    return v ? `${k}=${encodeURIComponent(v)}` : null;
  })
  .filter(Boolean);
const utmQuery = utmParts.length
  ? utmParts.join('&')
  : 'utm_source=vivawellnessco&utm_medium=cta&utm_content=start_page';
const bookingHref = `https://vivawellnessco.glossgenius.com/services?${utmQuery}`;

const whatToBring = [
  'Any labs from the last twelve months, even the ones that came back out of range',
  'A list of what you take right now, prescriptions and supplements, with doses',
  'What you actually want, in your own words (energy, body comp, performance, recovery, longevity)',
  'A working webcam and a quiet forty-five minutes to yourself',
];

const visitSteps = [
  {
    num: '01',
    title: 'I ask what you have already tried',
    body: 'We start with what you have actually done, what helped, what flopped, and what changed along the way. No rushing you through a checklist.',
  },
  {
    num: '02',
    title: 'We look at the whole picture',
    body: 'Liliana goes through your labs, your symptoms, and your goals together, not in separate silos. If your labs are missing or out of date, she orders what we need.',
  },
  {
    num: '03',
    title: 'You get a plan in plain English',
    body: 'You leave with a written protocol recommendation, plus a clear breakdown of what is in it, what it costs, and what the first ninety days should feel like.',
  },
  {
    num: '04',
    title: 'Nobody talks you into anything',
    body: 'You decide whether to enroll after the visit, not during it. The first-visit fee is a one-time charge, separate from any membership you might choose to start.',
  },
];

// First ninety days · process-clarity timeline shown to prospects right
// before the final Schedule CTA. Generic enough to apply across protocols
// (TRT, HRT, GLP-1, peptides); Liliana can edit the clinical cadence as needed.
const ninetyDays = [
  {
    range: 'Days 0–3',
    label: 'First few days',
    title: 'Intake, script, medication ships',
    body: 'Your first telehealth visit. Liliana goes through your history, writes your starting protocol, and sends it over to the 503A pharmacy. Compounded medication usually ships in 48–72 hours, and most patients have it in hand within the first week.',
  },
  {
    range: 'Days 3–30',
    label: 'Weeks 1–4',
    title: 'Titration begins',
    body: 'We start low and build up at your pace, based on how you tolerate it. Message me directly with any side-effect questions, no phone tree. If your labs are still pending, this is the window where they get drawn.',
  },
  {
    range: 'Days 30–60',
    label: 'Weeks 5–8',
    title: 'First dose-adjustment check-in',
    body: 'We sit down again and tune the protocol around how your body is actually responding. Any changes come from your numbers and how you feel, not a one-size-fits-all calendar.',
  },
  {
    range: 'Days 60–90',
    label: 'Weeks 9–12',
    title: 'Labs re-pulled, results reviewed',
    body: 'Follow-up labs tell us the protocol is doing what we hoped. Liliana walks you through every number so you understand it, not just nods along. From here it is monthly maintenance with quarterly check-ins.',
  },
];
---

<Layout
  title="Your first visit · Viva Wellness Co."
  description="What to expect from your first telehealth visit with Viva Wellness Co. · duration, price, what to bring, and how Liliana works through your goals."
>

  <section class="start-hero">
    <div class="container start-hero__inner">
      <span class="eyebrow">· Your first visit</span>
      <h1 class="start-hero__title">
        Forty-five minutes <span class="italic-display">with Liliana.</span>
      </h1>
      <p class="lead">
        Before you book, I want you to know exactly what the first visit looks like,
        what it costs, and what to bring. Concierge should mean you can see everything
        coming. Nothing hidden, no surprise bill in your inbox later.
      </p>
    </div>
  </section>

  <section class="start-headline">
    <div class="container">
      <ul class="start-headline__grid">
        <li>
          <span class="eyebrow">Duration</span>
          <strong>{FIRST_VISIT_DURATION_MIN} min</strong>
          <span class="start-headline__note">Secure video. No commute, no waiting room, no old magazines.</span>
        </li>
        <li>
          <span class="eyebrow">Visit fee</span>
          <strong>${FIRST_VISIT_PRICE_USD}</strong>
          <span class="start-headline__note">{FIRST_VISIT_CREDIT_NOTE}</span>
        </li>
        <li>
          <span class="eyebrow">Provider</span>
          <strong>Liliana Damron, APRN, FNP-BC</strong>
          <span class="start-headline__note">Founder. Your first visit is with me, every time, not someone I handed you off to.</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container start-grid">
      <div class="start-grid__left">
        <span class="index" data-num="01">What happens</span>
        <h2 class="start-h2">
          The visit, <span class="italic-display">step by step.</span>
        </h2>
        <ol class="start-steps">
          {visitSteps.map((s) => (
            <li class="start-step">
              <span class="start-step__num">{s.num}</span>
              <div>
                <h3 class="start-step__title">{s.title}</h3>
                <p class="start-step__body">{s.body}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <aside class="start-grid__right">
        <div class="start-card">
          <span class="eyebrow">· Bring with you</span>
          <ul class="start-bring">
            {whatToBring.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <p class="start-card__note">
            No recent labs? Don't worry about it. I'll order what we need at the
            first visit, and you can usually run those labs through your insurance.
          </p>
        </div>

        <div class="start-card start-card--quiet">
          <span class="eyebrow">· Not ready to book?</span>
          <p>
            Take the protocol-match quiz first. Five questions, about ninety seconds.
            You'll land on the program tier that fits your goals and your budget, and
            the eBook shows up in your inbox right away.
          </p>
          <a href="/#quiz" class="start-link">Take the quiz →</a>
        </div>
      </aside>
    </div>
  </section>

  <section class="section ninety">
    <div class="container">
      <div class="ninety__head">
        <span class="index" data-num="02">After your first visit</span>
        <h2 class="ninety__title">
          What the first <span class="italic-display">ninety days</span> actually look like.
        </h2>
        <p class="lead">
          Here's the actual calendar, not a vague promise. This rhythm holds across
          hormone, metabolic, peptide, and recovery protocols, and I shift the timing
          to match what your body is telling me along the way.
        </p>
      </div>

      <ol class="ninety__list">
        {ninetyDays.map((phase) => (
          <li class="ninety__phase">
            <div class="ninety__phase-head">
              <span class="ninety__phase-label">{phase.label}</span>
              <span class="ninety__phase-range">{phase.range}</span>
            </div>
            <h3 class="ninety__phase-title">{phase.title}</h3>
            <p class="ninety__phase-body">{phase.body}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="start-cta">
    <div class="container start-cta__inner">
      <h2 class="start-cta__title">
        Ready when you <span class="italic-display">are.</span>
      </h2>
      <p class="lead">
        Booking takes about a minute. You pick a time, fill out a short intake form,
        and I'll send your video link the day before we meet.
      </p>
      <div class="start-cta__ctas">
        <a href={bookingHref} target="_blank" rel="noopener" class="btn btn--bronze">
          Schedule my first visit
        </a>
        {DISCOVERY_CALL_URL && (
          <a href={DISCOVERY_CALL_URL} target="_blank" rel="noopener" class="btn">
            Talk to Liliana first · 15 min, free
          </a>
        )}
        <a href="/contact" class="btn">Ask a question first</a>
      </div>
      <p class="start-cta__fine">
        Texas, Colorado, Florida, and Iowa residents only at time of visit. Visit fee
        is paid through GlossGenius (HIPAA-eligible payment processor).
      </p>
    </div>
  </section>

</Layout>

<style>
  .start-hero {
    padding: clamp(5rem, 11vw, 9rem) 0 clamp(2rem, 5vw, 3rem);
    position: relative;
    overflow: hidden;
  }
  .start-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(800px 500px at 75% 0%, rgba(214, 134, 74, 0.14), transparent 65%);
    pointer-events: none;
  }
  .start-hero__inner { position: relative; max-width: 60ch; }
  .start-hero__title {
    font-size: clamp(2.6rem, 6vw, 4.5rem);
    line-height: 1.0;
    letter-spacing: -0.02em;
    margin: 1rem 0 1.5rem;
  }
  .start-hero__title .italic-display { color: var(--bronze-bright); }

  .start-headline {
    padding: 0 0 clamp(2rem, 5vw, 3.5rem);
  }
  .start-headline__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: 1px solid var(--rule-strong);
    border-radius: 2px;
    background: var(--rule-strong);
  }
  @media (max-width: 760px) { .start-headline__grid { grid-template-columns: 1fr; } }
  .start-headline__grid li {
    background: var(--ink-2);
    padding: 1.5rem 1.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .start-headline__grid strong {
    font-family: var(--font-display);
    font-size: 2.4rem;
    font-weight: 460;
    line-height: 1;
    color: var(--paper);
    letter-spacing: -0.015em;
  }
  .start-headline__note {
    color: rgba(247, 244, 238, 0.7);
    font-size: 0.92rem;
    line-height: 1.5;
    max-width: 32ch;
  }

  .start-grid {
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }
  @media (max-width: 900px) { .start-grid { grid-template-columns: 1fr; } }

  .start-h2 {
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin: 0.6rem 0 2rem;
    max-width: 18ch;
    line-height: 1.05;
  }
  .start-h2 .italic-display { color: var(--bronze); }

  .start-steps { display: flex; flex-direction: column; border-top: 1px solid var(--rule-strong); }
  .start-step {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 1.2rem;
    padding: 1.6rem 0;
    border-bottom: 1px solid var(--rule);
    align-items: start;
  }
  .start-step__num {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--bronze);
    letter-spacing: 0.12em;
    padding-top: 0.4rem;
  }
  .start-step__title {
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
    color: var(--paper);
  }
  .start-step__body {
    color: rgba(247, 244, 238, 0.78);
    font-size: 0.98rem;
    line-height: 1.6;
    max-width: 56ch;
  }

  .start-card {
    background: var(--ink-2);
    border: 1px solid var(--rule);
    border-left: 2px solid var(--bronze);
    padding: 1.6rem 1.7rem;
    margin-bottom: 1.4rem;
  }
  .start-card .eyebrow { display: block; margin-bottom: 1rem; }
  .start-bring {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-bottom: 1rem;
  }
  .start-bring li {
    padding-left: 1.2rem;
    position: relative;
    color: rgba(247, 244, 238, 0.85);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .start-bring li::before {
    content: '·';
    position: absolute;
    left: 0;
    color: var(--bronze);
    font-weight: 700;
  }
  .start-card__note {
    color: rgba(247, 244, 238, 0.6);
    font-size: 0.85rem;
    line-height: 1.55;
    padding-top: 1rem;
    border-top: 1px solid var(--rule);
  }
  .start-card--quiet { border-left-color: var(--rule-strong); }
  .start-card--quiet p {
    color: rgba(247, 244, 238, 0.78);
    font-size: 0.95rem;
    line-height: 1.55;
    margin-bottom: 0.8rem;
  }
  .start-link {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bronze);
    transition: color 200ms var(--ease);
  }
  .start-link:hover { color: var(--bronze-bright); }

  /* ============ FIRST NINETY DAYS ============ */
  .ninety {
    padding: clamp(3rem, 6vw, 5rem) 0;
    border-top: 1px solid var(--rule);
  }
  .ninety__head { max-width: 800px; margin-bottom: clamp(2rem, 4vw, 3rem); }
  .ninety__title {
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin: 0.6rem 0 1.2rem;
    max-width: 22ch;
    line-height: 1.05;
  }
  .ninety__title .italic-display { color: var(--bronze); }
  .ninety__list {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--rule-strong);
    border: 1px solid var(--rule-strong);
    border-radius: 2px;
  }
  @media (max-width: 900px) { .ninety__list { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .ninety__list { grid-template-columns: 1fr; } }
  .ninety__phase {
    background: var(--ink);
    padding: clamp(1.4rem, 3vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    position: relative;
    transition: background 240ms var(--ease);
  }
  .ninety__phase:hover { background: var(--ink-2); }
  .ninety__phase-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.8rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0.4rem;
  }
  .ninety__phase-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--bronze);
  }
  .ninety__phase-range {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--mute);
    letter-spacing: 0.08em;
  }
  .ninety__phase-title {
    font-size: 1.15rem;
    line-height: 1.2;
    color: var(--paper);
    margin: 0;
  }
  .ninety__phase-body {
    color: rgba(247, 244, 238, 0.78);
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0;
    max-width: none;
  }

  .start-cta {
    padding: clamp(4rem, 8vw, 7rem) 0;
    background: var(--ink);
    border-top: 1px solid var(--rule);
    position: relative;
    overflow: hidden;
  }
  .start-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(700px 400px at 50% 0%, rgba(214, 134, 74, 0.18), transparent 60%);
    pointer-events: none;
  }
  .start-cta__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    max-width: 60ch;
    margin: 0 auto;
  }
  .start-cta__title {
    font-size: clamp(2rem, 5vw, 3.6rem);
    margin: 0.4rem 0;
    line-height: 1.05;
  }
  .start-cta__title .italic-display { color: var(--bronze-bright); }
  .start-cta__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 0.8rem;
  }
  .start-cta__fine {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--mute);
    line-height: 1.55;
    margin-top: 1.5rem;
  }
</style>
