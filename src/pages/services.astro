---
import Layout from '../layouts/Layout.astro';

// Four quiz-aligned tiers. The quiz routes every prospect into one of these
// four. Anything more granular (micro-dose, advanced, elite, etc.) is a
// variation the provider recommends in-visit, not a separately-shoppable SKU.
//
// Annual pricing = monthly * 12 with ~16% off. Numbers rounded to clean dollars.
// Adjust ANNUAL_DISCOUNT or the individual annual* fields if a different
// promotional rate is desired.
const programs = [
  {
    tier: 'Entry',
    name: 'Concierge Access',
    price: 99,
    priceLabel: '$99',
    annualLabel: '$999',
    annualSavingsLabel: 'save $189',
    tagline: 'Provider access + member pricing on peptides and compounded meds.',
    body: 'A membership for a la carte buyers. You get concierge-level provider attention across hormones, peptides, metabolic, and recovery, plus member pricing on compounded peptides, GLP-1, and TRT add-ons when you want to order them. Pay only for the protocols you actually use instead of committing to a bundled monthly fee.',
    includes: [
      'Direct messaging access to your provider',
      'Monthly evaluation visit + one acute/sick visit credit per month',
      'Member pricing on compounded peptides (BPC-157, TB-500, GHK-Cu, CJC, etc.)',
      'Member pricing on compounded GLP-1 and TRT add-ons',
      'Lab orders + standard prescriptions routed through your insurance',
      'Guidance across hormones, peptides, metabolic, and recovery',
    ],
    rightFor: [
      'You want to pay only for what you use, not a bundled monthly fee',
      'You want to try a peptide or compounded protocol without locking into an all-inclusive tier',
      'You have insurance that covers your labs and standard prescriptions',
      'You want a provider thinking about you across multiple paths, not a one-off appointment',
    ],
    notRightFor: [
      'You want a predictable flat fee that includes everything for one protocol (see TRT & HRT All Inclusive or Metabolic Core)',
      'You want everything across hormones, recovery, and performance under one fully-managed plan (see Peak Performance)',
    ],
  },
  {
    tier: 'Foundational',
    name: 'TRT & HRT All Inclusive',
    price: 199,
    priceLabel: '$199',
    annualLabel: '$1,999',
    annualSavingsLabel: 'save $389',
    tagline: 'Hormone optimization for men and women, flat monthly fee.',
    body: 'Personalized hormone optimization for both men and women. Compounded testosterone for TRT, plus compounded estradiol, progesterone, and adjunct protocols for HRT and perimenopause support. Supplies, biannual labs, and home delivery in one monthly fee.',
    includes: [
      'Compounded testosterone (injection, cream, or gel) for TRT',
      'Compounded estradiol + progesterone for HRT (cream, troche, or pellet protocols)',
      'Anastrozole, HCG, DHEA, and thyroid adjuncts when clinically indicated',
      'Perimenopause and menopause symptom management',
      'Biannual labs and dose adjustments',
      'Supplies, sharps, and home delivery',
      'Direct provider access by message',
    ],
    rightFor: [
      'You want hormone optimization (TRT for men, HRT for women) at a flat monthly fee',
      'You have known low-T, perimenopause, or menopause symptoms you want addressed',
      'You want labs, supplies, and dose adjustments handled inside the membership',
    ],
    notRightFor: [
      'You are focused primarily on weight loss (see Metabolic Core)',
      'You want hormones, GLP-1, and performance peptides under one plan (see Peak Performance)',
    ],
  },
  {
    tier: 'Core',
    name: 'Metabolic Core',
    price: 349,
    priceLabel: '$349',
    annualLabel: '$3,499',
    annualSavingsLabel: 'save $689',
    featured: true,
    tagline: 'Compounded GLP-1, shipped to you.',
    body: 'Compounded GLP-1 protocol for stronger appetite control, consistent fat loss, and preserved muscle. Patient-specific semaglutide or tirzepatide from a 503A pharmacy (same active molecules as Wegovy and Mounjaro, prepared individually under clinical supervision, not the brand-name products).',
    includes: [
      'Compounded semaglutide or tirzepatide, 503A-sourced',
      'Dose titration calibrated to your physiology',
      'Tesamorelin option for visceral fat targeting',
      'Optional recovery peptide layer',
      'Supplies, sharps, and home delivery',
      'Provider-led monthly check-ins',
    ],
    rightFor: [
      'Compounded GLP-1 (semaglutide or tirzepatide) is your primary goal',
      'You want a provider actively managing titration and side effects, not a five-minute refill',
      'You want supplies, sharps, and shipments handled inside the membership',
    ],
    notRightFor: [
      'You want testosterone or HRT as the focus (see TRT & HRT All Inclusive)',
      'You want recovery and performance peptides combined with metabolic (see Peak Performance)',
    ],
  },
  {
    tier: 'Premium',
    name: 'Peak Performance',
    price: 699,
    priceLabel: '$699',
    annualLabel: '$6,999',
    annualSavingsLabel: 'save $1,389',
    tagline: 'Everything, fully managed.',
    body: 'Total-body optimization combining hormone, metabolic, recovery, and performance protocols in one plan. The single tier that makes sense when you want all of it under one provider with priority access.',
    includes: [
      'Provider-led hormone foundation (TRT or HRT)',
      'Recovery peptide stack (BPC-157, TB-500, GHK-Cu)',
      'Performance support (CJC-1295 / Ipamorelin, MOTS-c)',
      'Optional compounded GLP-1 layer',
      'Comprehensive labs, supplies, and home delivery',
      'Priority scheduling and provider access',
    ],
    rightFor: [
      'You want hormones, metabolic, recovery, and performance under one fully-managed plan',
      'You want priority scheduling and the most direct provider access available',
      'You are already running pieces of this stack and want them coordinated by one provider',
    ],
    notRightFor: [
      'You only need one protocol (start with TRT/HRT or Metabolic Core instead)',
      'You want to test-drive peptides a la carte (see Concierge Access)',
    ],
  },
];

const includedAlways = [
  'One complimentary telehealth visit per quarter',
  'Direct messaging access to your provider',
  'Supplies and home delivery',
  'Routine follow-ups and dose adjustments',
  'Priority scheduling',
  'Member pricing on add-ons',
];

const pillars = [
  { num: '01', title: 'Hormone Optimization', body: 'TRT and HRT protocols calibrated to how you want to feel and perform, not just where the lab range starts.' },
  { num: '02', title: 'Metabolic Reset', body: 'Compounded GLP-1 protocols stepped to your physiology. Real appetite control without losing the muscle you trained for.' },
  { num: '03', title: 'Recovery & Healing', body: 'Peptide stacks that close the gap between training load and what your body can actually recover from. BPC-157, TB-500, GHK-Cu.' },
  { num: '04', title: 'Performance', body: 'Support for athletes and high-output professionals. Peptide and hormone protocols calibrated to keep you on the line, not behind it.' },
  { num: '05', title: 'Recomp', body: 'Coordinated metabolic, hormone, and recovery support designed to shift body composition while keeping training intact.' },
  { num: '06', title: 'Lifestyle & Longevity', body: 'Long-arc protocols for healthspan. Sleep, hormones, inflammation, and longevity peptides managed as one system.' },
];

// Schema.org · each tier emits a MedicalProcedure node so Google can
// surface a specific program in search.
const slugify = (s: string) => s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
const areaServed = [
  { '@type': 'State', name: 'Texas' },
  { '@type': 'State', name: 'Colorado' },
  { '@type': 'State', name: 'Florida' },
];
const servicesSchema = {
  '@context': 'https://schema.org',
  '@graph': programs.map((prog) => ({
    '@type': 'MedicalProcedure',
    '@id': `https://vivawellnessco.com/services#${slugify(prog.name)}`,
    name: prog.name,
    description: prog.body,
    provider: { '@id': 'https://vivawellnessco.com/#organization' },
    offers: {
      '@type': 'Offer',
      priceCurrency: 'USD',
      price: String(prog.price),
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: String(prog.price),
        priceCurrency: 'USD',
        unitText: 'MONTH',
      },
      availability: 'https://schema.org/InStock',
      areaServed,
    },
  })),
};
---

<Layout
  title="Concierge Programs · TRT, GLP-1, Performance Medicine | Viva Wellness Co."
  description="Four concierge telehealth memberships in Austin, TX. Compounded GLP-1 weight loss, TRT, recovery peptides, and total-body performance medicine. From $99 to $699 per month. Texas, Colorado, Florida."
  schema={servicesSchema}
>

  {/* HERO */}
  <section class="services-hero">
    <div class="container services-hero__inner">
      <span class="eyebrow reveal" style="--d: 100ms;">· Programs &amp; memberships</span>
      <h1 class="services-hero__title reveal" style="--d: 250ms;">
        You bring the goals,<br/>
        <span class="italic-display">I'll bring the protocol.</span>
      </h1>
      <p class="lead reveal" style="--d: 500ms;">
        Every Viva membership is a flat monthly fee with everything included.
        Medication, supplies, home delivery, follow-ups, provider access. No
        surprises. A 12-week minimum gives the protocol enough runway to
        actually work.
      </p>
    </div>
  </section>

  {/* PILLARS · the work, framed conceptually before the categorized tiers */}
  <section class="section pillars-section">
    <div class="container">
      <div class="section-head">
        <span class="index" data-num="01">The work</span>
        <h2 class="section-head__title">
          Six pillars. <span class="italic-display">Unlimited potential.</span>
        </h2>
        <p class="lead section-head__lead">
          Viva treats the body as one system. Pull on hormones, metabolism,
          recovery, or performance and the rest move. Every membership is
          whole-body, managed by a single provider.
        </p>
      </div>

      <ul class="pillars">
        {pillars.map((p) => (
          <li class="pillar">
            <span class="pillar__num">{p.num}</span>
            <h3 class="pillar__title">{p.title}</h3>
            <p class="pillar__body">{p.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* INCLUDED-EVERYWHERE STRIP */}
  <section class="included">
    <div class="container">
      <div class="included__inner">
        <div class="included__head">
          <span class="index" data-num="·">Every membership includes</span>
        </div>
        <ul class="included__list">
          {includedAlways.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* QUIZ CTA BANNER */}
  <section class="quiz-banner">
    <div class="container quiz-banner__inner">
      <div class="quiz-banner__copy">
        <span class="eyebrow">· Quick way to pick</span>
        <h2 class="quiz-banner__title">
          Five questions, <span class="italic-display">one match.</span>
        </h2>
        <p>
          Tell me your goals, training, and budget. The quiz lands you on
          the tier that fits, in about ninety seconds.
        </p>
      </div>
      <a href="/#quiz" class="btn btn--bronze">Take the quiz</a>
    </div>
  </section>

  {/* PROVIDER STRIP · a beat of warmth before the pricing grid */}
  <section class="section--paper provider-strip">
    <div class="container provider-strip__inner">
      <a href="/about" class="provider-strip__media" transition:name="provider-photo" aria-label="About Liliana Damron">
        <img src="/liliana-sm.jpg" alt="Liliana Damron, APRN, FNP-BC" loading="lazy" />
      </a>
      <div class="provider-strip__copy">
        <span class="eyebrow">· Your provider for every protocol</span>
        <p class="provider-strip__line">
          Every tier on this page is managed personally by
          <strong>Liliana Damron, APRN, FNP-BC</strong>.
          Same provider every visit — no handoffs to staff or junior clinicians.
        </p>
        <a href="/about" class="provider-strip__link">Meet your provider →</a>
      </div>
    </div>
  </section>

  {/* PROGRAMS · four quiz-aligned tiers */}
  <section class="section programs-section">
    <div class="container">
      <div class="section-head">
        <span class="index" data-num="02">The programs</span>
        <h2 class="section-head__title">
          Four tiers. <span class="italic-display">Pick yours.</span>
        </h2>
        <p class="lead section-head__lead">
          Flat monthly fee. Medication, supplies, home delivery, follow-ups,
          provider access. The quiz routes you to one of these four. The
          provider tunes the details inside your tier in your first visit.
        </p>
      </div>

      <ul class="prog-grid">
        {programs.map((p) => (
          <li class:list={["prog-card", p.featured && 'prog-card--featured']} id={slugify(p.name)}>
            <header class="prog-card__head">
              <span class="prog-card__tier">{p.tier}</span>
              <h3 class="prog-card__name">{p.name}</h3>
              <div class="prog-card__price">
                <span class="prog-card__amt">{p.priceLabel}</span>
                <span class="prog-card__cad">/mo</span>
              </div>
              <p class="prog-card__annual">
                or <strong>{p.annualLabel}</strong>/yr · <span>{p.annualSavingsLabel}</span>
              </p>
              <p class="prog-card__tagline">{p.tagline}</p>
            </header>
            <p class="prog-card__body">{p.body}</p>
            <ul class="prog-card__includes">
              {p.includes.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
            {(p.rightFor || p.notRightFor) && (
              <div class="prog-card__fit">
                {p.rightFor && (
                  <div class="prog-card__fit-block">
                    <span class="prog-card__fit-label prog-card__fit-label--yes">Right for you if</span>
                    <ul class="prog-card__fit-list">
                      {p.rightFor.map((item) => (<li>{item}</li>))}
                    </ul>
                  </div>
                )}
                {p.notRightFor && (
                  <div class="prog-card__fit-block">
                    <span class="prog-card__fit-label prog-card__fit-label--no">Not this tier if</span>
                    <ul class="prog-card__fit-list prog-card__fit-list--no">
                      {p.notRightFor.map((item) => (<li>{item}</li>))}
                    </ul>
                  </div>
                )}
              </div>
            )}
            <a href="/start?utm_source=vivawellnessco&utm_medium=cta&utm_content=services_tier" class="btn btn--bronze prog-card__cta">
              Start with {p.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* POLICIES */}
  <section class="section section--paper">
    <div class="container policies">
      <div>
        <span class="index" data-num="03">The fine print</span>
        <h2 class="policies__title">Membership policies, plainly stated.</h2>
      </div>
      <ul class="policies__list">
        <li>Provider review and approval required prior to initiating any therapy.</li>
        <li>All programs require a 12-week minimum commitment to allow adequate time for measurable results.</li>
        <li>Memberships renew automatically every 30 days. Cancel any time after the initial 12 weeks.</li>
        <li>A valid card on file is required. Payments are securely processed through GlossGenius.</li>
        <li>Medication, supplies, and shipments are provided while membership remains active.</li>
        <li>FSA and HSA accepted. Insurance not accepted for memberships, but can be applied to labs and non-compounded medications.</li>
        <li>Compounded medications (GLP-1, testosterone, estradiol, progesterone, peptides) are patient-specific preparations from FDA-regulated 503A pharmacies. They are not FDA-approved finished products. Each is prescribed individually after clinical evaluation, not selected from a menu.</li>
      </ul>
    </div>
  </section>

  {/* CTA */}
  <section class="services-cta">
    <div class="container services-cta__inner">
      <h2 class="services-cta__title">
        Not sure which tier? <span class="italic-display">Start with a visit.</span>
      </h2>
      <p class="lead">
        Your first telehealth consult is the diagnostic step. Liliana reviews
        your goals, history, and labs, then recommends the protocol that fits.
        No commitment to a tier until you've talked to a provider.
      </p>
      <div class="services-cta__ctas">
        <a href="/start?utm_source=vivawellnessco&utm_medium=cta&utm_content=services_cta" class="btn btn--bronze">Book your first visit</a>
        <a href="/contact" class="btn">Ask a question</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .services-hero {
    padding: clamp(6rem, 12vw, 10rem) 0 clamp(4rem, 8vw, 6rem);
    position: relative;
    overflow: hidden;
  }
  .services-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(800px 500px at 80% 30%, rgba(201, 120, 58, 0.15), transparent 60%);
    pointer-events: none;
  }
  .services-hero__inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    max-width: 1100px;
  }
  .services-hero__title {
    font-size: clamp(2.6rem, 6.8vw, 5.4rem);
    line-height: 1.02;
    letter-spacing: -0.028em;
  }
  .services-hero__title .italic-display { color: var(--bronze); }

  /* PILLARS */
  .pillars-section { padding: clamp(3rem, 7vw, 5rem) 0; }
  .pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; border-top: 1px solid var(--rule-strong); }
  .pillar { padding: 1.4rem 1.2rem 1.4rem 0; border-right: 1px solid var(--rule); border-bottom: 1px solid var(--rule-strong); transition: background 240ms var(--ease); }
  .pillar:nth-child(3n) { border-right: 0; }
  .pillar:hover { background: rgba(214, 134, 74, 0.04); }
  .pillar__num { font-family: var(--font-mono); font-size: 0.7rem; color: var(--bronze); letter-spacing: 0.1em; display: block; margin-bottom: 0.9rem; }
  .pillar__title { font-size: 1.2rem; margin-bottom: 0.5rem; color: var(--paper); line-height: 1.2; }
  .pillar__body { color: rgba(245, 241, 234, 0.7); font-size: 0.9rem; line-height: 1.45; }
  @media (max-width: 960px) { .pillars { grid-template-columns: repeat(2, 1fr); } .pillar { border-right: 1px solid var(--rule); padding: 1.4rem 1.2rem; } .pillar:nth-child(2n) { border-right: 0; } .pillar:nth-child(2n+1) { padding-left: 0; } }
  @media (max-width: 600px) { .pillars { grid-template-columns: 1fr; } .pillar { border-right: 0 !important; padding-left: 0; } }

  /* INCLUDED */
  .included {
    background: var(--ink-2);
    border-top: 1px solid var(--rule-strong);
    border-bottom: 1px solid var(--rule-strong);
    padding: 2.5rem 0;
  }
  .included__inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 2rem;
    align-items: start;
  }
  @media (max-width: 800px) {
    .included__inner { grid-template-columns: 1fr; }
  }
  .included__head { padding-top: 0.4rem; }
  .included__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem 2rem;
    color: rgba(245, 241, 234, 0.85);
    font-size: 0.95rem;
  }
  @media (max-width: 600px) { .included__list { grid-template-columns: 1fr; } }
  .included__list li {
    padding-left: 1.2rem;
    position: relative;
  }
  .included__list li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--bronze);
    font-size: 0.7rem;
    top: 0.4rem;
  }

  /* QUIZ BANNER */
  .quiz-banner {
    padding: clamp(3rem, 6vw, 5rem) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    background: var(--ink);
    position: relative;
    overflow: hidden;
  }
  .quiz-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(700px 400px at 80% 50%, rgba(201, 120, 58, 0.12), transparent 60%);
    pointer-events: none;
  }
  .quiz-banner__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(1.5rem, 4vw, 4rem);
    align-items: center;
  }
  @media (max-width: 800px) {
    .quiz-banner__inner { grid-template-columns: 1fr; }
  }
  .quiz-banner__title {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0.7rem 0 1rem;
    max-width: 16ch;
  }
  .quiz-banner__title .italic-display { color: var(--bronze); }
  .quiz-banner__copy p {
    color: rgba(245, 241, 234, 0.7);
    max-width: 56ch;
  }

  /* PROVIDER STRIP · between quiz banner and programs grid */
  .provider-strip {
    padding: clamp(2.4rem, 5vw, 3.8rem) 0;
    border-bottom: 1px solid rgba(12, 10, 9, 0.08);
  }
  .provider-strip__inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  @media (max-width: 600px) {
    .provider-strip__inner { grid-template-columns: 1fr; text-align: center; gap: 1.2rem; }
  }
  .provider-strip__media {
    display: block;
    width: clamp(96px, 14vw, 132px);
    height: clamp(96px, 14vw, 132px);
    border-radius: 50%;
    overflow: hidden;
    background: var(--ink);
    text-decoration: none;
    transition: transform 240ms var(--ease), box-shadow 240ms var(--ease);
  }
  @media (max-width: 600px) {
    .provider-strip__media { justify-self: center; }
  }
  .provider-strip__media:hover {
    transform: scale(1.02);
    box-shadow: 0 6px 20px rgba(12, 10, 9, 0.12);
  }
  .provider-strip__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .provider-strip__copy {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .provider-strip__line {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    font-weight: 400;
    line-height: 1.45;
    color: var(--ink);
    margin: 0;
    max-width: 58ch;
    letter-spacing: -0.005em;
  }
  .provider-strip__line strong { font-weight: 500; }
  .provider-strip__link {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--bronze-deep);
    text-decoration: none;
    transition: color 200ms var(--ease);
  }
  .provider-strip__link:hover { color: var(--bronze); }

  /* PROGRAMS · four large quiz-aligned tier cards */
  .programs-section { padding: clamp(3rem, 7vw, 5rem) 0; }
  .prog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--rule-strong);
    border: 1px solid var(--rule-strong);
  }
  @media (max-width: 800px) { .prog-grid { grid-template-columns: 1fr; } }
  .prog-card {
    background: var(--ink);
    padding: clamp(1.8rem, 3.5vw, 2.4rem);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: background 240ms var(--ease);
    position: relative;
  }
  .prog-card:hover { background: var(--ink-2); }
  .prog-card--featured {
    background: var(--ink-2);
    box-shadow: inset 0 2px 0 0 var(--bronze);
  }
  .prog-card--featured::after {
    content: 'Most chosen';
    position: absolute;
    top: 0;
    right: clamp(1.4rem, 3vw, 2rem);
    transform: translateY(-50%);
    background: var(--bronze);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.4rem 0.7rem;
    font-weight: 500;
  }
  .prog-card__head {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      "tier tier"
      "name price"
      "annual annual"
      "tagline tagline";
    gap: 0.35rem 1rem;
    padding-bottom: 1.2rem;
    border-bottom: 1px solid var(--rule);
  }
  .prog-card__annual {
    grid-area: annual;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--mute);
    margin: -0.1rem 0 0;
  }
  .prog-card__annual strong {
