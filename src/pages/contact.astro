---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact · Viva Wellness Co."
  description="Get in touch with Viva Wellness Co. and receive our free Precision Hormone & Peptide Therapy eBook by email. Concierge telehealth in Austin, TX."
>

  <section class="contact-hero">
    <div class="container contact-hero__inner">
      <span class="eyebrow reveal" style="--d: 100ms;">Start the conversation</span>
      <h1 class="contact-hero__title reveal" style="--d: 250ms;">
        Get the <span class="italic-display">eBook.</span><br/>
        Get a real reply.
      </h1>
      <p class="lead reveal" style="--d: 500ms;">
        Drop your details. We'll email you our Precision Hormone &amp; Peptide
        Therapy guide and Liliana will be in touch personally if you have
        questions. No bots, no funnels, no spam.
      </p>
    </div>
  </section>

  <section class="contact-body">
    <div class="container contact-body__grid">
      <div class="contact-body__form-wrap">
        <form class="contact-form" id="contact-form" novalidate>
          <div class="field">
            <label for="c-name" class="field__label">Your name</label>
            <input
              id="c-name"
              name="name"
              type="text"
              class="field__input"
              autocomplete="name"
              required
              placeholder="First and last"
            />
          </div>

          <div class="field">
            <label for="c-email" class="field__label">Email</label>
            <input
              id="c-email"
              name="email"
              type="email"
              class="field__input"
              autocomplete="email"
              required
              placeholder="you@example.com"
            />
          </div>

          <div class="field">
            <label for="c-phone" class="field__label">Phone</label>
            <input
              id="c-phone"
              name="phone"
              type="tel"
              class="field__input"
              autocomplete="tel"
              placeholder="(512) 555-0123"
            />
            <span class="field__hint">Optional. Used only if you ask us to call or text.</span>
          </div>

          <div class="field">
            <label for="c-message" class="field__label">Anything to share?</label>
            <textarea
              id="c-message"
              name="message"
              class="field__textarea"
              placeholder="Goals, current routine, questions about a specific protocol&hellip;"
            ></textarea>
            <span class="field__hint">Optional. Skip if you just want the eBook.</span>
          </div>

          {/* Honeypot · spam trap, hidden from real users */}
          <div class="hp" aria-hidden="true">
            <label>Leave this empty
              <input name="company" type="text" tabindex="-1" autocomplete="off" />
            </label>
          </div>

          <button type="submit" class="btn btn--bronze" id="c-submit">Send &amp; get the eBook</button>

          <div class="contact-form__status" id="c-status" role="status" aria-live="polite"></div>
        </form>
      </div>

      <aside class="contact-side">
        <div class="contact-side__card">
          <span class="eyebrow">Prefer to skip the form?</span>
          <ul class="contact-side__list">
            <li>
              <span class="contact-side__k">Call or text</span>
              <a href="tel:7372107283" class="contact-side__v">(737) 210-7283</a>
            </li>
            <li>
              <span class="contact-side__k">Email</span>
              <a href="mailto:info@vivawellnessco.com" class="contact-side__v">info@vivawellnessco.com</a>
            </li>
            <li>
              <span class="contact-side__k">WhatsApp</span>
              <a href="https://wa.me/15128002794" target="_blank" rel="noopener" class="contact-side__v">+1 512-800-2794</a>
            </li>
            <li>
              <span class="contact-side__k">Book direct</span>
              <a href="https://vivawellnessco.glossgenius.com/" target="_blank" rel="noopener" class="contact-side__v">vivawellnessco.glossgenius.com</a>
            </li>
          </ul>
        </div>

        <div class="contact-side__panel">
          <span class="contact-side__num">01</span>
          <h3>What you get</h3>
          <p>The Precision Hormone &amp; Peptide Therapy eBook (15 pages, 8 chapters) arrives in your inbox within a minute.</p>
        </div>
        <div class="contact-side__panel">
          <span class="contact-side__num">02</span>
          <h3>Service area</h3>
          <p>Concierge telehealth licensed in Texas, Colorado, and Florida.</p>
        </div>
        <div class="contact-side__panel">
          <span class="contact-side__num">03</span>
          <h3>Response time</h3>
          <p>Personal replies within 24 hours, business days. Often same day.</p>
        </div>
      </aside>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('c-status') as HTMLDivElement | null;
  const submit = document.getElementById('c-submit') as HTMLButtonElement | null;
  if (form && status && submit) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';
      status.className = 'contact-form__status';

      const data = new FormData(form);
      const payload = {
        source: 'contact',
        name: String(data.get('name') || '').trim(),
        email: String(data.get('email') || '').trim(),
        phone: String(data.get('phone') || '').trim(),
        message: String(data.get('message') || '').trim(),
        company: String(data.get('company') || '').trim(), // honeypot
      };

      if (!payload.name || !payload.email) {
        status.textContent = 'Name and email are required.';
        status.classList.add('is-error');
        return;
      }

      submit.disabled = true;
      submit.textContent = 'Sending…';

      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok || !json.ok) {
          throw new Error(json.error || 'Something went wrong. Try again or email info@vivawellnessco.com.');
        }
        status.textContent = "Sent. Check your inbox in a minute for the eBook.";
        status.classList.add('is-success');
        form.reset();
      } catch (err) {
        status.textContent = err instanceof Error ? err.message : 'Send failed. Try again.';
        status.classList.add('is-error');
      } finally {
        submit.disabled = false;
        submit.textContent = 'Send & get the eBook';
      }
    });
  }
</script>

<style>
  .contact-hero {
    padding: clamp(5rem, 12vw, 9rem) 0 clamp(2rem, 5vw, 4rem);
    position: relative;
    overflow: hidden;
  }
  .contact-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(700px 400px at 75% 10%, rgba(201, 120, 58, 0.18), transparent 60%),
      radial-gradient(500px 350px at 5% 90%, rgba(201, 120, 58, 0.08), transparent 60%);
    pointer-events: none;
  }
  .contact-hero__inner {
    position: relative;
    max-width: 60ch;
  }
  .contact-hero__title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    line-height: 0.95;
    letter-spacing: 0.005em;
    margin: 1rem 0 1.5rem;
  }
  .contact-hero__title .italic-display { color: var(--bronze-bright); }

  .contact-body {
    padding: clamp(2rem, 5vw, 4rem) 0 clamp(5rem, 10vw, 8rem);
  }
  .contact-body__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }
  @media (max-width: 900px) {
    .contact-body__grid { grid-template-columns: 1fr; }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 540px;
  }
  .contact-form .btn { align-self: flex-start; margin-top: 0.5rem; }
  .hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }

  .contact-form__status {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    min-height: 1.2em;
    padding: 0.4rem 0;
  }
  .contact-form__status.is-success { color: var(--bronze-bright); }
  .contact-form__status.is-error { color: #e76e6e; }

  .contact-side {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .contact-side__card {
    background: var(--ink-2);
    border: 1px solid var(--rule-strong);
    padding: 1.8rem 1.6rem;
    border-radius: 2px;
  }
  .contact-side__card .eyebrow { display: block; margin-bottom: 1.2rem; }
  .contact-side__list {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .contact-side__list li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .contact-side__k {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mute);
  }
  .contact-side__v {
    font-family: var(--font-display-italic);
    font-size: 1.1rem;
    letter-spacing: -0.01em;
    color: var(--paper);
    border-bottom: 1px solid transparent;
    transition: border-color 200ms var(--ease), color 200ms var(--ease);
    align-self: flex-start;
  }
  .contact-side__v:hover {
    color: var(--bronze-bright);
    border-bottom-color: var(--bronze);
  }

  .contact-side__panel {
    padding: 1.2rem 0;
    border-top: 1px solid var(--rule);
  }
  .contact-side__panel:first-of-type { border-top: 0; padding-top: 0.6rem; }
  .contact-side__num {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: var(--bronze);
    display: block;
    margin-bottom: 0.6rem;
  }
  .contact-side__panel h3 {
    font-size: 1.25rem;
    margin-bottom: 0.4rem;
    color: var(--paper);
  }
  .contact-side__panel p {
    color: rgba(245, 241, 234, 0.7);
    font-size: 0.93rem;
    line-height: 1.55;
    max-width: 36ch;
  }
</style>
