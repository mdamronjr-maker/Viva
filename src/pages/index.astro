<script>
  // Network partner rotator. Wrapped + cleaned up on astro:before-swap so
  // view transitions don't leak the interval across navigations.
  let rotatorTimer: number | undefined;

  function initRotator() {
    const rotator = document.querySelector('[data-rotator]') as HTMLElement | null;
    if (!rotator) return;
    const slides = rotator.querySelectorAll('[data-slide]');
    const dots = rotator.querySelectorAll('[data-dot]');
    let i = 0;
    const INTERVAL = 3000;
    function show(idx: number) {
      slides.forEach((s, n) => s.classList.toggle('is-active', n === idx));
      dots.forEach((d, n) => d.classList.toggle('is-active', n === idx));
      i = idx;
    }
    function next() { show((i + 1) % slides.length); }
    function start() { stop(); rotatorTimer = window.setInterval(next, INTERVAL); }
    function stop() { if (rotatorTimer) clearInterval(rotatorTimer); rotatorTimer = undefined; }
    dots.forEach((d, n) => d.addEventListener('click', () => { show(n); start(); }));
    rotator.addEventListener('mouseenter', stop);
    rotator.addEventListener('mouseleave', start);
    document.addEventListener('visibilitychange', () => { if (document.hidden) stop(); else start(); });
    start();
  }

  document.addEventListener('astro:page-load', initRotator);
  document.addEventListener('astro:before-swap', () => {
    if (rotatorTimer) { clearInterval(rotatorTimer); rotatorTimer = undefined; }
  });

  // Testimonial carousel · same pattern as the partner rotator but with
  // prev/next arrows and a longer interval (reading quotes takes time).
  let tRotatorTimer: number | undefined;

  function initTestimonialsRotator() {
    const rotator = document.querySelector('[data-trotator]') as HTMLElement | null;
    if (!rotator) return;
    const slides = rotator.querySelectorAll('[data-tslide]');
    const dots = rotator.querySelectorAll('[data-tdot]');
    const prev = rotator.querySelector('[data-tprev]') as HTMLButtonElement | null;
    const next = rotator.querySelector('[data-tnext]') as HTMLButtonElement | null;
    if (slides.length === 0) return;
    let i = 0;
    const INTERVAL = 6000;
    function show(idx: number) {
      const safe = ((idx % slides.length) + slides.length) % slides.length;
      slides.forEach((s, n) => s.classList.toggle('is-active', n === safe));
      dots.forEach((d, n) => d.classList.toggle('is-active', n === safe));
      i = safe;
    }
    function go(delta: number) { show(i + delta); start(); }
    function start() { stop(); tRotatorTimer = window.setInterval(() => show(i + 1), INTERVAL); }
    function stop() { if (tRotatorTimer) clearInterval(tRotatorTimer); tRotatorTimer = undefined; }
    dots.forEach((d, n) => d.addEventListener('click', () => { show(n); start(); }));
    prev?.addEventListener('click', () => go(-1));
    next?.addEventListener('click', () => go(1));
    rotator.addEventListener('mouseenter', stop);
    rotator.addEventListener('mouseleave', start);
    document.addEventListener('visibilitychange', () => { if (document.hidden) stop(); else start(); });
    start();
  }

  document.addEventListener('astro:page-load', initTestimonialsRotator);
  document.addEventListener('astro:before-swap', () => {
    if (tRotatorTimer) { clearInterval(tRotatorTimer); tRotatorTimer = undefined; }
    // Always exit quiz focus mode before navigation so the next page renders normally
    document.body.classList.remove('quiz-focus');
  });
</script>

<script>
  import { match, type Answers } from '../lib/quiz';

  // Wrapped in an init function and rebound on every astro:page-load so
  // view transitions reset quiz state and rebind to the freshly-rendered DOM.
  function initQuiz() {
  const TOTAL = 5;
  const state = { step: 1, answers: {} as Answers };

  const stepEls = document.querySelectorAll('.qx__step') as NodeListOf<HTMLDivElement>;
  const bar = document.getElementById('qx-bar') as HTMLDivElement | null;
  const meta = document.getElementById('qx-step-label') as HTMLSpanElement | null;
  const back = document.getElementById('qx-back') as HTMLButtonElement | null;
  const section = document.getElementById('quiz') as HTMLElement | null;

  // Only run on pages that have the quiz markup (home only)
  if (stepEls.length === 0) return;

  function render() {
    stepEls.forEach((el) => {
      el.classList.toggle('is-active', Number(el.dataset.step) === state.step);
    });
    const pct = state.step <= TOTAL ? ((state.step - 1) / TOTAL) * 100 : 100;
    if (bar) bar.style.width = `${pct}%`;
    if (meta) {
      if (state.step <= TOTAL) meta.textContent = `Question ${state.step} of ${TOTAL}`;
      else if (state.step === TOTAL + 1) meta.textContent = 'Almost there';
      else meta.textContent = 'Your match';
    }
    if (back) back.hidden = state.step <= 1 || state.step > TOTAL + 1;
    section?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Focus mode · entered when the user clicks their first answer, exited via
  // X / Escape / navigation. Idempotent class toggle.
  function enterFocus() {
    if (document.body.classList.contains('quiz-focus')) return;
    document.body.classList.add('quiz-focus');
    window.scrollTo({ top: 0, behavior: 'instant' as ScrollBehavior });
  }
  function exitFocus() {
    if (!document.body.classList.contains('quiz-focus')) return;
    document.body.classList.remove('quiz-focus');
    document.getElementById('quiz')?.scrollIntoView({ behavior: 'instant' as ScrollBehavior, block: 'start' });
  }

  document.querySelectorAll('.qx__opt').forEach((btn) => {
    btn.addEventListener('click', () => {
      const q = (btn as HTMLElement).dataset.q as keyof Answers;
      const v = (btn as HTMLElement).dataset.v as string;
      if (!q || !v) return;
      state.answers[q] = v;
      if (state.step < TOTAL + 1) state.step += 1;
      enterFocus();
      render();
    });
  });

  back?.addEventListener('click', () => {
    if (state.step > 1) { state.step -= 1; render(); }
  });

  document.getElementById('qx-exit')?.addEventListener('click', exitFocus);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.body.classList.contains('quiz-focus')) exitFocus();
  });

  const form = document.getElementById('qx-form') as HTMLFormElement | null;
  const status = document.getElementById('qx-status') as HTMLDivElement | null;
  const submit = document.getElementById('qx-submit') as HTMLButtonElement | null;

  if (form && status && submit) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.textContent = '';
      status.className = 'qx__status';
      const data = new FormData(form);
      const name = String(data.get('name') || '').trim();
      const email = String(data.get('email') || '').trim();
      const phone = String(data.get('phone') || '').trim();
      const company = String(data.get('company') || '').trim();
      if (!name || !email) {
        status.textContent = 'Name and email are required.';
        status.classList.add('is-error');
        return;
      }
      const m = match(state.answers);
      const utm: Record<string, string> = {};
      const params = new URLSearchParams(window.location.search);
      for (const k of ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'] as const) {
        const v = params.get(k);
        if (v) utm[k] = v;
      }
      submit.disabled = true;
      submit.setAttribute('aria-busy', 'true');
      submit.textContent = 'Sending';
      try {
        const res = await fetch('/api/lead', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            source: 'quiz',
            name, email, phone, company,
            quiz: state.answers,
            match: { key: m.key, name: m.name, price: m.price },
            utm,
            referrer: document.referrer || '',
          }),
        });
        const json = await res.json().catch(() => ({}));
        if (!res.ok || !json.ok) {
          throw new Error(json.error || 'Send failed. Try again or email info@vivawellnessco.com.');
        }
        document.getElementById('qx-r-name')!.textContent = m.name;
        document.getElementById('qx-r-price')!.textContent = m.price;
        document.getElementById('qx-r-body')!.textContent = m.body;
        document.getElementById('qx-r-list')!.innerHTML = m.bullets.map((b) => `<li>${b}</li>`).join('');
        state.step = TOTAL + 2;
        render();
      } catch (err) {
        status.textContent = err instanceof Error ? err.message : 'Send failed. Try again.';
        status.classList.add('is-error');
      } finally {
        submit.disabled = false;
        submit.removeAttribute('aria-busy');
        submit.textContent = 'Reveal my protocol';
      }
    });
  }
  } // end initQuiz

  document.addEventListener('astro:page-load', initQuiz);
</script>

