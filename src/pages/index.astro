---
import Layout from '../layouts/Layout.astro';
import NoPhiNotice from '../components/NoPhiNotice.astro';
import { TURNSTILE_SITEKEY } from '../lib/turnstile';

const faqs = [
  {
    q: 'Is Viva Wellness Co. accepting new patients?',
    a: "Yes. I'm licensed in Texas, Colorado, Florida, and Iowa and currently accepting new patients in all four states. New patient visits typically book within a week.",
  },
  {
    q: 'Which states are you licensed in?',
    a: 'Texas, Colorado, Florida, and Iowa. Viva is a one-hundred-percent telehealth practice, so visits happen by secure video wherever you are physically located in one of those states at the time of the appointment.',
  },
  {
    q: 'Do you accept insurance?',
    a: 'Memberships are not billed to insurance. I accept FSA and HSA cards for membership fees. For labs and non-compounded medications outside the membership, insurance can be applied. Many patients use the Viva Concierge tier specifically to keep their existing insurance for labs and prescriptions.',
  },
  {
    q: 'Where are your medications sourced from?',
    a: 'Every compounded medication I dispense comes from FDA-regulated 503A compounding pharmacies that perform third-party testing for potency and sterility. I do not work with grey-market peptide vendors. Medications ship from the pharmacy directly to your home.',
  },
  {
    q: 'Is your GLP-1 the same as Wegovy or Mounjaro?',
    a: 'Not exactly. Wegovy (semaglutide) and Mounjaro and Zepbound (tirzepatide) are brand-name medications from Novo Nordisk and Eli Lilly. I dispense compounded semaglutide and tirzepatide from FDA-regulated 503A pharmacies. Same active molecules, prepared patient-specifically under a different regulatory framework, prescribed only after my clinical evaluation. Typically far less expensive than the brand versions (which insurance rarely covers for weight loss), but they are not identical products. I will not prescribe what is not clinically appropriate for you, regardless of the tier you select.',
  },
  {
    q: 'How fast will I receive the eBook after submitting a form?',
    a: 'The Precision Hormone & Peptide Therapy eBook is emailed automatically, usually within sixty seconds. If you do not see it, check your spam folder or email info@vivawellnessco.com and I will resend.',
  },
  {
    q: 'Can I cancel my membership?',
    a: 'Yes. Memberships require an initial twelve-week commitment so the protocol has enough runway to produce measurable results. After that, you can cancel any time with no penalty. Memberships renew automatically every thirty days until you cancel.',
  },
  {
    q: 'What does Concierge Access at $99 actually include?',
    a: 'Two things. First, provider access: direct messaging with your provider, a monthly evaluation visit plus one acute/sick visit credit each month, lab orders routed through your insurance, and ongoing guidance across hormones, peptides, metabolic, and recovery. Second, member pricing: when you do want to add provider-selected compounded peptides, compounded GLP-1, or TRT add-ons, you get them at member rates instead of paying retail. It is the right tier when you want a provider thinking about you and the flexibility to pay a la carte for protocols, rather than committing to one of the all-inclusive bundles (TRT, Metabolic Core, Metabolic Advanced).',
  },
  {
    q: 'Is my health information private?',
    a: "This website collects only the marketing details you choose to share: your name, email, phone, and quiz answers (goal, age range, sex assigned at birth, activity, and budget). I don't collect clinical records such as lab results or diagnoses here. Once you become a patient, all clinical communication moves into the HIPAA-compliant patient portal. Lab results, medication adjustments, and provider messaging happen there, not on this site or in regular email.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const PICON = {
  key: '<path d="m15.5 7.5 2.3 2.3a1 1 0 0 0 1.4 0l2.1-2.1a1 1 0 0 0 0-1.4L19 4"/><path d="m21 2-9.6 9.6"/><circle cx="7.5" cy="15.5" r="5.5"/>',
  pulse: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
  flame: '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>',
  trophy: '<path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/>',
};
const programs = [
  { tier: 'Entry', name: 'Concierge Access', price: '$99', cadence: '/mo', icon: 'key', href: '/services#viva-concierge-access', body: 'Provider access plus member pricing on compounded peptides, GLP-1, and add-ons. Pay a la carte for the protocols you want instead of a bundled monthly fee.' },
  { tier: 'Foundational', name: 'TRT & HRT All Inclusive', price: '$199', cadence: '/mo', icon: 'pulse', href: '/services#trt-hrt-all-inclusive', body: 'Personalized testosterone optimization with compounded medication, supplies, and biannual labs.' },
  { tier: 'Core', name: 'Metabolic Core', price: '$349', cadence: '/mo', icon: 'flame', href: '/services#metabolic-core', body: 'Compounded tirzepatide, fully managed, for stronger appetite control and consistent fat loss.', featured: true },
  { tier: 'Premium', name: 'Metabolic Advanced', price: '$499', cadence: '/mo', icon: 'trophy', href: '/services#metabolic-advanced', body: 'Our most advanced metabolic tier: a fully managed, provider-titrated protocol for the most aggressive appetite control and fat loss. Your specific medication is selected during your clinical evaluation.' },
];

const testimonials = [
  {
    quote: "Liliana has cared for my elderly parents since I moved them urgently from Florida. She has been amazing. She picked up on things the docs missed in the hospital and I did as well. She is very smart, capable, and super nice. As a physician, the best reference is that she cares for my family.",
    name: 'Dr. Matt Phillips',
    role: 'Physician · Verified Google review',
  },
  {
    quote: "This company and Liliana have changed my life. As a medical provider myself, I can ensure you are in trustworthy hands.",
    name: 'Kaitlin Trevino',
    role: 'Medical provider · Verified Google review',
  },
  {
    quote: "Lili has been an exceptional provider throughout my wellness treatment journey. From our very first consultation, she truly understood my needs. She carefully listened as I explained my symptoms.",
    name: 'Priscilla Moraes',
    role: 'Patient · Verified Google review',
  },
  {
    quote: "The telehealth setup is incredibly convenient and made everything so easy. The care was professional, personal, and I felt truly supported throughout the process.",
    name: 'Nancy Flores',
    role: 'Telehealth patient · Verified Google review',
  },
  {
    quote: "I am so very cautious when choosing medical providers to guide me through my own health journey. Liliana exceeded every expectation.",
    name: 'Tobiah Vega',
    role: 'Patient · Verified Google review',
  },
  {
    quote: "Most competent, caring provider. I get personalized care that's effective and timely. The proof is in the results and in how I feel. Just grateful everyday I found her.",
    name: 'Tiffany Plaster',
    role: 'Patient · Verified Google review',
  },
];

---

<Layout
  title="Concierge Peptide Therapy, GLP-1 & TRT in Austin | Viva Wellness Co."
  description="Provider-led concierge telehealth in Austin, TX. GLP-1 weight loss, TRT, hormone optimization, recovery, and recomposition protocols. Texas, Colorado, Florida, Iowa. Founded by Liliana Damron, APRN, FNP-BC."
  schema={faqSchema}
>

  {/* ============ HERO · Matt Johnson full-bleed ============ */}
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <img
        src="/matt-johnson-hd.jpg"
        srcset="/matt-johnson-hd-sm.jpg 800w, /matt-johnson-hd.jpg 1600w"
        sizes="100vw"
        alt=""
        fetchpriority="high"
      />
      <div class="hero__bg-grad"></div>
    </div>

    <div class="container hero__inner">
      <div class="hero__eyebrows reveal" style="--d: 100ms;">
        <span class="eyebrow">Telehealth · TX · CO · FL · IA</span>
        <span class="eyebrow hero__eyebrow-right">· 100% Concierge</span>
      </div>

      <h1 class="hero__title">
        <span class="reveal" style="--d: 200ms;">You bring the goals.</span>
        <span class="italic-display reveal" style="--d: 420ms;">I'll build the protocol.</span>
      </h1>

      <div class="hero__foot reveal" style="--d: 1100ms;">
        <p class="hero__lead">
          I'm Liliana Damron, a nurse practitioner who'd rather catch the trouble
          early than treat it late. Tell me where you want to go, and I'll run the
          labs, build the protocol, and adjust as you go. Hormones, metabolic,
          peptides, recovery — one provider, by video, from Austin.
        </p>
        <div class="hero__ctas">
          <a href="#quiz" class="btn btn--bronze">Find your protocol</a>
          <a href="/start?utm_source=vivawellnessco&utm_medium=cta&utm_content=home_hero" class="btn hero__btn-quiet">Book your first visit</a>
        </div>
        <p class="hero__proof" style="font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--mute); margin: 0.4rem 0 0;">5.0 on Google reviews</p>
      </div>

      <div class="hero__index reveal" style="--d: 1300ms;">
        <span class="index" data-num="00">Founded by Liliana Damron, APRN, FNP-BC</span>
      </div>
    </div>
  </section>

  {/* ============ MARQUEE ============ */}
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span>Catch dysfunction early</span>
      <span>Healthspan, not just lifespan</span>
      <span>Measured, not guessed</span>
      <span>One provider, one plan</span>
      <span>Protocols that adapt to you</span>
      <span>Built before it breaks</span>
      <span>Catch dysfunction early</span>
      <span>Healthspan, not just lifespan</span>
      <span>Measured, not guessed</span>
      <span>One provider, one plan</span>
      <span>Protocols that adapt to you</span>
      <span>Built before it breaks</span>
    </div>
  </div>

  <aside class="trust" aria-label="Practice credentials"><ul class="trust__grid container" role="list"><li class="trust__cell"><span class="trust__num" aria-hidden="true">01</span><p class="trust__label">Board-certified nurse practitioner</p></li><li class="trust__cell"><span class="trust__num" aria-hidden="true">02</span><p class="trust__label">Licensed in TX, CO, FL, IA</p></li><li class="trust__cell"><span class="trust__num" aria-hidden="true">03</span><p class="trust__label">Meds from FDA-regulated 503A pharmacies, third-party tested</p></li><li class="trust__cell"><span class="trust__num" aria-hidden="true">04</span><p class="trust__label">Provider-led, never algorithm-dispensed</p></li></ul></aside>


  {/* ============ INLINE QUIZ · the showpiece ============ */}
  <section class="qx" id="quiz">
    <img class="qx__bg" src="/quiz-bg.webp" alt="" aria-hidden="true" loading="lazy" decoding="async" />
    <div class="container qx__inner">

      <div class="qx__head">
        <span class="index" data-num="01">The match</span>
        <h2 class="qx__title">
          Find your protocol, <span class="italic-display">take the match quiz.</span>
        </h2>
        <div class="qx__meta">
          <span class="eyebrow" id="qx-step-label" role="status" aria-live="polite" aria-atomic="true">Question 1 of 5</span>
          <div class="qx__progress" aria-hidden="true">
            <div class="qx__progress-bar" id="qx-bar"></div>
          </div>
        </div>
      </div>

      {/* Step 1 */}
      <div class="qx__step is-active" data-step="1">
        <p class="qx__q" id="qx-q1" role="heading" aria-level="3">What is your <span class="italic-display">primary goal</span> right now?</p>
        <div class="qx__options" role="group" aria-labelledby="qx-q1">
          <button class="qx__opt" data-q="goal" data-v="weight"><span class="qx__opt-num">01</span><span class="qx__opt-label">Lose weight or reset metabolism</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="goal" data-v="hormones"><span class="qx__opt-num">02</span><span class="qx__opt-label">Optimize hormones · energy, libido, mood</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="goal" data-v="recovery"><span class="qx__opt-num">03</span><span class="qx__opt-label">Recover from training, surgery, or injury</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="goal" data-v="longevity"><span class="qx__opt-num">04</span><span class="qx__opt-label">Longevity, anti-aging, sustained vitality</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="goal" data-v="performance"><span class="qx__opt-num">05</span><span class="qx__opt-label">Performance and body recomposition</span><span class="qx__opt-arrow">→</span></button>
        </div>
      </div>

      {/* Step 2 */}
      <div class="qx__step" data-step="2">
        <p class="qx__q" id="qx-q2" role="heading" aria-level="3">What is your <span class="italic-display">age range</span>?</p>
        <div class="qx__options" role="group" aria-labelledby="qx-q2">
          <button class="qx__opt" data-q="age" data-v="u35"><span class="qx__opt-num">01</span><span class="qx__opt-label">Under 35</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="age" data-v="35to44"><span class="qx__opt-num">02</span><span class="qx__opt-label">35 to 44</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="age" data-v="45to54"><span class="qx__opt-num">03</span><span class="qx__opt-label">45 to 54</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="age" data-v="55plus"><span class="qx__opt-num">04</span><span class="qx__opt-label">55 and up</span><span class="qx__opt-arrow">→</span></button>
        </div>
      </div>

      {/* Step 3 */}
      <div class="qx__step" data-step="3">
        <p class="qx__q" id="qx-q3" role="heading" aria-level="3">For protocol routing, sex <span class="italic-display">assigned at birth</span>?</p>
        <div class="qx__options" role="group" aria-labelledby="qx-q3">
          <button class="qx__opt" data-q="sex" data-v="m"><span class="qx__opt-num">01</span><span class="qx__opt-label">Male</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="sex" data-v="f"><span class="qx__opt-num">02</span><span class="qx__opt-label">Female</span><span class="qx__opt-arrow">→</span></button>
        </div>
      </div>

      {/* Step 4 */}
      <div class="qx__step" data-step="4">
        <p class="qx__q" id="qx-q4" role="heading" aria-level="3">How <span class="italic-display">active</span> are you?</p>
        <div class="qx__options" role="group" aria-labelledby="qx-q4">
          <button class="qx__opt" data-q="activity" data-v="sedentary"><span class="qx__opt-num">01</span><span class="qx__opt-label">Mostly sedentary right now</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="activity" data-v="moderate"><span class="qx__opt-num">02</span><span class="qx__opt-label">2 to 4 workouts a week</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="activity" data-v="athlete"><span class="qx__opt-num">03</span><span class="qx__opt-label">5+ sessions, training with intent</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="activity" data-v="competitive"><span class="qx__opt-num">04</span><span class="qx__opt-label">Competitive athlete or high performer</span><span class="qx__opt-arrow">→</span></button>
        </div>
      </div>

      {/* Step 5 */}
      <div class="qx__step" data-step="5">
        <p class="qx__q" id="qx-q5" role="heading" aria-level="3">Where is your <span class="italic-display">monthly comfort</span>?</p>
        <div class="qx__options" role="group" aria-labelledby="qx-q5">
          <button class="qx__opt" data-q="budget" data-v="b99"><span class="qx__opt-num">01</span><span class="qx__opt-label">Up to $99 a month</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="budget" data-v="b199"><span class="qx__opt-num">02</span><span class="qx__opt-label">Up to $199 a month</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="budget" data-v="b349"><span class="qx__opt-num">03</span><span class="qx__opt-label">Up to $349 a month</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="budget" data-v="bmax"><span class="qx__opt-num">04</span><span class="qx__opt-label">$349 and up, build me the plan</span><span class="qx__opt-arrow">→</span></button>
        </div>
      </div>

      {/* Step 6 · gate */}
      <div class="qx__step" data-step="6">
        <p class="qx__q" role="heading" aria-level="3">Almost done. <span class="italic-display">Three details</span> to see your match.</p>
        <p class="qx__lede">
          I'll email your matched protocol plus the Precision Hormone &amp;
          Peptide Therapy eBook. I follow up personally only if you want me to.
        </p>
        <NoPhiNotice />
        <form class="qx__form" id="qx-form" novalidate>
          <div class="field"><label for="qx-name" class="field__label">Your name</label><input id="qx-name" name="name" type="text" class="field__input" autocomplete="name" required placeholder="First and last" /></div>
          <div class="field"><label for="qx-email" class="field__label">Email</label><input id="qx-email" name="email" type="email" class="field__input" autocomplete="email" required placeholder="you@example.com" /></div>
          <div class="field"><label for="qx-phone" class="field__label">Phone</label><input id="qx-phone" name="phone" type="tel" class="field__input" autocomplete="tel" placeholder="(512) 555-0123" /><span class="field__hint">Optional. Only used if you ask me to call or text.</span></div>
          <div class="hp" aria-hidden="true"><label>Leave empty<input name="company" type="text" tabindex="-1" autocomplete="off" /></label></div>
          <div class="cf-turnstile" data-sitekey={TURNSTILE_SITEKEY} data-theme="light"></div>
          <button type="submit" class="btn btn--bronze" id="qx-submit">Reveal my protocol</button>
          <div class="qx__status" id="qx-status" role="status" aria-live="polite"></div>
        </form>
      </div>

      {/* Step 7 · result */}
      <div class="qx__step" data-step="7" tabindex="-1">
        <span class="eyebrow">Your match</span>
        <h2 class="qx__result-title">
          <span class="italic-display">Recommended:</span><br/>
          <span id="qx-r-name">Viva Concierge</span>
        </h2>
        <div class="qx__result-card">
          <div class="qx__result-price">
            <span class="qx__result-amt" id="qx-r-price">$99</span>
            <span class="qx__result-cad">/mo</span>
          </div>
          <p class="qx__result-body" id="qx-r-body">A starting protocol calibrated to your answers.</p>
          <ul class="qx__result-list" id="qx-r-list"></ul>
          <div class="qx__discuss">
            <span class="qx__discuss-label">Bring to your discovery call</span>
            <p class="qx__discuss-hint">
              Based on your answers, worth asking Liliana about. Conversation
              starters, not prescriptions — she confirms what fits clinically
              on the call.
            </p>
            <ul class="qx__result-list qx__result-list--discuss" id="qx-r-discuss"></ul>
          </div>
          <div class="qx__result-ctas">
            <a href="/start?utm_source=vivawellnessco&utm_medium=cta&utm_content=home_quiz_result" class="btn btn--bronze">Book your first visit</a>
            <a href="/services" class="btn">See all programs</a>
          </div>
          <p class="qx__result-note">
            The eBook is on its way to your inbox. This match is a starting point;
            your final protocol is tailored during your consult. Compounded
            medications, when included, are dispensed by FDA-regulated 503A
            pharmacies only after clinical evaluation and provider approval.
          </p>
        </div>
      </div>

      <button class="qx__back" id="qx-back" aria-label="Previous question" hidden>← Back</button>
      <button class="qx__exit" id="qx-exit" type="button" aria-label="Exit quiz">×</button>
    </div>
  </section>

  {/* ============ PROGRAMS ============ */}
  <section class="section section--imgbg">
    <img class="section__bg" src="/programs-bg.webp" alt="" aria-hidden="true" loading="lazy" decoding="async" />
    <div class="container">
      <div class="section-head">
        <span class="index" data-num="02">The programs</span>
        <h2 class="section-head__title">
          Explore the programs <span class="italic-display">and memberships.</span>
        </h2>
        <p class="lead section-head__lead">
          From a $99 concierge entry point to a $499 fully-managed metabolic
          plan. Every tier includes provider access, home delivery, and protocol
          adjustments built in.
        </p>
      </div>

      <ul class="programs">
        {programs.map((p) => (
          <li class:list={["program", p.featured && 'program--featured']}>
            <svg class="program__ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={PICON[p.icon]} />
            <span class="program__tier">{p.tier}</span>
            <h3 class="program__name">{p.name}</h3>
            <div class="program__price">
              <span class="program__price-amt">{p.price}</span>
              <span class="program__price-cad">{p.cadence}</span>
            </div>
            <p class="program__body">{p.body}</p>
            <a href={p.href} class="program__link">Learn more →</a>
          </li>
        ))}
      </ul>

      <p class="programs-terms">
        Individual results vary. Memberships include an initial 12-week commitment, then renew
        automatically every 30 days; cancel anytime after the first 12 weeks · <a href="/terms">membership terms</a>.
      </p>

      <div class="programs-foot">
        <a href="/services" class="btn">See all programs</a>
      </div>
    </div>
  </section>

  {/* ============ PROVIDER BAND · a real, named provider ============ */}
  <section class="provider-band section--paper">
    <div class="container provider-band__inner">
      <figure class="provider-band__media to-reveal">
        <div class="provider-band__frame" transition:name="provider-photo">
          <img
            src="/liliana-new.webp"
            alt="Liliana Damron, APRN, FNP-BC"
            width="640"
            height="800"
            loading="lazy"
            decoding="async"
          />
        </div>
        <figcaption class="provider-band__caption">
          <span class="provider-band__name">Liliana Damron</span>
          <span class="provider-band__creds">APRN, FNP-BC · Founder</span>
        </figcaption>
      </figure>

      <div class="provider-band__copy to-reveal">
        <span class="index" data-num="03">Your provider</span>
        <h2 class="provider-band__title">
          A real, named provider, <span class="italic-display">not a delegate.</span>
        </h2>
        <p class="provider-band__voice">
          &ldquo;Your first visit is with me, Liliana, not a delegate, not a
          questionnaire, not a chatbot. I read your chart and approve your
          protocol myself.&rdquo;
        </p>
        <a href="/about" class="btn btn--bronze provider-band__cta">Meet your provider</a>
      </div>
    </div>
  </section>

  {/* ============ TESTIMONIALS ============ */}
  <section class="testimonials">
    <img class="testimonials__bg" src="/testimonials-bg.webp" alt="" aria-hidden="true" loading="lazy" decoding="async" />
    <div class="container">
      <div class="testimonials__head">
        <span class="index" data-num="04">In their words</span>
        <h2 class="testimonials__title">
          Five stars. <span class="italic-display">Eighty-six reviews.</span><br/>
          Verified on Google.
