---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: 'Is Viva Wellness Co. accepting new patients?',
    a: "Yes. We're licensed in Texas, Colorado, and Florida and currently accepting new patients in all three states. New patient visits typically book within a week.",
  },
  {
    q: 'Which states are you licensed in?',
    a: 'Texas, Colorado, and Florida. We are a one-hundred-percent telehealth practice, so visits happen by secure video wherever you are physically located in one of those states at the time of the appointment.',
  },
  {
    q: 'Do you accept insurance?',
    a: 'Memberships are not billed to insurance. We accept FSA and HSA cards for membership fees. For labs and non-compounded medications outside the membership, insurance can be applied. Many patients use the Viva Concierge tier specifically to keep their existing insurance for labs and prescriptions.',
  },
  {
    q: 'Where are your medications sourced from?',
    a: 'Every compounded medication we dispense comes from FDA-regulated 503A compounding pharmacies that perform third-party testing for potency and sterility. We do not work with grey-market peptide vendors. Medications ship from the pharmacy directly to your home.',
  },
  {
    q: 'How fast will I receive the eBook after submitting a form?',
    a: 'The Precision Hormone & Peptide Therapy eBook is emailed automatically, usually within sixty seconds. If you do not see it, check your spam folder or email info@vivawellnessco.com and we will resend.',
  },
  {
    q: 'Can I cancel my membership?',
    a: 'Yes. Memberships require an initial twelve-week commitment so the protocol has enough runway to produce measurable results. After that, you can cancel any time with no penalty. Memberships renew automatically every thirty days until you cancel.',
  },
  {
    q: "What's the difference between TRT All Inclusive and HRT Guidance?",
    a: 'TRT All Inclusive ($199 per month) bundles compounded testosterone, supplies, biannual labs, and home delivery into one flat fee. HRT Guidance ($99 per month) is provider oversight only, designed for patients who want to use their insurance for labs and prescriptions. Same clinical attention; different financial structure.',
  },
  {
    q: 'Is my health information private?',
    a: "This website only collects marketing leads (name, email, phone, quiz answers). We do not collect protected health information here. Once you become a patient, all clinical communication moves into our HIPAA-compliant patient portal. Lab results, medication adjustments, and provider messaging happen there, not on this site or in regular email.",
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const pillars = [
  { num: '01', title: 'Hormone Optimization', body: 'TRT and HRT protocols calibrated to how you want to feel and perform, not just where the lab range starts.' },
  { num: '02', title: 'Metabolic Reset', body: 'Compounded GLP-1 protocols stepped to your physiology. Real appetite control without losing the muscle you trained for.' },
  { num: '03', title: 'Recovery & Healing', body: 'Peptide stacks that close the gap between training load and what your body can actually recover from. BPC-157, TB-500, GHK-Cu.' },
  { num: '04', title: 'Performance', body: 'Support for athletes and high-output professionals. Peptide and hormone protocols calibrated to keep you on the line, not behind it.' },
  { num: '05', title: 'Recomp', body: 'Coordinated metabolic, hormone, and recovery support designed to shift body composition while keeping training intact.' },
  { num: '06', title: 'Lifestyle & Longevity', body: 'Long-arc protocols for healthspan. Sleep, hormones, inflammation, and longevity peptides managed as one system.' },
];

const programs = [
  { tier: 'Entry', name: 'Viva Concierge', price: '$99', cadence: '/mo', body: 'Concierge provider access for evaluation, ongoing guidance, and insurance-based labs across hormones, metabolic, and recovery.' },
  { tier: 'Foundational', name: 'TRT All Inclusive', price: '$199', cadence: '/mo', body: 'Personalized testosterone optimization with compounded medication, supplies, and biannual labs.' },
  { tier: 'Core', name: 'Metabolic Core', price: '$349', cadence: '/mo', body: 'Stepped-up GLP-1 protocol for stronger appetite control and consistent fat loss.', featured: true },
  { tier: 'Premium', name: 'Peak Performance', price: '$699', cadence: '/mo', body: 'Total-body optimization combining metabolic, recovery, and performance protocols in one plan.' },
];
---

<Layout
  title="Concierge Telehealth in Austin | GLP-1, TRT, Performance Medicine | Viva Wellness Co."
  description="Provider-led concierge telehealth in Austin, TX. GLP-1 weight loss, TRT, hormone optimization, recovery, and recomposition protocols. Texas, Colorado, Florida. Founded by Liliana Damron, APRN, FNP-BC."
  schema={faqSchema}
>

  {/* ============ HERO · Matt Johnson full-bleed ============ */}
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <img
        src="/matt-johnson.jpg"
        srcset="/matt-johnson-sm.jpg 800w, /matt-johnson.jpg 1600w"
        sizes="100vw"
        alt=""
        fetchpriority="high"
      />
      <div class="hero__bg-grad"></div>
    </div>

    <div class="container hero__inner">
      <div class="hero__eyebrows reveal" style="--d: 100ms;">
        <span class="eyebrow">Telehealth · TX · CO · FL</span>
        <span class="eyebrow hero__eyebrow-right">· 100% Concierge</span>
      </div>

      <h1 class="hero__title">
        <span class="reveal" style="--d: 200ms;">Performance</span>
        <span class="reveal" style="--d: 360ms;">medicine,</span>
        <span class="italic-display reveal" style="--d: 540ms;">engineered</span>
        <span class="reveal" style="--d: 700ms;">for the body</span>
        <span class="reveal" style="--d: 860ms;">you train.</span>
      </h1>

      <div class="hero__foot reveal" style="--d: 1100ms;">
        <p class="hero__lead">
          Provider-led protocols for hormone optimization, metabolic reset,
          recovery, and recomposition. Concierge care, delivered virtually
          from Austin.
        </p>
        <div class="hero__ctas">
          <a href="https://vivawellnessco.glossgenius.com/?utm_source=vivawellnessco&utm_medium=cta&utm_content=home_hero" target="_blank" rel="noopener" class="btn btn--bronze">Start Your Protocol</a>
          <a href="#quiz" class="btn hero__btn-quiet">Protocol match quiz</a>
        </div>
      </div>

      <div class="hero__index reveal" style="--d: 1300ms;">
        <span class="index" data-num="00">Founded by Liliana Damron, APRN, FNP-BC</span>
      </div>

      <figcaption class="hero__credit reveal" style="--d: 1400ms;" aria-hidden="true">
        <span class="hero__credit-name">Matt Johnson</span>
        <span class="hero__credit-role">Austin athlete · ultra runner</span>
      </figcaption>
    </div>
  </section>

  {/* ============ MARQUEE ============ */}
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span>Recover smarter</span>
      <span>Train harder</span>
      <span>Live longer</span>
      <span>Optimize hormones</span>
      <span>Reset metabolism</span>
      <span>Rebuild stronger</span>
      <span>Recover smarter</span>
      <span>Train harder</span>
      <span>Live longer</span>
      <span>Optimize hormones</span>
      <span>Reset metabolism</span>
      <span>Rebuild stronger</span>
    </div>
  </div>

  {/* ============ PILLARS ============ */}
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="index" data-num="01">The work</span>
        <h2 class="section-head__title">
          Six pillars. <span class="italic-display">Unlimited potential.</span>
        </h2>
        <p class="lead section-head__lead">
          Viva treats the body as one system. Hormones, metabolism, recovery,
          performance, body composition, and longevity work together. Pull on
          one and the rest move. Every membership is built around whole-body
          optimization, managed by a single provider.
        </p>
      </div>

      <ul class="pillars">
        {pillars.map((p) => (
          <li class="pillar">
            <span class="pillar__num">{p.num}</span>
            <h3 class="pillar__title">{p.title}</h3>
            <p class="pillar__body">{p.body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  {/* ============ INLINE QUIZ · the showpiece ============ */}
  <section class="qx" id="quiz">
    <div class="container qx__inner">

      <div class="qx__head">
        <span class="index" data-num="02">The match</span>
        <h2 class="qx__title">
          Find your protocol, <span class="italic-display">take our match quiz.</span>
        </h2>
        <div class="qx__meta">
          <span class="eyebrow" id="qx-step-label">Question 1 of 5</span>
          <div class="qx__progress" aria-hidden="true">
            <div class="qx__progress-bar" id="qx-bar"></div>
          </div>
        </div>
      </div>

      {/* Step 1 */}
      <div class="qx__step is-active" data-step="1">
        <p class="qx__q" role="heading" aria-level="3">What is your <span class="italic-display">primary goal</span> right now?</p>
        <div class="qx__options">
          <button class="qx__opt" data-q="goal" data-v="weight"><span class="qx__opt-num">01</span><span class="qx__opt-label">Lose weight or reset metabolism</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="goal" data-v="hormones"><span class="qx__opt-num">02</span><span class="qx__opt-label">Optimize hormones · energy, libido, mood</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="goal" data-v="recovery"><span class="qx__opt-num">03</span><span class="qx__opt-label">Recover from training, surgery, or injury</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="goal" data-v="longevity"><span class="qx__opt-num">04</span><span class="qx__opt-label">Longevity, anti-aging, sustained vitality</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="goal" data-v="performance"><span class="qx__opt-num">05</span><span class="qx__opt-label">Performance and body recomposition</span><span class="qx__opt-arrow">→</span></button>
        </div>
      </div>

      {/* Step 2 */}
      <div class="qx__step" data-step="2">
        <p class="qx__q" role="heading" aria-level="3">What is your <span class="italic-display">age range</span>?</p>
        <div class="qx__options">
          <button class="qx__opt" data-q="age" data-v="u35"><span class="qx__opt-num">01</span><span class="qx__opt-label">Under 35</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="age" data-v="35to44"><span class="qx__opt-num">02</span><span class="qx__opt-label">35 to 44</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="age" data-v="45to54"><span class="qx__opt-num">03</span><span class="qx__opt-label">45 to 54</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="age" data-v="55plus"><span class="qx__opt-num">04</span><span class="qx__opt-label">55 and up</span><span class="qx__opt-arrow">→</span></button>
        </div>
      </div>

      {/* Step 3 */}
      <div class="qx__step" data-step="3">
        <p class="qx__q" role="heading" aria-level="3">For protocol routing, sex <span class="italic-display">assigned at birth</span>?</p>
        <div class="qx__options">
          <button class="qx__opt" data-q="sex" data-v="m"><span class="qx__opt-num">01</span><span class="qx__opt-label">Male</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="sex" data-v="f"><span class="qx__opt-num">02</span><span class="qx__opt-label">Female</span><span class="qx__opt-arrow">→</span></button>
        </div>
      </div>

      {/* Step 4 */}
      <div class="qx__step" data-step="4">
        <p class="qx__q" role="heading" aria-level="3">How <span class="italic-display">active</span> are you?</p>
        <div class="qx__options">
          <button class="qx__opt" data-q="activity" data-v="sedentary"><span class="qx__opt-num">01</span><span class="qx__opt-label">Mostly sedentary right now</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="activity" data-v="moderate"><span class="qx__opt-num">02</span><span class="qx__opt-label">2 to 4 workouts a week</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="activity" data-v="athlete"><span class="qx__opt-num">03</span><span class="qx__opt-label">5+ sessions, training with intent</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="activity" data-v="competitive"><span class="qx__opt-num">04</span><span class="qx__opt-label">Competitive athlete or high performer</span><span class="qx__opt-arrow">→</span></button>
        </div>
      </div>

      {/* Step 5 */}
      <div class="qx__step" data-step="5">
        <p class="qx__q" role="heading" aria-level="3">Where is your <span class="italic-display">monthly comfort</span>?</p>
        <div class="qx__options">
          <button class="qx__opt" data-q="budget" data-v="b99"><span class="qx__opt-num">01</span><span class="qx__opt-label">Up to $99 a month</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="budget" data-v="b199"><span class="qx__opt-num">02</span><span class="qx__opt-label">Up to $199 a month</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="budget" data-v="b349"><span class="qx__opt-num">03</span><span class="qx__opt-label">Up to $349 a month</span><span class="qx__opt-arrow">→</span></button>
          <button class="qx__opt" data-q="budget" data-v="bmax"><span class="qx__opt-num">04</span><span class="qx__opt-label">$349 and up, build me the plan</span><span class="qx__opt-arrow">→</span></button>
        </div>
      </div>

      {/* Step 6 · gate */}
      <div class="qx__step" data-step="6">
        <p class="qx__q" role="heading" aria-level="3">Almost done. <span class="italic-display">Three details</span> to see your match.</p>
        <p class="qx__lede">
          We'll email your matched protocol plus the Precision Hormone &amp;
          Peptide Therapy eBook. Liliana follows up personally only if you want her to.
        </p>
        <form class="qx__form" id="qx-form" novalidate>
          <div class="field"><label for="qx-name" class="field__label">Your name</label><input id="qx-name" name="name" type="text" class="field__input" autocomplete="name" required placeholder="First and last" /></div>
          <div class="field"><label for="qx-email" class="field__label">Email</label><input id="qx-email" name="email" type="email" class="field__input" autocomplete="email" required placeholder="you@example.com" /></div>
          <div class="field"><label for="qx-phone" class="field__label">Phone</label><input id="qx-phone" name="phone" type="tel" class="field__input" autocomplete="tel" placeholder="(512) 555-0123" /><span class="field__hint">Optional. Only used if you ask us to call or text.</span></div>
          <div class="hp" aria-hidden="true"><label>Leave empty<input name="company" type="text" tabindex="-1" autocomplete="off" /></label></div>
          <button type="submit" class="btn btn--bronze" id="qx-submit">Reveal my protocol</button>
          <div class="qx__status" id="qx-status" role="status" aria-live="polite"></div>
        </form>
      </div>

      {/* Step 7 · result */}
      <div class="qx__step" data-step="7">
        <span class="eyebrow">Your match</span>
        <h2 class="qx__result-title">
          <span class="italic-display">Recommended:</span><br/>
          <span id="qx-r-name">Viva Concierge</span>
        </h2>
        <div class="qx__result-card">
          <div class="qx__result-price">
            <span class="qx__result-amt" id="qx-r-price">$99</span>
            <span class="qx__result-cad">/mo</span>
          </div>
          <p class="qx__result-body" id="qx-r-body">A starting protocol calibrated to your answers.</p>
          <ul class="qx__result-list" id="qx-r-list"></ul>
          <div class="qx__result-ctas">
            <a href="https://vivawellnessco.glossgenius.com/?utm_source=vivawellnessco&utm_medium=cta&utm_content=home_quiz_result" target="_blank" rel="noopener" class="btn btn--bronze">Book your first visit</a>
            <a href="/services" class="btn">See all programs</a>
          </div>
          <p class="qx__result-note">
            The eBook is on its way to your inbox. This match is a starting point ·
            your final protocol will be tailored during your consult.
          </p>
        </div>
      </div>

      <button class="qx__back" id="qx-back" aria-label="Previous question" hidden>← Back</button>
    </div>
  </section>

  {/* ============ PROVIDER ============ */}
  <section class="section section--paper">
    <div class="container provider">
      <div class="provider__media">
        <div class="provider__photo" transition:name="provider-photo">
          <img
            src="/liliana.jpg"
            srcset="/liliana-sm.jpg 600w, /liliana.jpg 1200w"
            sizes="(max-width: 900px) 100vw, 42vw"
            alt="Liliana Damron, APRN, FNP-BC, founder of Viva Wellness Co."
            loading="lazy"
          />
        </div>
        <span class="provider__caption">
          Liliana Damron, APRN, FNP-BC<br/>
          Founder &amp; Lead Provider
        </span>
      </div>
      <div class="provider__copy">
        <span class="index" data-num="03">The provider</span>
        <h2 class="provider__title">
          Founded by a nurse practitioner who watched <span class="italic-display">preventable disease</span> steal people's lives.
        </h2>
        <p class="lead">
          With a background in geriatric medicine, Liliana built Viva to do the
          opposite of what she saw every day. The goal isn't to manage decline. It
          is to extend strength, function, and capacity, so your healthspan
          finally matches your lifespan.
        </p>
        <p>
          Every protocol is reviewed and approved by a licensed provider. Every
          medication is sourced from FDA-regulated 503A compounding pharmacies
          with third-party testing for potency and sterility. No sketchy vials.
          No shady websites. Just performance medicine done correctly.
        </p>
        <a href="/about" class="btn btn--ink">Read the story</a>
      </div>
    </div>
  </section>

  {/* ============ PROGRAMS ============ */}
  <section class="section">
    <div class="container">
      <div class="section-head">
        <span class="index" data-num="04">The programs</span>
        <h2 class="section-head__title">
          Explore our programs <span class="italic-display">and memberships.</span>
        </h2>
        <p class="lead section-head__lead">
          From a $99 concierge entry point to a $699 fully-loaded performance
          plan. Every tier includes provider access, home delivery, and protocol
          adjustments built in.
        </p>
      </div>

      <ul class="programs">
        {programs.map((p) => (
          <li class:list={["program", p.featured && 'program--featured']}>
            <span class="program__tier">{p.tier}</span>
            <h3 class="program__name">{p.name}</h3>
            <div class="program__price">
              <span class="program__price-amt">{p.price}</span>
              <span class="program__price-cad">{p.cadence}</span>
            </div>
            <p class="program__body">{p.body}</p>
            <a href="/services" class="program__link">Learn more →</a>
          </li>
        ))}
      </ul>

      <div class="programs-foot">
        <a href="/services" class="btn">See all programs</a>
      </div>
    </div>
  </section>

  {/* ============ NETWORK ROTATOR ============ */}
  <section class="network" id="network">
    <div class="container">
      <div class="network__head">
        <span class="index" data-num="05">The network</span>
        <h2 class="network__title">
          The Austin partners <span class="italic-display">we trust</span> with our patients.
        </h2>
        <p class="lead">
          Concierge medicine is a small piece of total care. For everything that
          falls outside our scope, we work with practitioners we'd send our own
          family to.
        </p>
      </div>

      <div class="rotator" data-rotator>
        <div class="rotator__track" data-rotator-track>

          <article class="rotator__slide is-active" data-slide>
            <div class="rotator__media rotator__media--portrait">
              <img src="/partners/team-perez.avif" alt="Team Perez photo" loading="lazy" decoding="async" onerror="this.style.display='none'; this.parentElement.classList.add('is-empty')" />
              <div class="rotator__media-fallback" aria-hidden="true"><span class="rotator__media-mono">TP</span></div>
            </div>
            <div class="rotator__copy">
              <span class="rotator__cat">Strength &amp; Conditioning</span>
              <h3 class="rotator__name">Team Perez</h3>
              <div class="rotator__operator">Run by Jorge Luis</div>
              <p class="rotator__desc">
                Online and in-person strength coaching for serious lifters and
                hybrid athletes. The training side of the equation Viva doesn't
                cover. Pairs perfectly with metabolic and recomp protocols.
              </p>
              <div class="rotator__links">
                <a href="https://www.pontelaspilas.co/" target="_blank" rel="noopener" class="rotator__link">pontelaspilas.co →</a>
                <a href="https://www.instagram.com/jorge_luis_pt/" target="_blank" rel="noopener" class="rotator__link">@jorge_luis_pt →</a>
              </div>
            </div>
          </article>

          <article class="rotator__slide" data-slide>
            <div class="rotator__media rotator__media--logo">
              <img src="/partners/voltex-pt.svg" alt="Voltex PT logo" loading="lazy" decoding="async" onerror="this.style.display='none'; this.parentElement.classList.add('is-empty')" />
              <div class="rotator__media-fallback" aria-hidden="true"><span class="rotator__media-mono">VPT</span></div>
            </div>
            <div class="rotator__copy">
              <span class="rotator__cat">Physical Therapy</span>
              <h3 class="rotator__name">Voltex PT</h3>
              <div class="rotator__operator">Austin, TX</div>
              <p class="rotator__desc">
                Physical therapy and rehabilitation when a Viva patient needs
                in-person, hands-on care that no telehealth visit can replace.
                Movement assessments, manual therapy, return-to-sport protocols.
              </p>
            </div>
          </article>

          <article class="rotator__slide" data-slide>
            <div class="rotator__media rotator__media--logo rotator__media--logo-dark">
              <img src="/partners/austin-sports-therapy.png" alt="Austin Sports Therapy logo" loading="lazy" decoding="async" onerror="this.style.display='none'; this.parentElement.classList.add('is-empty')" />
              <div class="rotator__media-fallback" aria-hidden="true"><span class="rotator__media-mono">AST</span></div>
            </div>
            <div class="rotator__copy">
              <span class="rotator__cat">Sports Recovery</span>
              <h3 class="rotator__name">Austin Sports Therapy</h3>
              <div class="rotator__operator">Austin, TX</div>
              <p class="rotator__desc">
                Specialized sports injury recovery for athletes and active
                adults. Soft tissue work, joint rehabilitation, performance
                restoration. The kind of care that gets people back to training,
                not just out of pain.
              </p>
            </div>
          </article>

        </div>

        <div class="rotator__controls">
          <div class="rotator__dots" data-dots role="tablist" aria-label="Featured partners">
            <button class="rotator__dot is-active" data-dot="0" aria-label="Show Team Perez"></button>
            <button class="rotator__dot" data-dot="1" aria-label="Show Voltex PT"></button>
            <button class="rotator__dot" data-dot="2" aria-label="Show Austin Sports Therapy"></button>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ============ TESTIMONIALS ============ */}
  <section class="testimonials">
    <div class="container">
      <div class="testimonials__head">
        <span class="index" data-num="06">In their words</span>
        <h2 class="testimonials__title">
          Five stars. <span class="italic-display">Eighty-six reviews.</span><br/>
          Zero exceptions.
        </h2>
