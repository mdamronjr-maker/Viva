<style>
  /* ============ HERO ============ */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 6rem 0 4rem;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(800px 500px at 80% 20%, rgba(201, 120, 58, 0.18), transparent 60%),
      radial-gradient(600px 400px at 10% 90%, rgba(201, 120, 58, 0.10), transparent 60%);
    pointer-events: none;
  }
  .hero__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  .hero__title {
    font-size: clamp(3.2rem, 11vw, 9rem);
    font-weight: 320;
    line-height: 0.92;
    letter-spacing: -0.035em;
    max-width: 14ch;
  }
  .hero__title span { display: inline-block; }
  .hero__title .italic-display { color: var(--bronze-bright); }
  .hero__foot {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: end;
    margin-top: 2rem;
  }
  .hero__ctas { display: flex; gap: 1rem; flex-wrap: wrap; justify-self: end; }
  .hero__index {
    border-top: 1px solid var(--rule-strong);
    padding-top: 1rem;
    margin-top: 1rem;
  }
  @media (max-width: 760px) {
    .hero { min-height: 80vh; }
    .hero__foot { grid-template-columns: 1fr; gap: 1.8rem; }
    .hero__ctas { justify-self: start; }
  }

  /* ============ SECTION HEAD ============ */
  .section-head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
    margin-bottom: 4rem;
    max-width: 100%;
  }
  .section-head__title {
    font-size: clamp(2.2rem, 5.5vw, 4.5rem);
    max-width: 16ch;
  }
  .section-head__title .italic-display { color: var(--bronze); }
  .section--paper .section-head__title .italic-display { color: var(--bronze-deep); }
  .section-head__lead { margin-top: 0.5rem; }

  /* ============ QUIZ TEASER ============ */
  .quiz-teaser {
    padding: clamp(4rem, 8vw, 6rem) 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    position: relative;
    overflow: hidden;
  }
  .quiz-teaser::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(700px 400px at 20% 50%, rgba(201, 120, 58, 0.12), transparent 60%);
    pointer-events: none;
  }
  .quiz-teaser__inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }
  @media (max-width: 800px) {
    .quiz-teaser__inner { grid-template-columns: 1fr; }
  }
  .quiz-teaser__title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    margin: 1rem 0 1.2rem;
    max-width: 14ch;
  }
  .quiz-teaser__title .italic-display { color: var(--bronze-bright); }
  .quiz-teaser__copy .btn { margin-top: 0.5rem; }
  .quiz-teaser__visual {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .quiz-teaser__num {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 360;
    color: var(--bronze);
    width: 3rem;
    height: 3rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--rule-strong);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .quiz-teaser__line {
    width: 1.5rem;
    height: 1px;
    background: var(--rule-strong);
    flex-shrink: 0;
  }
  @media (max-width: 800px) {
    .quiz-teaser__visual { display: none; }
  }

  /* ============ PILLARS ============ */
  .pillars {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--rule-strong);
  }
  .pillar {
    padding: 2rem 1.5rem 2rem 0;
    border-right: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule-strong);
    transition: background 240ms var(--ease);
  }
  .pillar:last-child { border-right: 0; }
  .pillar:hover { background: rgba(201, 120, 58, 0.04); }
  .pillar__num {
