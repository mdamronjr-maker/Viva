---
import Layout from '../layouts/Layout.astro';

const bookingUrl = 'https://vivawellnessco.glossgenius.com/';
---

<Layout title="Book Your Visit — Viva Wellness Co." description="Schedule your first telehealth visit with Viva Wellness Co. Provider-led performance medicine, delivered virtually from Austin, TX.">

  <section class="book-shell">
    <div class="container book-shell__inner">

      <div class="book-head">
        <span class="eyebrow reveal" style="--d: 100ms;">— Booking</span>
        <h1 class="book-title reveal" style="--d: 250ms;">
          Schedule your <span class="italic-display">first visit.</span>
        </h1>
        <p class="lead reveal" style="--d: 450ms;">
          Pick a time that works for you. The first visit is a 45-minute telehealth
          consult where Liliana reviews your goals, history, and any current labs,
          then recommends a protocol if you're a fit.
        </p>
      </div>

      <div class="book-frame-wrap" data-frame-wrap>
        <iframe
          src={bookingUrl}
          title="Viva Wellness booking"
          class="book-frame"
          loading="lazy"
          allow="payment"
          data-book-frame
        ></iframe>

        <div class="book-fallback" data-book-fallback hidden>
          <span class="eyebrow">— Continue securely</span>
          <h2>Booking opens in a new tab.</h2>
          <p>
            For your security, our scheduling system runs on a separate domain.
            Click below to continue. You'll come right back when you're done.
          </p>
          <a href={bookingUrl} target="_blank" rel="noopener" class="btn btn--bronze">
            Open booking
          </a>
        </div>
      </div>

      <div class="book-note">
        <div class="book-note__col">
          <span class="book-note__label">What happens next</span>
          <p>You'll receive a confirmation by email within minutes, plus a telehealth link by text on the day of the visit. Bring any recent labs you'd like Liliana to review.</p>
        </div>
        <div class="book-note__col">
          <span class="book-note__label">Need help?</span>
          <p>Email <a href="mailto:info@vivawellnessco.com">info@vivawellnessco.com</a> or text <a href="tel:7372107283">(737) 210-7283</a>. We answer within one business day.</p>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script is:inline>
  // If GlossGenius sends X-Frame-Options that block embedding, the iframe will fail
  // to load. Detect and swap to fallback.
  (() => {
    const frame = document.querySelector('[data-book-frame]');
    const fallback = document.querySelector('[data-book-fallback]');
    if (!frame || !fallback) return;

    let loaded = false;
    frame.addEventListener('load', () => {
      // The iframe fired load. In most blocked cases the load event still fires
      // but the document is empty. Try to detect this with contentWindow access.
      // Cross-origin will throw, which is normal and means it loaded fine.
      try {
        // If we CAN access (same-origin or empty), it failed.
        const doc = frame.contentDocument;
        if (doc === null || (doc && doc.body && doc.body.children.length === 0)) {
          showFallback();
          return;
        }
      } catch (e) {
        // Cross-origin error = success. Frame loaded normally.
      }
      loaded = true;
    });

    // Hard timeout: if nothing loads in 5s, fall back.
    setTimeout(() => {
      if (!loaded) showFallback();
    }, 5000);

    function showFallback() {
      frame.style.display = 'none';
      fallback.hidden = false;
    }
  })();
</script>

<style>
  .book-shell {
    padding: clamp(3rem, 7vw, 6rem) 0 clamp(4rem, 8vw, 7rem);
    position: relative;
    overflow: hidden;
    min-height: 90vh;
  }
  .book-shell::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(800px 500px at 80% 20%, rgba(201, 120, 58, 0.12), transparent 60%);
    pointer-events: none;
  }
  .book-shell__inner { position: relative; }

  .book-head {
    max-width: 820px;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .book-title {
    font-size: clamp(2.6rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.025em;
    margin: 1rem 0 1.5rem;
    max-width: 16ch;
  }
  .book-title .italic-display { color: var(--bronze-bright); }

  /* IFRAME WRAPPER */
  .book-frame-wrap {
    position: relative;
    background: var(--paper);
    border: 1px solid var(--rule-strong);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: clamp(2rem, 4vw, 3rem);
    box-shadow: 0 30px 60px -20px rgba(0, 0, 0, 0.4);
  }
  .book-frame {
    display: block;
    width: 100%;
    height: 1100px;
    border: 0;
    background: var(--paper);
  }
  @media (max-width: 720px) {
    .book-frame { height: 900px; }
  }

  /* FALLBACK */
  .book-fallback {
    padding: clamp(3rem, 7vw, 5rem) clamp(1.5rem, 4vw, 3rem);
    background: var(--ink-2);
    color: var(--paper);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    min-height: 500px;
    justify-content: center;
  }
  .book-fallback h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 380;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0.5rem 0 0.5rem;
    max-width: 18ch;
  }
  .book-fallback p {
    color: rgba(245, 241, 234, 0.78);
    max-width: 50ch;
    margin: 0 0 1rem;
  }

  /* NOTE STRIP */
  .book-note {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--rule-strong);
    border: 1px solid var(--rule-strong);
  }
  @media (max-width: 700px) { .book-note { grid-template-columns: 1fr; } }
  .book-note__col {
    background: var(--ink);
    padding: 1.7rem 1.7rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .book-note__label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--bronze);
  }
  .book-note__col p {
    color: rgba(245, 241, 234, 0.75);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0;
  }
  .book-note__col a {
    color: var(--bronze);
    border-bottom: 1px solid rgba(201, 120, 58, 0.4);
    transition: color 200ms var(--ease), border-color 200ms var(--ease);
  }
  .book-note__col a:hover {
    color: var(--bronze-bright);
    border-color: var(--bronze-bright);
  }
</style>
